{% extends "layouts/app.njk" %}
{% set nav_active = "reports" %}

{% block title %}Reports · Meridian{% endblock %}

{#
  Reports — analytics page. A stat grid plus four ApexCharts (revenue area,
  category + channel donuts, top-products bar) rendered by charts.js, which
  reads the --st-* tokens and re-themes on stisla:themechange. The period
  control is static (sample data); a real build would refetch on change.
#}
{% macro stat(label, value, delta, dir, icon) %}
  <div class="col-span-6 lg:col-span-3">
    <div class="card h-full">
      <div class="card__body flex-col-reverse md:flex-row gap-4">
        <div class="w-full flex flex-col gap-2">
          <span class="text-sm text-muted-foreground">{{ label }}</span>
          <div class="text-2xl font-bold">{{ value }}</div>
          <div class="flex items-center gap-2">
            <span class="badge badge--soft badge--{{ 'success' if dir == 'up' else 'danger' }}">
              {{ ("solar:graph-" + dir + "-linear") | icon }} {{ delta }}
            </span>
            <span class="text-xs text-muted-foreground">vs last period</span>
          </div>
        </div>
        <span class="icon-box icon-box--primary">{{ icon | icon }}</span>
      </div>
    </div>
  </div>
{% endmacro %}

{% block page %}
<div class="page content">
  <div class="content__container">
    <header class="page__header">
      <div class="page__headline">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb__item"><a href="/dashboard/">Dashboard</a></li>
            <li class="breadcrumb__item" aria-current="page">Reports</li>
          </ol>
        </nav>
        <h1 class="page__title">Reports</h1>
        <p class="page__description">Revenue, orders, and product performance for Meridian.</p>
      </div>
      <div class="page__action">
        <div class="toggle-group" data-stisla-toggle-group role="radiogroup" aria-label="Date range">
          <button type="button" class="toggle" role="radio" aria-checked="false">7d</button>
          <button type="button" class="toggle" role="radio" data-state="active" aria-checked="true">30d</button>
          <button type="button" class="toggle" role="radio" aria-checked="false">90d</button>
        </div>
        <button type="button" class="button button--neutral">{{ "solar:download-minimalistic-linear" | icon }} Export</button>
      </div>
    </header>

    <div class="page__body">
      {# Stat grid #}
      <section class="page__section">
        <div class="grid grid-cols-12 gap-4">
          {{ stat("Revenue", "$48,210", "12%", "up", "solar:dollar-minimalistic-linear") }}
          {{ stat("Orders", "1,284", "8%", "up", "solar:cart-large-2-linear") }}
          {{ stat("Avg. order value", "$37.55", "3%", "up", "solar:bill-list-linear") }}
          {{ stat("Refund rate", "2.4%", "0.6%", "down", "solar:restart-linear") }}
        </div>
      </section>

      {# Revenue + category #}
      <section class="page__section">
        <div class="grid grid-cols-12 gap-4">
          <div class="col-span-12 xl:col-span-8">
            <div class="card h-full">
              <div class="card__header">
                <span class="card__title">Revenue over time</span>
                <span class="badge badge--soft badge--success ms-auto">{{ "solar:graph-up-linear" | icon }} 12%</span>
              </div>
              <div class="card__body">
                <div id="revenueChart" class="chart"></div>
              </div>
            </div>
          </div>
          <div class="col-span-12 xl:col-span-4">
            <div class="card h-full">
              <div class="card__header"><span class="card__title">Sales by category</span></div>
              <div class="card__body">
                <div id="categoryChart" class="chart"></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {# Top products + channels #}
      <section class="page__section">
        <div class="grid grid-cols-12 gap-4">
          <div class="col-span-12 lg:col-span-6">
            <div class="card h-full">
              <div class="card__header"><span class="card__title">Top products</span></div>
              <div class="card__body">
                <div id="topProductsChart" class="chart"></div>
              </div>
            </div>
          </div>
          <div class="col-span-12 lg:col-span-6">
            <div class="card h-full">
              <div class="card__header"><span class="card__title">Sales by channel</span></div>
              <div class="card__body">
                <div id="channelChart" class="chart"></div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
{% endblock %}
