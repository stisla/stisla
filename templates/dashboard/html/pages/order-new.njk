{% extends "layouts/app.njk" %}
{% set nav_active = "orders" %}

{% block title %}New order · Meridian{% endblock %}

{#
  Create / edit order form. The same template serves both: "New order" starts
  blank, "Edit" prefills the controls server-side — the markup is identical.
  The line-items editor (add/remove rows, live totals) is wired by order-form.js.
#}

{% block page %}
<div class="page content">
  <div class="content__container">
    <header class="page__header">
      <div class="page__headline">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb__item"><a href="/dashboard/">Dashboard</a></li>
            <li class="breadcrumb__item"><a href="/dashboard/orders.html">Orders</a></li>
            <li class="breadcrumb__item" aria-current="page">New order</li>
          </ol>
        </nav>
        <h1 class="page__title">New order</h1>
        <p class="page__description">Add products, assign a customer, and set shipping before saving.</p>
      </div>
    </header>

    <div class="page__body">
      <form class="order-form" data-order-form>
        <div class="grid grid-cols-12 gap-4">
          {# ---- Main column ---- #}
          <div class="col-span-12 lg:col-span-8">
            <div class="flex flex-col gap-3">
              {# Line items #}
              <div class="card">
                <div class="card__header"><span class="card__title">Line items</span></div>
                <div class="line-items">
                  <div class="line-items__head" aria-hidden="true">
                    <span>Product</span>
                    <span class="text-end">Qty</span>
                    <span class="text-end">Unit price</span>
                    <span class="text-end">Total</span>
                    <span></span>
                  </div>
                  <div data-line-items>
                    {% set items = [
                      { name: "Aged Cheddar 1kg",  qty: 3, price: "24.00" },
                      { name: "Olive Oil 500ml",   qty: 2, price: "18.50" }
                    ] %}
                    {% for it in items %}
                    <div class="line-items__row" data-line-row>
                      <div class="line-items__field">
                        <span class="line-items__label">Product</span>
                        <input type="text" class="input" value="{{ it.name }}" placeholder="Product name" aria-label="Product name" />
                      </div>
                      <div class="line-items__field">
                        <span class="line-items__label">Qty</span>
                        <input type="number" class="input text-end" value="{{ it.qty }}" min="1" data-qty aria-label="Quantity" />
                      </div>
                      <div class="line-items__field">
                        <span class="line-items__label">Unit price</span>
                        <div class="input-group">
                          <span class="input-group__text">$</span>
                          <input type="number" class="input text-end" value="{{ it.price }}" min="0" step="0.01" data-price aria-label="Unit price" />
                        </div>
                      </div>
                      <div class="line-items__field">
                        <span class="line-items__label">Total</span>
                        <span class="line-items__total" data-line-total>$0.00</span>
                      </div>
                      <div class="line-items__remove">
                        <button type="button" class="button button--soft button--danger" data-remove-item aria-label="Remove item">
                          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
                          <span class="line-items__remove-text">Remove</span>
                        </button>
                      </div>
                    </div>
                    {% endfor %}
                  </div>
                </div>

                <div class="card__body items-end">
                  <button type="button" class="button button--soft button--primary button--sm" data-add-item>
                    {{ "solar:add-circle-linear" | icon }} Add item
                  </button>
                </div>

                <div class="card__footer">
                  <dl class="order-form__totals">
                    <div class="order-form__total-row">
                      <dt>Subtotal</dt>
                      <dd data-subtotal>$0.00</dd>
                    </div>
                    <div class="order-form__total-row">
                      <dt>Tax (10%)</dt>
                      <dd data-tax>$0.00</dd>
                    </div>
                    <div class="order-form__total-row">
                      <dt>Shipping</dt>
                      <dd>
                        <div class="input-group w-30">
                          <span class="input-group__text">$</span>
                          <input type="number" class="input text-end" value="15.00" min="0" step="0.01" data-shipping aria-label="Shipping cost" />
                        </div>
                      </dd>
                    </div>
                    <div class="order-form__total-row order-form__total-row--grand">
                      <dt>Total</dt>
                      <dd data-total>$0.00</dd>
                    </div>
                  </dl>
                </div>
              </div>

              {# Notes #}
              <div class="card">
                <div class="card__header"><span class="card__title">Notes</span></div>
                <div class="card__body">
                  <div class="field">
                    <label for="orderNotes" class="field__label">Order notes</label>
                    <textarea class="textarea" id="orderNotes" rows="3" placeholder="Internal notes, delivery instructions, or anything the team should know."></textarea>
                    <p class="field__description">Notes are private and never shown to the customer.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          {# ---- Side column ---- #}
          <div class="col-span-12 lg:col-span-4">
            <div class="flex flex-col gap-3">
              {# Status #}
              <div class="card">
                <div class="card__header"><span class="card__title">Status</span></div>
                <div class="card__body">
                  <div class="field">
                    <label for="orderStatus" class="field__label">Order status</label>
                    <select class="select" id="orderStatus" data-stisla-select>
                      <option value="pending" selected>Pending</option>
                      <option value="processing">Processing</option>
                      <option value="shipped">Shipped</option>
                      <option value="completed">Completed</option>
                      <option value="cancelled">Cancelled</option>
                    </select>
                  </div>
                  <div class="field">
                    <label for="paymentStatus" class="field__label">Payment status</label>
                    <select class="select" id="paymentStatus" data-stisla-select>
                      <option value="unpaid" selected>Unpaid</option>
                      <option value="paid">Paid</option>
                      <option value="partial">Partially paid</option>
                      <option value="refunded">Refunded</option>
                    </select>
                  </div>
                  <div class="field">
                    <div class="field__item">
                      <input class="switch" type="checkbox" role="switch" id="sendConfirm" checked />
                      <label class="field__label" for="sendConfirm">Send confirmation email</label>
                    </div>
                  </div>
                </div>
              </div>

              {# Customer #}
              <div class="card">
                <div class="card__header"><span class="card__title">Customer</span></div>
                <div class="card__body">
                  <div class="field">
                    <label for="customer" class="field__label">Customer</label>
                    <select class="select" id="customer" data-stisla-select data-placeholder="Search customers">
                      <option value=""></option>
                      <option value="acme">Acme Corp</option>
                      <option value="riverway">Riverway Ltd</option>
                      <option value="northwind">Northwind Traders</option>
                      <option value="globex">Globex</option>
                      <option value="initech">Initech</option>
                    </select>
                  </div>
                  <div class="field">
                    <label for="custEmail" class="field__label">Email</label>
                    <input type="email" class="input" id="custEmail" placeholder="billing@acme.co" />
                  </div>
                  <div class="field">
                    <label for="custPhone" class="field__label">Phone</label>
                    <div class="input-group">
                      <span class="input-group__text">{{ "solar:phone-linear" | icon }}</span>
                      <input type="tel" class="input" id="custPhone" placeholder="+1 555 0123" />
                    </div>
                  </div>
                </div>
              </div>

              {# Shipping #}
              <div class="card">
                <div class="card__header"><span class="card__title">Shipping</span></div>
                <div class="card__body">
                  <div class="field">
                    <label for="shipMethod" class="field__label">Method</label>
                    <select class="select" id="shipMethod" data-stisla-select>
                      <option value="standard" selected>Standard (3–5 days)</option>
                      <option value="express">Express (1–2 days)</option>
                      <option value="pickup">Local pickup</option>
                    </select>
                  </div>
                  <div class="field">
                    <label for="shipAddress" class="field__label">Address</label>
                    <textarea class="textarea" id="shipAddress" rows="3" placeholder="Street, city, state, ZIP"></textarea>
                  </div>
                </div>
              </div>

              {# Tags #}
              <div class="card">
                <div class="card__header"><span class="card__title">Tags</span></div>
                <div class="card__body">
                  <div class="field">
                    <label for="orderTags" class="field__label">Tags</label>
                    <select class="select" id="orderTags" multiple data-stisla-select data-placeholder="Add tags">
                      <option value="vip">VIP</option>
                      <option value="wholesale">Wholesale</option>
                      <option value="rush">Rush</option>
                      <option value="gift">Gift</option>
                      <option value="fragile">Fragile</option>
                    </select>
                    <p class="field__description">Used for filtering and automation rules.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {# Sticky save bar — pins to the bottom of the scrolling main column. #}
        <div class="sticky-bar">
          <div class="me-auto">
            <div class="text-xs text-muted-foreground">Order total</div>
            <div class="text-xl font-bold" data-total>$0.00</div>
          </div>
          <a href="/dashboard/orders.html" class="button button--ghost button--neutral">Cancel</a>
          <button type="submit" class="button button--primary">
            {{ "solar:check-circle-linear" | icon }} Save order
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

{# Row blueprint cloned by "Add item". Kept out of the table so its inputs
   aren't submitted or counted until a row is actually added. #}
<template data-line-template>
  <div class="line-items__row" data-line-row>
    <div class="line-items__field">
      <span class="line-items__label">Product</span>
      <input type="text" class="input" placeholder="Product name" aria-label="Product name" />
    </div>
    <div class="line-items__field">
      <span class="line-items__label">Qty</span>
      <input type="number" class="input text-end" value="1" min="1" data-qty aria-label="Quantity" />
    </div>
    <div class="line-items__field">
      <span class="line-items__label">Unit price</span>
      <div class="input-group">
        <span class="input-group__text">$</span>
        <input type="number" class="input text-end" value="0.00" min="0" step="0.01" data-price aria-label="Unit price" />
      </div>
    </div>
    <div class="line-items__field">
      <span class="line-items__label">Total</span>
      <span class="line-items__total" data-line-total>$0.00</span>
    </div>
    <div class="line-items__remove">
      <button type="button" class="button button--soft button--danger" data-remove-item aria-label="Remove item">
        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
        <span class="line-items__remove-text">Remove</span>
      </button>
    </div>
  </div>
</template>
{% endblock %}
