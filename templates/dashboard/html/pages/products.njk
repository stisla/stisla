{% extends "layouts/app.njk" %}
{% set nav_active = "products" %}

{% block title %}Products · Meridian{% endblock %}

{#
  Products — a plain server-rendered table. Rows come from a for-loop over the
  sample data (the status badge is derived from stock level); sorting, the
  category filter, pagination, and search are server concerns expressed as
  links / a form. Row selection → bulk bar is the only client JS.
#}

{% set products = [
  { name: "Espresso Beans 2kg",     sku: "ESP-2000", category: "Coffee",    price: "32.00", stock: 124 },
  { name: "Ceramic Pour-Over",      sku: "POU-014",  category: "Equipment", price: "45.00", stock: 18 },
  { name: "Paper Filters (100pk)",  sku: "FIL-100",  category: "Supplies",  price: "8.50",  stock: 0 },
  { name: "Cold Brew Concentrate",  sku: "CLD-050",  category: "Coffee",    price: "16.00", stock: 73 },
  { name: "Milk Frother",           sku: "FRO-220",  category: "Equipment", price: "29.00", stock: 9 },
  { name: "Travel Mug",             sku: "MUG-330",  category: "Equipment", price: "24.00", stock: 210 },
  { name: "Gift Box",               sku: "GFT-001",  category: "Gifts",     price: "20.00", stock: 56 },
  { name: "Tasting Notebook",       sku: "NOT-012",  category: "Supplies",  price: "12.00", stock: 0 },
  { name: "Burr Grinder",           sku: "GRD-450",  category: "Equipment", price: "89.00", stock: 7 },
  { name: "Whole Bean Sampler",     sku: "SMP-006",  category: "Gifts",     price: "28.00", stock: 41 }
] %}
{% set categoryFilters = ["all", "Coffee", "Equipment", "Supplies", "Gifts"] %}

{% block page %}
<div class="page content">
  <div class="content__container">
    <header class="page__header">
      <div class="page__headline">
        <h1 class="page__title">Products</h1>
        <p class="page__description">Your catalog of 10 products across four categories.</p>
      </div>
      <div class="page__action">
        <button type="button" class="button button--neutral">{{ "solar:download-minimalistic-linear" | icon }} Export</button>
        <a href="/dashboard/product-new.html" class="button button--primary">{{ "solar:add-circle-linear" | icon }} Add product</a>
      </div>
    </header>

    <div class="page__body">
      <section class="page__section">
        <div class="card" data-table-select>
          {# Toolbar — category filter (server links) + search (server form). #}
          <div class="card__header flex-wrap">
            <div class="toggle-group mt-4 md:mt-0" data-stisla-toggle-group role="radiogroup" aria-label="Filter by category">
              {% for c in categoryFilters %}
              <button type="button" class="toggle" role="radio" aria-checked="{{ 'true' if loop.first else 'false' }}"{% if loop.first %} data-state="active"{% endif %}>{{ "All" if c == "all" else c }}</button>
              {% endfor %}
            </div>
            <form class="input-group ms-auto w-full md:w-60 mb-4 md:mb-0" role="search">
              <span class="input-group__text">{{ "solar:magnifer-linear" | icon }}</span>
              <input type="search" name="q" class="input" placeholder="Search products…" aria-label="Search products" />
            </form>
          </div>

          {# Bulk bar #}
          <div class="card__header card__header--alt flex-wrap" data-bulkbar hidden>
            <span><strong data-select-count>0</strong> selected</span>
            <div class="flex flex-wrap items-center gap-2 ms-auto">
              <button type="button" class="button button--sm button--outline button--neutral">{{ "solar:archive-linear" | icon }} Archive</button>
              <button type="button" class="button button--sm button--danger" data-stisla-dialog-trigger="deleteConfirm">{{ "solar:trash-bin-trash-linear" | icon }} Delete</button>
            </div>
          </div>

          <div class="table-responsive">
            <table class="table table--hover table--align-middle">
              <thead class="table__head--alt">
                <tr>
                  <th scope="col"><input class="checkbox" type="checkbox" data-select-all aria-label="Select all products on this page" /></th>
                  <th scope="col"><a class="table__sort" href="?sort=name">Product</a></th>
                  <th scope="col"><a class="table__sort" href="?sort=category">Category</a></th>
                  <th scope="col" class="text-end"><a class="table__sort" href="?sort=price">Price</a></th>
                  <th scope="col" class="text-end"><a class="table__sort" href="?sort=stock">Stock</a></th>
                  <th scope="col">Status</th>
                  <th scope="col" class="text-end"><span class="sr-only">Actions</span></th>
                </tr>
              </thead>
              <tbody>
                {% for p in products %}
                <tr>
                  <td><input class="checkbox" type="checkbox" data-select-row aria-label="Select {{ p.name }}" /></td>
                  <th scope="row">
                    <div class="flex items-center gap-3">
                      <img class="shrink-0 rounded-sm object-cover" src="https://picsum.photos/seed/{{ p.sku }}/96/96" alt=""
                           width="40" height="40" loading="lazy" />
                      <div>
                        <a href="/dashboard/product-new.html" class="font-medium">{{ p.name }}</a>
                        <div class="text-xs text-muted-foreground">SKU {{ p.sku }}</div>
                      </div>
                    </div>
                  </th>
                  <td>{{ p.category }}</td>
                  <td class="text-end"><span class="font-semibold">${{ p.price }}</span></td>
                  <td class="text-end">{{ p.stock }}</td>
                  <td>
                    {% if p.stock == 0 %}
                    <span class="badge badge--soft badge--danger">Out of stock</span>
                    {% elif p.stock <= 10 %}
                    <span class="badge badge--soft badge--warning">Low stock</span>
                    {% else %}
                    <span class="badge badge--soft badge--success">In stock</span>
                    {% endif %}
                  </td>
                  <td class="text-end">
                    <div class="flex justify-end gap-1">
                      <a href="/dashboard/product-new.html" class="button button--ghost button--neutral button--icon-only button--sm" aria-label="Edit {{ p.name }}">{{ "solar:pen-linear" | icon }}</a>
                      <button type="button" class="button button--ghost button--danger button--icon-only button--sm" data-stisla-dialog-trigger="deleteProduct" data-fill-name="{{ p.name }}" aria-label="Delete {{ p.name }}">{{ "solar:trash-bin-trash-linear" | icon }}</button>
                    </div>
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>

          <div class="card__footer">
            <span class="text-xs text-muted-foreground">Showing 1–10 of 10</span>
            <nav class="ms-auto" aria-label="Products pages">
              <ul class="pagination">
                <li><span class="pagination__button" aria-disabled="true" aria-label="Previous">{{ "solar:alt-arrow-left-linear" | icon }}</span></li>
                <li><a class="pagination__button" href="?page=1" data-state="active" aria-current="page">1</a></li>
                <li><span class="pagination__button" aria-disabled="true" aria-label="Next">{{ "solar:alt-arrow-right-linear" | icon }}</span></li>
              </ul>
            </nav>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>

{# Delete one product — name filled from the row trigger. #}
<div class="dialog dialog--sm" id="deleteProduct" data-stisla-dialog data-state="closed"
     role="alertdialog" aria-modal="true" aria-labelledby="deleteProductLabel"
     aria-describedby="deleteProductDesc" aria-hidden="true" tabindex="-1">
  <div class="dialog__backdrop" data-stisla-dialog-dismiss></div>
  <div class="dialog__panel">
    <div class="dialog__content">
      <button type="button" class="dialog__close" data-stisla-dialog-dismiss aria-label="Close"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
      <div class="dialog__body text-center pt-6">
        <span class="icon-box icon-box--danger icon-box--circle icon-box--lg mb-3">
          {{ "solar:trash-bin-trash-linear" | icon }}
        </span>
        <h3 class="dialog__title mb-1" id="deleteProductLabel">Delete <span data-slot="name"></span>?</h3>
        <p class="text-muted-foreground" id="deleteProductDesc">This removes the product from your catalog. This can't be undone.</p>
      </div>
      <div class="dialog__footer justify-center">
        <button type="button" class="button button--ghost button--neutral" data-stisla-dialog-dismiss>Cancel</button>
        <button type="button" class="button button--danger" data-stisla-dialog-dismiss>Delete product</button>
      </div>
    </div>
  </div>
</div>

{# Bulk-delete dialog. #}
<div class="dialog dialog--sm" id="deleteConfirm" data-stisla-dialog data-state="closed"
     role="alertdialog" aria-modal="true" aria-labelledby="delProdLabel"
     aria-describedby="delProdDesc" aria-hidden="true" tabindex="-1">
  <div class="dialog__backdrop" data-stisla-dialog-dismiss></div>
  <div class="dialog__panel">
    <div class="dialog__content">
      <button type="button" class="dialog__close" data-stisla-dialog-dismiss aria-label="Close"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
      <div class="dialog__body text-center pt-6">
        <span class="icon-box icon-box--danger icon-box--circle icon-box--lg mb-3">
          {{ "solar:trash-bin-trash-linear" | icon }}
        </span>
        <h3 class="dialog__title mb-1" id="delProdLabel">Delete <span data-select-count>0</span> products?</h3>
        <p class="text-muted-foreground" id="delProdDesc">The selected products are permanently removed. This can't be undone.</p>
      </div>
      <div class="dialog__footer justify-center">
        <button type="button" class="button button--ghost button--neutral" data-stisla-dialog-dismiss>Cancel</button>
        <button type="button" class="button button--danger" data-stisla-dialog-dismiss>Delete products</button>
      </div>
    </div>
  </div>
</div>
{% endblock %}
