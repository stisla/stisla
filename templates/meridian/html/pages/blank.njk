{% extends "layouts/app.njk" %}
{% set nav_active = "blank" %}

{% block title %}Blank page · Meridian{% endblock %}

{#
  Blank starter — a clean canvas on the app shell. Duplicate this file and
  drop your own content into the page__section.
#}

{% block page %}
<div class="page content">
  <div class="content__container">
    <header class="page__header">
      <div class="page__headline">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb__item"><a href="/meridian/">Dashboard</a></li>
            <li class="breadcrumb__item" aria-current="page">Blank</li>
          </ol>
        </nav>
        <h1 class="page__title">Blank page</h1>
        <p class="page__description">A clean starting point — duplicate this file and build your view.</p>
      </div>
      <div class="page__action">
        <button type="button" class="button button--primary">{{ "solar:add-circle-linear" | icon }} New</button>
      </div>
    </header>

    <div class="page__body">
      <section class="page__section">
        <div class="card">
          <div class="empty-state">
            <span class="empty-state__media">{{ "solar:documents-linear" | icon }}</span>
            <h3 class="empty-state__title">Your content here</h3>
            <p class="empty-state__text">Replace this card with your page content.</p>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
{% endblock %}
