# Build output
/dist/
/site-dist/
/.tmp/
/.vite/

# Staged package contents — regenerated by `npm run build:packages`.
# Hand-authored package.json + README.md inside each package directory stay tracked.
/packages/*/dist/
/packages/*/scss/
/packages/*/src/
/packages/*/LICENSE
/packages/*/LICENSES/
/packages/*/*.tgz

# Deps
/node_modules/

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
._*
.cache
.idea
.vscode
