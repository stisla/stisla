    "./dist/stisla-full.js",
    "./src/index.js",
    "./src/index-full.js"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "embla-carousel": "^8.6.0",
    "focus-trap": "^8.2.1",
    "tabbable": "^6.4.0"
  },
  "peerDependencies": {
    "@stisla/css": "3.0.0-beta.1"
  }
}
