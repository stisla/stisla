{
  "name": "@stisla/vanilla",
  "version": "3.0.0-beta.1",
  "description": "Stisla v3 — vanilla JS implementation. Pairs with @stisla/css. Composed primitives (Floating UI, focus-trap) plus Stisla's own component classes.",
  "license": "MIT",
  "author": "Nauval Azhar <nauvalazhar2@gmail.com> (https://stisla.dev)",
  "homepage": "https://stisla.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/stisla/stisla.git",
    "directory": "packages/vanilla"
  },
  "bugs": "https://github.com/stisla/stisla/issues",
  "keywords": [
    "stisla",
    "vanilla",
    "admin",
    "dashboard",
    "design-system",
    "bem"
  ],
  "type": "module",
  "main": "./dist/stisla.js",
  "module": "./dist/stisla.js",
  "exports": {
    ".": "./dist/stisla.js",
    "./full": "./dist/stisla-full.js",
    "./integrations/carousel": "./dist/integrations/carousel.js",
