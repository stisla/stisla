<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script>
    // Apply saved theme synchronously to avoid a light-mode flash on dark sessions.
    (function () {
      var t = localStorage.getItem('stisla-theme');
      if (t === 'dark' || t === 'light') document.documentElement.dataset.theme = t;
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  <title>{% block title %}Stisla v3{% endblock %}</title>
  {% if dev %}
    <link rel="stylesheet" href="/src/scss/bundles/stisla-full.scss" />
    <link rel="stylesheet" href="/src/site/styles/site.scss" />
  {% else %}
    <link rel="stylesheet" href="/assets/stisla-full.css" />
    <link rel="stylesheet" href="/assets/site-styles.css" />
  {% endif %}
</head>
<body>
  <div class="site-layout">
    {% include "partials/_site-sidebar.njk" %}
    <main class="site-main">
      <div class="main-container prose">
        {% block content %}{% endblock %}
      </div>
    </main>
  </div>

  {% if dev %}
    <script type="module" src="/src/js/index.js"></script>
    <script type="module" src="/src/site/scripts/site.js"></script>
  {% else %}
    <script src="/assets/stisla.js"></script>
    <script src="/assets/site.js"></script>
  {% endif %}
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>lucide.createIcons();</script>
</body>
</html>
