{#
  Dashboard template layout — the standalone-starter frame.

  Vendor dependencies (Stisla, ApexCharts, Lucide) load from the CDN so the
  downloaded zip runs with no build step. The template's own styles and
  scripts are first-party files under assets/, referenced with relative paths
  so the rendered folder is self-contained and zip-ready.

  Pages extend this and fill `block page`.
#}
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href='data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><style>.t{fill:%230a0a0a}.m{stroke:%23fafafa}@media (prefers-color-scheme: dark){.t{fill:%23fafafa}.m{stroke:%230a0a0a}}</style><rect class="t" width="512" height="512" rx="112"/><path class="m" d="M 392 144 H 200 A 56 56 0 0 0 200 256 H 312 A 56 56 0 0 1 312 368 H 120" fill="none" stroke-width="76" stroke-linecap="round" stroke-linejoin="round"/></svg>' />
  <script>
    // Apply the saved theme before first paint to avoid a flash.
    (function () {
      var t = localStorage.getItem('stisla-theme');
      if (t === 'dark' || t === 'light') document.documentElement.dataset.theme = t;
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  <title>{% block title %}Dashboard · Northwind{% endblock %}</title>

  <!-- Stisla full bundle — the dashboard is a consuming app, so it opts into
       the utilities and optional components the full bundle carries. The
       framework's "no utilities needed" proof lives at the component level
       (core has zero utility coupling); an app reaching for utilities is the
       sanctioned tweak surface, not a contradiction.
       Swap @beta → @3 once 3.0 ships. -->
  {% if dev %}
    <link rel="stylesheet" href="/src/scss/bundles/stisla-full.scss" />
  {% else %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@stisla/css@beta/dist/stisla-full.css" />
  {% endif %}

  <!-- Template styles -->
  {% if dev %}
    <link rel="stylesheet" href="/src/site/templates/dashboard/assets/css/dashboard.scss" />
  {% else %}
    <link rel="stylesheet" href="assets/css/dashboard.css" />
  {% endif %}

  {% block head %}{% endblock %}
</head>
<body>
  <div class="app-shell" data-stisla-app-shell data-stisla-app-shell-auto-collapse="true">
    {% include "templates/dashboard/_partials/_sidebar.njk" %}

    <main class="app-shell__main">
      {% include "templates/dashboard/_partials/_topbar.njk" %}
      {% block page %}{% endblock %}
    </main>
  </div>

  <!-- Stisla JS — local source in dev, CDN in the built / zip output. -->
  {% if dev %}
    <script type="module" src="/src/js/index-full.js"></script>
  {% else %}
    <script type="module" src="https://cdn.jsdelivr.net/npm/@stisla/vanilla@beta/dist/stisla-full.js"></script>
  {% endif %}

  <!-- Third-party (CDN in both dev and prod) -->
  <script src="https://cdn.jsdelivr.net/npm/apexcharts@3"></script>

  <!-- Template scripts. All self-contained, no shared globals: theme toggle,
       the ApexCharts setup, the order-form line-item editor, and table-select
       (row selection + bulk bar + confirm-dialog fill). Tables are static
       server-rendered markup, so there is no data-grid runtime. -->
  {% if dev %}
    <script type="module" src="/src/site/templates/dashboard/assets/js/theme.js"></script>
    <script type="module" src="/src/site/templates/dashboard/assets/js/charts.js"></script>
    <script type="module" src="/src/site/templates/dashboard/assets/js/order-form.js"></script>
    <script type="module" src="/src/site/templates/dashboard/assets/js/table-select.js"></script>
  {% else %}
    <script src="assets/js/theme.js"></script>
    <script src="assets/js/charts.js"></script>
    <script src="assets/js/order-form.js"></script>
    <script src="assets/js/table-select.js"></script>
  {% endif %}

  {# Per-page hook for any extra page-specific script. #}
  {% block scripts %}{% endblock %}
</body>
</html>
