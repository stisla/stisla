{#
  Off-shell layout for auth + error pages — a split screen: the form fills the
  left panel, a brand showcase fills the right (hidden on small screens). Loads
  Stisla + the template theme.js (for the corner theme toggle) and a tiny
  password-visibility toggle; skips the dashboard's table/chart/form scripts
  since these pages don't use them. Pages fill `block auth`.
#}
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href='data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><style>.t{fill:%230a0a0a}.m{stroke:%23fafafa}@media (prefers-color-scheme: dark){.t{fill:%23fafafa}.m{stroke:%230a0a0a}}</style><rect class="t" width="512" height="512" rx="112"/><path class="m" d="M 392 144 H 200 A 56 56 0 0 0 200 256 H 312 A 56 56 0 0 1 312 368 H 120" fill="none" stroke-width="76" stroke-linecap="round" stroke-linejoin="round"/></svg>' />
  <script>
    // Apply the saved theme before first paint to avoid a flash.
    (function () {
      var t = localStorage.getItem('stisla-theme');
      if (t === 'dark' || t === 'light') document.documentElement.dataset.theme = t;
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  <title>{% block title %}Meridian{% endblock %}</title>

  <!-- Stisla full bundle — app opts into utilities + optional components. -->
  {% if dev %}
    <link rel="stylesheet" href="/src/scss/bundles/stisla-full.scss" />
    <link rel="stylesheet" href="/src/site/templates/dashboard/assets/css/dashboard.scss" />
  {% else %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@stisla/css@beta/dist/stisla-full.css" />
    <link rel="stylesheet" href="assets/css/dashboard.css" />
  {% endif %}

  {% block head %}{% endblock %}
</head>
<body>
  <main class="auth">
    {# Left — the form. #}
    <section class="auth__panel">
      <button type="button" class="btn btn--ghost btn--neutral btn--icon-only auth__toggle" data-theme-toggle aria-label="Toggle theme">
        {{ "solar:moon-linear" | icon }}
      </button>
      <div class="auth__form">
        {% block auth %}{% endblock %}
      </div>
    </section>

    {# Right — brand showcase. Logo pinned top, pitch pinned bottom. #}
    <aside class="auth__aside">
      <a href="/dashboard/" class="auth__brand">
        <span class="auth__brand-mark">
          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1.5l3.4 7.1 7.1 3.4-7.1 3.4-3.4 7.1-3.4-7.1L1.5 12l7.1-3.4z" opacity=".45"/><path d="M12 1.5l3.4 7.1L12 12 8.6 8.6z"/></svg>
        </span>
        <span class="auth__brand-text">
          <span class="auth__brand-name">Meridian</span>
        </span>
      </a>
      <div class="auth__pitch">
        <h2 class="auth__pitch-title">Run your <span>commerce, calmly.</span></h2>
        <p class="auth__pitch-lede">Orders, revenue, and customer intelligence — the whole store observed from one calm dashboard.</p>
      </div>
    </aside>
  </main>

  {% if dev %}
    <script type="module" src="/src/js/index-full.js"></script>
  {% else %}
    <script type="module" src="https://cdn.jsdelivr.net/npm/@stisla/vanilla@beta/dist/stisla-full.js"></script>
  {% endif %}
  {% if dev %}
    <script type="module" src="/src/site/templates/dashboard/assets/js/theme.js"></script>
  {% else %}
    <script src="assets/js/theme.js"></script>
  {% endif %}

  {# Password visibility toggle — a button with data-password-toggle flips the
     type of the input named by its aria-controls. Tiny + auth-only, so it
     lives here rather than in a shared asset. #}
  <script>
    document.addEventListener('click', function (event) {
      var toggle = event.target.closest('[data-password-toggle]');
      if (!toggle) return;
      var input = document.getElementById(toggle.getAttribute('aria-controls'));
      if (!input) return;
      var reveal = input.type === 'password';
      input.type = reveal ? 'text' : 'password';
      toggle.setAttribute('aria-pressed', String(reveal));
    });
  </script>

  {% block scripts %}{% endblock %}
</body>
</html>
