{#
  Landing layout. Same head/navbar/scripts as base, but no sidebar, no
  right rail, no content-card chrome, no mobile ToC strip. The main column
  is the hero and features grid. Pages that extend this fill `block landing`.
#}
{% extends "layouts/base.njk" %}

{% block layout %}
<div class="site-layout site-layout--landing">
  <main class="site-main site-main--landing">
    {% block landing %}{% endblock %}
  </main>
</div>
{% endblock %}
