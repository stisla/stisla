{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Popovers · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Popovers</h1>
    <p class="lead">A small floating panel anchored to a trigger.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>Set <code>data-bs-toggle="popover"</code> on any focusable element and pass the title and body via <code>data-bs-title</code> and <code>data-bs-content</code>. The popover initializes from a one-line scanner in <code>site.js</code>.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn-primary" data-bs-toggle="popover" data-bs-title="API key" data-bs-content="Used to authenticate requests to the workspace from your scripts and CI.">
      Show popover
    </button>
    {% endcall %}
  </section>

  <section>
    <h2>Directions</h2>
    <p>Use <code>data-bs-placement</code> to anchor the panel on a specific side of the trigger.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2">
      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="popover" data-bs-placement="top" data-bs-title="Top" data-bs-content="Anchors the panel above the trigger.">
        Top
      </button>
      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="popover" data-bs-placement="right" data-bs-title="Right" data-bs-content="Anchors the panel to the right of the trigger.">
        Right
      </button>
      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="popover" data-bs-placement="bottom" data-bs-title="Bottom" data-bs-content="Anchors the panel below the trigger.">
        Bottom
      </button>
      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="popover" data-bs-placement="left" data-bs-title="Left" data-bs-content="Anchors the panel to the left of the trigger.">
        Left
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Hover trigger</h2>
    <p>Add <code>data-bs-trigger="hover focus"</code> to open on pointer hover and keyboard focus. Click stays the default elsewhere so accidental dismissals don't fight the user.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="popover" data-bs-trigger="hover focus" data-bs-title="Read-only" data-bs-content="Members with the viewer role can browse but not edit shared boards.">
      Hover or focus me
    </button>
    {% endcall %}
  </section>

  <section>
    <h2>Dismiss on next click</h2>
    <p>Set <code>data-bs-trigger="focus"</code> so the popover closes the moment the trigger loses focus. Render the trigger as an <code>&lt;a&gt;</code> with <code>tabindex="0"</code> so it stays in the tab order without acting like a button.</p>
    {% call ui.demo() %}
    <a tabindex="0" class="btn btn-outline-secondary" role="button" data-bs-toggle="popover" data-bs-trigger="focus" data-bs-title="Dismissible" data-bs-content="Click elsewhere or tab out to close this popover.">
      Click, then click away
    </a>
    {% endcall %}
  </section>

  <section>
    <h2>HTML content</h2>
    <p>Pass <code>data-bs-html="true"</code> to render the content as HTML instead of escaping it. Useful for short inline emphasis or links.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="popover" data-bs-html="true" data-bs-title="Release notes" data-bs-content="<strong>v3.0</strong> ships the popover, navbar, and drawer components. <a href='#'>See changelog</a>.">
      View update
    </button>
    {% endcall %}
  </section>

  <section>
    <h2>Disabled triggers</h2>
    <p>Disabled buttons don't fire pointer events, so wrap them in a focusable span and put the popover attributes on the wrapper.</p>
    {% call ui.demo() %}
    <span class="d-inline-block" tabindex="0" data-bs-toggle="popover" data-bs-trigger="hover focus" data-bs-content="Reach out to the workspace owner to enable this action.">
      <button type="button" class="btn btn-primary" disabled style="pointer-events: none;">Disabled action</button>
    </span>
    {% endcall %}
  </section>
{% endblock %}
