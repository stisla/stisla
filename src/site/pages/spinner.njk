{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Spinner · Stisla{% endblock %}

{% block content %}
  <header>
    <h1>Spinner</h1>
    <p class="lead">A lightweight indicator for in-flight work.</p>
  </header>

  <section>
    <h2>Border</h2>
    <p>The default. Use <code>.spinner</code> with <code>role="status"</code> and a visually hidden label so screen readers announce the loading state.</p>
    {% call ui.demo() %}
    <div class="spinner" role="status">
      <span class="visually-hidden">Loading…</span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Grow</h2>
    <p>Add <code>.spinner--grow</code> for a pulsing dot. Same markup, same a11y story.</p>
    {% call ui.demo() %}
    <div class="spinner spinner--grow" role="status">
      <span class="visually-hidden">Loading…</span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Colors</h2>
    <p>Both spinners inherit from <code>currentColor</code>, so any <code>.text-*</code> utility recolors them.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <div class="spinner text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner text-success" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner text-danger" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner text-warning" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner text-info" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner text-muted-foreground" role="status"><span class="visually-hidden">Loading…</span></div>
    </div>
    {% endcall %}

    <p>The grow variant takes the same utilities.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <div class="spinner spinner--grow text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner spinner--grow text-success" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner spinner--grow text-danger" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner spinner--grow text-warning" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner spinner--grow text-info" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner spinner--grow text-muted-foreground" role="status"><span class="visually-hidden">Loading…</span></div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Add <code>.spinner--sm</code> for the compact size used inside buttons and badges, or <code>.spinner--lg</code> for an empty-state hero.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <div class="spinner spinner--sm" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner spinner--lg" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner spinner--grow spinner--sm" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner spinner--grow" role="status"><span class="visually-hidden">Loading…</span></div>
      <div class="spinner spinner--grow spinner--lg" role="status"><span class="visually-hidden">Loading…</span></div>
    </div>
    {% endcall %}

    <p>For one-off sizes, override <code>--spinner-size</code> inline.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <div class="spinner" role="status" style="--spinner-size: 3rem; --spinner-width: 4px;">
        <span class="visually-hidden">Loading…</span>
      </div>
      <div class="spinner spinner--grow" role="status" style="--spinner-size: 3rem;">
        <span class="visually-hidden">Loading…</span>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Alignment</h2>
    <p>Spinners are inline-block, so flex and margin utilities place them like any other inline element.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <div class="spinner spinner--sm" role="status" aria-hidden="true"></div>
      <span>Syncing inbox</span>
    </div>
    {% endcall %}

    <p>Center one inside a card or empty state by wrapping it in a flex container.</p>
    {% call ui.demo() %}
    <div class="card">
      <div class="card__body d-flex justify-content-center" style="padding-block: 2.5rem;">
        <div class="spinner spinner--lg text-primary" role="status">
          <span class="visually-hidden">Loading…</span>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>In buttons</h2>
    <p>For the canonical icon-aware loading state, use <code>.is-loading</code> on the button itself. It swaps any leading or trailing icon for the spinner without shifting the label. See <a class="link" href="/button">Button</a>.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary is-loading" aria-busy="true">Saving</button>
      <button type="button" class="btn btn--outline btn--neutral is-loading" aria-busy="true">Loading</button>
    </div>
    {% endcall %}

    <p>For a standalone spinner inside a button (separate from <code>.is-loading</code>), slot <code>.spinner.spinner--sm</code> as a leading element.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary" disabled>
        <span class="spinner spinner--sm" role="status" aria-hidden="true"></span>
        Loading
      </button>
      <button type="button" class="btn btn--primary" disabled>
        <span class="spinner spinner--grow spinner--sm" role="status" aria-hidden="true"></span>
        Loading
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Customization</h2>
    <p>Three variables retune <code>.spinner</code> without touching component CSS. Override on <code>.spinner</code> itself, on a parent scope, or on <code>:root</code>. The cascade scopes the change.</p>
    <div class="prose">
      <table>
        <thead>
          <tr>
            <th>Variable</th>
            <th>Use</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--spinner-size</code></td>
            <td>Diameter; sm and lg reassign this</td>
          </tr>
          <tr>
            <td><code>--spinner-width</code></td>
            <td>Stroke width on <code>.spinner</code>; ignored by <code>.spinner--grow</code></td>
          </tr>
          <tr>
            <td><code>--spinner-duration</code></td>
            <td>One animation cycle; reduced-motion overrides to a longer value</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p>Color comes from <code>currentColor</code>, so any <code>.text-*</code> utility recolors the spinner without a dedicated variable.</p>
  </section>
{% endblock %}
