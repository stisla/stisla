{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Accordion · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Accordion</h1>
    <p class="lead">A stack of collapsible panels. Each item is a self-contained rounded chip with a 4px inset from the wrapper edge; the flush variant strips the chip styling for an edge-to-edge list.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>Default behavior: opening one item collapses the others via <code>data-bs-parent</code>. The first item is open on load.</p>
    {% call ui.demo() %}
    <div class="accordion w-100" id="accordionExample">
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
            Accordion Item #1
          </button>
        </h2>
        <div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#accordionExample">
          <div class="accordion-body">
            <strong>This is the first item's accordion body.</strong> It shows by default. The chip is fully rounded; the body fills the chip's bottom corners.
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
            Accordion Item #2
          </button>
        </h2>
        <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
          <div class="accordion-body">
            Active items use a <code>--bs-primary</code> 15% alpha tint with full primary text and chevron.
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
            Accordion Item #3
          </button>
        </h2>
        <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
          <div class="accordion-body">
            Each chip carries its own border and 16px radius; BS5's stacked-block first/last special-casing is overridden so every item reads the same.
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Always open</h2>
    <p>Drop <code>data-bs-parent</code> on each <code>.accordion-collapse</code> to let multiple items stay open at once.</p>
    {% call ui.demo() %}
    <div class="accordion w-100" id="accordionPanelsStayOpenExample">
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#panelsStayOpen-collapseOne" aria-expanded="true" aria-controls="panelsStayOpen-collapseOne">
            Accordion Item #1
          </button>
        </h2>
        <div id="panelsStayOpen-collapseOne" class="accordion-collapse collapse show">
          <div class="accordion-body">
            This item stays open even when others are toggled.
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#panelsStayOpen-collapseTwo" aria-expanded="false" aria-controls="panelsStayOpen-collapseTwo">
            Accordion Item #2
          </button>
        </h2>
        <div id="panelsStayOpen-collapseTwo" class="accordion-collapse collapse">
          <div class="accordion-body">
            Toggling this item does not collapse the others.
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#panelsStayOpen-collapseThree" aria-expanded="false" aria-controls="panelsStayOpen-collapseThree">
            Accordion Item #3
          </button>
        </h2>
        <div id="panelsStayOpen-collapseThree" class="accordion-collapse collapse">
          <div class="accordion-body">
            Open as many as you like.
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Flush</h2>
    <p>Add <code>.accordion-flush</code> to drop the chip styling: no wrapper padding, no per-item radius, and a single divider between rows. The active state stays plain — no primary tint.</p>
    {% call ui.demo() %}
    <div class="accordion accordion-flush w-100" id="accordionFlushExample">
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseOne" aria-expanded="true" aria-controls="flush-collapseOne">
            What is Liverpool Football Club?
          </button>
        </h2>
        <div id="flush-collapseOne" class="accordion-collapse collapse show" data-bs-parent="#accordionFlushExample">
          <div class="accordion-body">Liverpool Football Club is the biggest football club in the world.</div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseTwo" aria-expanded="false" aria-controls="flush-collapseTwo">
            How many titles has Liverpool Football Club won?
          </button>
        </h2>
        <div id="flush-collapseTwo" class="accordion-collapse collapse" data-bs-parent="#accordionFlushExample">
          <div class="accordion-body">Across all competitions, well over 60 trophies — domestic and continental.</div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseThree" aria-expanded="false" aria-controls="flush-collapseThree">
            Will Jurgen Klopp manage Liverpool again?
          </button>
        </h2>
        <div id="flush-collapseThree" class="accordion-collapse collapse" data-bs-parent="#accordionFlushExample">
          <div class="accordion-body">Probably not — but you'll never walk alone.</div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>
{% endblock %}
