{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Images · Stisla v3{% endblock %}

{% set img_landscape = "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&w=900&q=70" %}
{% set img_square = "https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=600&h=600&q=70" %}
{% set img_portrait = "https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=facearea&facepad=2.5&w=400&h=400&q=80" %}

{% block content %}
  <header>
    <h1>Images</h1>
    <p class="lead">Utilities for responsive, rounded, and aligned <code>&lt;img&gt;</code> elements.</p>
  </header>

  <section>
    <h2>Responsive</h2>
    <p>Add <code>.img-fluid</code> to scale an image to the width of its container while keeping its aspect ratio.</p>
    {% call ui.demo() %}
    <img src="{{ img_landscape }}" class="img-fluid rounded" alt="Mountain landscape" />
    {% endcall %}
  </section>

  <section>
    <h2>Thumbnail</h2>
    <p>Use <code>.img-thumbnail</code> to wrap an image with a 1px border and a small inset padding. Works on top of <code>.img-fluid</code>.</p>
    {% call ui.demo() %}
    <img src="{{ img_square }}" class="img-thumbnail" width="200" height="200" alt="Workspace" />
    {% endcall %}
  </section>

  <section>
    <h2>Rounded</h2>
    <p>Pair an <code>&lt;img&gt;</code> with <code>.rounded</code>, <code>.rounded-pill</code>, or <code>.rounded-circle</code>. The circle variant expects a square source.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-3 align-items-center">
      <img src="{{ img_square }}" class="rounded" width="120" height="120" alt="Rounded" />
      <img src="{{ img_square }}" class="rounded-3" width="120" height="120" alt="Rounded large" />
      <img src="{{ img_portrait }}" class="rounded-circle" width="120" height="120" alt="Avatar" />
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Alignment</h2>
    <p>Float images with <code>.float-start</code> or <code>.float-end</code>, or center them by combining <code>.d-block</code> with <code>.mx-auto</code>.</p>
    {% call ui.demo() %}
    <div>
      <img src="{{ img_portrait }}" class="rounded float-start me-3" width="80" height="80" alt="Float start" />
      <img src="{{ img_portrait }}" class="rounded float-end ms-3" width="80" height="80" alt="Float end" />
      <p class="mb-0">Floated images sit inline with the surrounding text. Wrap them in a clearfix container if the parent does not already clear its floats.</p>
    </div>
    {% endcall %}
    {% call ui.demo() %}
    <img src="{{ img_portrait }}" class="rounded-circle d-block mx-auto" width="120" height="120" alt="Centered avatar" />
    {% endcall %}
  </section>

  <section>
    <h2>Figure</h2>
    <p>Use <code>.figure</code>, <code>.figure-img</code>, and <code>.figure-caption</code> to attach a caption to a self-contained image block.</p>
    {% call ui.demo() %}
    <figure class="figure">
      <img src="{{ img_landscape }}" class="figure-img img-fluid rounded" alt="Mountain landscape at dawn" />
      <figcaption class="figure-caption">A caption for the image above.</figcaption>
    </figure>
    {% endcall %}
  </section>
{% endblock %}
