{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Pagination · Stisla{% endblock %}

{% block content %}
  <header>
    <h1>Pagination</h1>
    <p class="lead">A row of page chips for moving through a long list or paginated view.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>Wrap a list of <code>.pagination__button</code> in <code>.pagination</code>. Mark the current page with <code>data-state="active"</code> and <code>aria-current="page"</code>. The active chip paints <code>--st-highlight</code> while hover paints the lighter <code>--st-accent</code>.</p>
    {% call ui.demo() %}
    <nav aria-label="Page navigation">
      <ul class="pagination">
        <li><a class="pagination__button" href="#">Previous</a></li>
        <li><a class="pagination__button" href="#">1</a></li>
        <li><a class="pagination__button" href="#" data-state="active" aria-current="page">2</a></li>
        <li><a class="pagination__button" href="#">3</a></li>
        <li><a class="pagination__button" href="#">Next</a></li>
      </ul>
    </nav>
    {% endcall %}
  </section>

  <section>
    <h2>With icons</h2>
    <p>Drop an <code>&lt;svg&gt;</code> or <code>&lt;i&gt;</code> inside the chip. Icons sit at <code>1em</code> so they scale with the chip's font size and stay on the label baseline.</p>
    {% call ui.demo() %}
    <nav aria-label="Page navigation">
      <ul class="pagination">
        <li>
          <a class="pagination__button" href="#" aria-label="Previous">
            <i data-lucide="chevron-left"></i>
            <span>Previous</span>
          </a>
        </li>
        <li><a class="pagination__button" href="#">1</a></li>
        <li><a class="pagination__button" href="#" data-state="active" aria-current="page">2</a></li>
        <li><a class="pagination__button" href="#">3</a></li>
        <li>
          <a class="pagination__button" href="#" aria-label="Next">
            <span>Next</span>
            <i data-lucide="chevron-right"></i>
          </a>
        </li>
      </ul>
    </nav>
    {% endcall %}
  </section>

  <section>
    <h2>Disabled</h2>
    <p>Set <code>aria-disabled="true"</code> on the chip (or use <code>&lt;button disabled&gt;</code>) to gray it out and turn off pointer events. Drop the <code>href</code> too so screen readers don't announce it as a link. Use on the leading or trailing chip when the user is at the start or end of the range.</p>
    {% call ui.demo() %}
    <nav aria-label="Page navigation">
      <ul class="pagination">
        <li>
          <span class="pagination__button" aria-label="Previous" aria-disabled="true">
            <i data-lucide="chevron-left"></i>
            <span>Previous</span>
          </span>
        </li>
        <li><a class="pagination__button" href="#" data-state="active" aria-current="page">1</a></li>
        <li><a class="pagination__button" href="#">2</a></li>
        <li><a class="pagination__button" href="#">3</a></li>
        <li>
          <a class="pagination__button" href="#" aria-label="Next">
            <span>Next</span>
            <i data-lucide="chevron-right"></i>
          </a>
        </li>
      </ul>
    </nav>
    {% endcall %}
  </section>

  <section>
    <h2>Ellipsis</h2>
    <p>Drop <code>.pagination__ellipsis</code> in for a truncation marker between page ranges. Takes the same chip footprint so the row rhythm holds, no hover, no focus.</p>
    {% call ui.demo() %}
    <nav aria-label="Page navigation">
      <ul class="pagination">
        <li>
          <a class="pagination__button" href="#" aria-label="Previous">
            <i data-lucide="chevron-left"></i>
          </a>
        </li>
        <li><a class="pagination__button" href="#">1</a></li>
        <li><a class="pagination__button" href="#">2</a></li>
        <li><a class="pagination__button" href="#" data-state="active" aria-current="page">3</a></li>
        <li><a class="pagination__button" href="#">4</a></li>
        <li><a class="pagination__button" href="#">5</a></li>
        <li><span class="pagination__ellipsis" aria-hidden="true">…</span></li>
        <li><a class="pagination__button" href="#">12</a></li>
        <li>
          <a class="pagination__button" href="#" aria-label="Next">
            <i data-lucide="chevron-right"></i>
          </a>
        </li>
      </ul>
    </nav>
    {% endcall %}
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Add <code>.pagination--sm</code> or <code>.pagination--lg</code> for compact or large chips. Heights match the button scale at 28 / 36 / 44 px under default density.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-column gap-4 w-100">
      <nav aria-label="Small page navigation">
        <ul class="pagination pagination--sm">
          <li><a class="pagination__button" href="#">Previous</a></li>
          <li><a class="pagination__button" href="#">1</a></li>
          <li><a class="pagination__button" href="#" data-state="active" aria-current="page">2</a></li>
          <li><a class="pagination__button" href="#">3</a></li>
          <li><a class="pagination__button" href="#">Next</a></li>
        </ul>
      </nav>
      <nav aria-label="Default page navigation">
        <ul class="pagination">
          <li><a class="pagination__button" href="#">Previous</a></li>
          <li><a class="pagination__button" href="#">1</a></li>
          <li><a class="pagination__button" href="#" data-state="active" aria-current="page">2</a></li>
          <li><a class="pagination__button" href="#">3</a></li>
          <li><a class="pagination__button" href="#">Next</a></li>
        </ul>
      </nav>
      <nav aria-label="Large page navigation">
        <ul class="pagination pagination--lg">
          <li><a class="pagination__button" href="#">Previous</a></li>
          <li><a class="pagination__button" href="#">1</a></li>
          <li><a class="pagination__button" href="#" data-state="active" aria-current="page">2</a></li>
          <li><a class="pagination__button" href="#">3</a></li>
          <li><a class="pagination__button" href="#">Next</a></li>
        </ul>
      </nav>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Alignment</h2>
    <p>Add <code>.pagination--center</code> or <code>.pagination--end</code> to flip the row's <code>justify-content</code>. Default is start.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-column gap-4 w-100">
      <nav aria-label="Centered page navigation">
        <ul class="pagination pagination--center">
          <li><a class="pagination__button" href="#">Previous</a></li>
          <li><a class="pagination__button" href="#">1</a></li>
          <li><a class="pagination__button" href="#" data-state="active" aria-current="page">2</a></li>
          <li><a class="pagination__button" href="#">3</a></li>
          <li><a class="pagination__button" href="#">Next</a></li>
        </ul>
      </nav>
      <nav aria-label="End-aligned page navigation">
        <ul class="pagination pagination--end">
          <li><a class="pagination__button" href="#">Previous</a></li>
          <li><a class="pagination__button" href="#">1</a></li>
          <li><a class="pagination__button" href="#" data-state="active" aria-current="page">2</a></li>
          <li><a class="pagination__button" href="#">3</a></li>
          <li><a class="pagination__button" href="#">Next</a></li>
        </ul>
      </nav>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Customization</h2>
    <p>Sixteen variables retune <code>.pagination</code> without touching component CSS. Override on <code>.pagination</code> itself, on a parent scope, or on <code>:root</code>. The cascade scopes the change. Size modifiers <code>--sm</code> / <code>--lg</code> retune the chip height, padding, and font size in their own scope, so there are no per-size vars to maintain.</p>
    <div class="prose">
      <table>
        <thead>
          <tr>
            <th>Variable</th>
            <th>Use</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--pagination-gap</code></td>
            <td>Space between chips</td>
          </tr>
          <tr>
            <td><code>--pagination-margin-bottom</code></td>
            <td>Trailing space below the row</td>
          </tr>
          <tr>
            <td><code>--pagination-font-size</code></td>
            <td>Chip text size</td>
          </tr>
          <tr>
            <td><code>--pagination-button-height</code></td>
            <td>Chip height (also doubles as <code>min-width</code> so single-glyph chips land as squares)</td>
          </tr>
          <tr>
            <td><code>--pagination-button-padding-x</code></td>
            <td>Chip horizontal padding (longer labels grow from this)</td>
          </tr>
          <tr>
            <td><code>--pagination-button-inner-gap</code></td>
            <td>Space between icon and label inside a chip</td>
          </tr>
          <tr>
            <td><code>--pagination-button-radius</code></td>
            <td>Chip corner radius (set 9999px for pill chips)</td>
          </tr>
          <tr>
            <td><code>--pagination-button-bg</code></td>
            <td>Chip rest background</td>
          </tr>
          <tr>
            <td><code>--pagination-button-color</code></td>
            <td>Chip rest text color</td>
          </tr>
          <tr>
            <td><code>--pagination-button-border-color</code></td>
            <td>Chip border color (set <code>var(--st-border)</code> for outlined chips)</td>
          </tr>
          <tr>
            <td><code>--pagination-button-hover-bg</code></td>
            <td>Hover background (interactive chips only)</td>
          </tr>
          <tr>
            <td><code>--pagination-button-hover-color</code></td>
            <td>Hover text color</td>
          </tr>
          <tr>
            <td><code>--pagination-button-active-bg</code></td>
            <td>Current page background (<code>data-state="active"</code> / <code>aria-current="page"</code>)</td>
          </tr>
          <tr>
            <td><code>--pagination-button-active-color</code></td>
            <td>Current page text color</td>
          </tr>
          <tr>
            <td><code>--pagination-button-disabled-color</code></td>
            <td>Disabled / ellipsis text color</td>
          </tr>
          <tr>
            <td><code>--pagination-button-ring</code></td>
            <td>Focus outline color</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
{% endblock %}
