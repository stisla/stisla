{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Badge · Stisla{% endblock %}

{% block content %}
  <header>
    <h1>Badge</h1>
    <p class="lead">A compact label for counts, statuses, and tags.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>A bare <code>.badge</code> sits on the neutral interactional fill. Use for non-semantic chips like counts or tags.</p>
    {% call ui.demo() %}
    <span class="badge">Default</span>
    {% endcall %}
  </section>

  <section>
    <h2>Filled intents</h2>
    <p>Add an intent modifier for a solid filled chip. Each intent ships with its paired <code>-foreground</code>, so a runtime token override recolors the chip and the label together.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <span class="badge badge--primary">Primary</span>
      <span class="badge badge--success">Success</span>
      <span class="badge badge--warning">Warning</span>
      <span class="badge badge--danger">Danger</span>
      <span class="badge badge--info">Info</span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Soft</h2>
    <p>Add <code>.badge--soft</code> for a tinted chip. The background mixes the intent at 15% over transparent; the label keeps the solid intent color. Without an intent, soft falls back to a muted neutral chip.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <span class="badge badge--soft">Default</span>
      <span class="badge badge--soft badge--primary">Primary</span>
      <span class="badge badge--soft badge--success">Success</span>
      <span class="badge badge--soft badge--warning">Warning</span>
      <span class="badge badge--soft badge--danger">Danger</span>
      <span class="badge badge--soft badge--info">Info</span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>With icon</h2>
    <p>Drop a direct <code>&lt;svg&gt;</code> or <code>&lt;i&gt;</code> child. The icon picks up the text color and scales to the badge's font size.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <span class="badge badge--soft badge--success">
        <i data-lucide="check"></i>
        Active
      </span>
      <span class="badge badge--soft badge--warning">
        <i data-lucide="clock"></i>
        Pending
      </span>
      <span class="badge badge--soft badge--danger">
        <i data-lucide="x"></i>
        Failed
      </span>
      <span class="badge badge--primary">
        <i data-lucide="star"></i>
        Featured
      </span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Loading</h2>
    <p>Slot a <code>.spinner.spinner--compact</code> in to signal in-flight work. It inherits the badge's text color and shrinks to the badge's font size.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <span class="badge badge--soft badge--primary">
        <span class="spinner spinner--compact" role="status" aria-hidden="true"></span>
        Syncing
      </span>
      <span class="badge badge--soft">
        <span class="spinner spinner--compact" role="status" aria-hidden="true"></span>
        Loading
      </span>
      <span class="badge badge--info">
        <span class="spinner spinner--compact" role="status" aria-hidden="true"></span>
        Uploading
      </span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>In buttons</h2>
    <p>Drop a badge inside a button for a count or status.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary">
        Inbox
        <span class="badge">4</span>
      </button>
      <button type="button" class="btn btn--outline btn--neutral">
        Notifications
        <span class="badge badge--danger">12</span>
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Customization</h2>
    <p>These variables retune <code>.badge</code> without touching component CSS. Override on <code>.badge</code> itself, on a parent scope, or on <code>:root</code>. The cascade scopes the change.</p>
    <table>
      <thead>
        <tr>
          <th>Variable</th>
          <th>Use</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>--badge-radius</code></td>
          <td>Corner radius; pilled by default, set a smaller value to flatten</td>
        </tr>
        <tr>
          <td><code>--badge-min-height</code></td>
          <td>Minimum height; the chip adapts to content above this</td>
        </tr>
        <tr>
          <td><code>--badge-padding-block</code></td>
          <td>Top and bottom padding</td>
        </tr>
        <tr>
          <td><code>--badge-padding-inline</code></td>
          <td>Left and right padding</td>
        </tr>
        <tr>
          <td><code>--badge-font-size</code></td>
          <td>Label size</td>
        </tr>
        <tr>
          <td><code>--badge-font-weight</code></td>
          <td>Label weight</td>
        </tr>
        <tr>
          <td><code>--badge-tone</code></td>
          <td>Color source the soft variant tints over; intents reassign this</td>
        </tr>
        <tr>
          <td><code>--badge-bg</code></td>
          <td>Background; intents set the intent color, soft mixes 15% over <code>--badge-tone</code></td>
        </tr>
        <tr>
          <td><code>--badge-color</code></td>
          <td>Label color; intents flip to the paired <code>-foreground</code>; soft reads <code>--badge-tone</code></td>
        </tr>
      </tbody>
    </table>
    <p>Pill is intentional, so the badge opts out of <code>--st-radius</code> by default. Set <code>--badge-radius</code> at the scope you want flattened (a preset wrapper, <code>:root</code>) or on the badge itself for a one-off.</p>
  </section>
{% endblock %}
