{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Button group · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Button group</h1>
    <p class="lead">A row of buttons that share rounding and elevation so they read as a single control.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>Wrap two or more <code>.btn</code>s in <code>.btn-group</code> with <code>role="group"</code> and an <code>aria-label</code>. Only the outer corners round; the seam between buttons stays square.</p>
    {% call ui.demo() %}
    <div class="btn-group" role="group" aria-label="Basic example">
      <button type="button" class="btn btn-primary">Left</button>
      <button type="button" class="btn btn-primary">Middle</button>
      <button type="button" class="btn btn-primary">Right</button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Outline</h2>
    <p>Outline groups stay flat — no wrapper shadow, same opt-out we apply to standalone outline buttons. Adjacent borders dedupe at the seam.</p>
    {% call ui.demo() %}
    <div class="btn-group" role="group" aria-label="Outline example">
      <button type="button" class="btn btn-outline-secondary">Left</button>
      <button type="button" class="btn btn-outline-secondary">Middle</button>
      <button type="button" class="btn btn-outline-secondary">Right</button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Mixed</h2>
    <p>A loud action paired with a quiet alternative. Same pattern as the standalone primary + outline-secondary pairing, just locked together as one chip.</p>
    {% call ui.demo() %}
    <div class="btn-group" role="group" aria-label="Mixed example">
      <button type="button" class="btn btn-primary">Publish</button>
      <button type="button" class="btn btn-outline-secondary">Save draft</button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Add <code>.btn-group-sm</code> or <code>.btn-group-lg</code> on the wrapper to size every member at once.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-column gap-2 align-items-start">
      <div class="btn-group btn-group-sm" role="group" aria-label="Small">
        <button type="button" class="btn btn-outline-secondary">Left</button>
        <button type="button" class="btn btn-outline-secondary">Middle</button>
        <button type="button" class="btn btn-outline-secondary">Right</button>
      </div>
      <div class="btn-group" role="group" aria-label="Default">
        <button type="button" class="btn btn-outline-secondary">Left</button>
        <button type="button" class="btn btn-outline-secondary">Middle</button>
        <button type="button" class="btn btn-outline-secondary">Right</button>
      </div>
      <div class="btn-group btn-group-lg" role="group" aria-label="Large">
        <button type="button" class="btn btn-outline-secondary">Left</button>
        <button type="button" class="btn btn-outline-secondary">Middle</button>
        <button type="button" class="btn btn-outline-secondary">Right</button>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Toggle group</h2>
    <p>Mark the selected member with <code>.active</code> and <code>aria-pressed="true"</code>. Use <code>data-bs-toggle="button"</code> to flip the state on click.</p>
    {% call ui.demo() %}
    <div class="btn-group" role="group" aria-label="View mode">
      <button type="button" class="btn btn-outline-secondary active" aria-pressed="true" data-bs-toggle="button">Day</button>
      <button type="button" class="btn btn-outline-secondary" aria-pressed="false" data-bs-toggle="button">Week</button>
      <button type="button" class="btn btn-outline-secondary" aria-pressed="false" data-bs-toggle="button">Month</button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Checkbox &amp; radio</h2>
    <p><code>.btn-check</code> turns hidden inputs into segmented-control members. Labels carry the visible styling; the input keeps a11y semantics.</p>
    {% call ui.demo() %}
    <div class="btn-group" role="group" aria-label="Tools">
      <input type="checkbox" class="btn-check" id="bg-check-1" autocomplete="off" checked>
      <label class="btn btn-outline-secondary" for="bg-check-1">Bold</label>
      <input type="checkbox" class="btn-check" id="bg-check-2" autocomplete="off">
      <label class="btn btn-outline-secondary" for="bg-check-2">Italic</label>
      <input type="checkbox" class="btn-check" id="bg-check-3" autocomplete="off">
      <label class="btn btn-outline-secondary" for="bg-check-3">Underline</label>
    </div>
    {% endcall %}
    <p>Radios work the same way; only one member can be active at a time.</p>
    {% call ui.demo() %}
    <div class="btn-group" role="group" aria-label="Alignment">
      <input type="radio" class="btn-check" name="bg-radio" id="bg-radio-1" autocomplete="off" checked>
      <label class="btn btn-outline-secondary" for="bg-radio-1">Left</label>
      <input type="radio" class="btn-check" name="bg-radio" id="bg-radio-2" autocomplete="off">
      <label class="btn btn-outline-secondary" for="bg-radio-2">Center</label>
      <input type="radio" class="btn-check" name="bg-radio" id="bg-radio-3" autocomplete="off">
      <label class="btn btn-outline-secondary" for="bg-radio-3">Right</label>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>With icons</h2>
    <p>Icons work the same as in standalone buttons — flexbox gap places them next to the label, and <code>.btn-icon</code> gives a square slot.</p>
    {% call ui.demo() %}
    <div class="btn-group" role="group" aria-label="Format">
      <button type="button" class="btn btn-outline-secondary btn-icon" aria-label="Bold">
        <i data-lucide="bold"></i>
      </button>
      <button type="button" class="btn btn-outline-secondary btn-icon" aria-label="Italic">
        <i data-lucide="italic"></i>
      </button>
      <button type="button" class="btn btn-outline-secondary btn-icon" aria-label="Underline">
        <i data-lucide="underline"></i>
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Split button</h2>
    <p>Pair a primary action with a caret-only toggle. The dropdown menu attaches to the trailing button.</p>
    {% call ui.demo() %}
    <div class="btn-group">
      <button type="button" class="btn btn-primary">Save</button>
      <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
        <span class="visually-hidden">Toggle dropdown</span>
      </button>
      <ul class="dropdown-menu">
        <li><a class="dropdown-item" href="#">Save and continue</a></li>
        <li><a class="dropdown-item" href="#">Save as draft</a></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item" href="#">Discard changes</a></li>
      </ul>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Vertical</h2>
    <p>Swap <code>.btn-group</code> for <code>.btn-group-vertical</code> to stack the buttons. Outer corners round on the top and bottom instead of left and right.</p>
    {% call ui.demo() %}
    <div class="btn-group-vertical" role="group" aria-label="Vertical example">
      <button type="button" class="btn btn-primary">Top</button>
      <button type="button" class="btn btn-primary">Middle</button>
      <button type="button" class="btn btn-primary">Bottom</button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Toolbar</h2>
    <p>Combine multiple groups under <code>.btn-toolbar</code>. The toolbar carries a default <code>0.5rem</code> gap between groups so they breathe without needing utility classes.</p>
    {% call ui.demo() %}
    <div class="btn-toolbar" role="toolbar" aria-label="Toolbar with button groups">
      <div class="btn-group" role="group" aria-label="First group">
        <button type="button" class="btn btn-outline-secondary">1</button>
        <button type="button" class="btn btn-outline-secondary">2</button>
        <button type="button" class="btn btn-outline-secondary">3</button>
        <button type="button" class="btn btn-outline-secondary">4</button>
      </div>
      <div class="btn-group" role="group" aria-label="Second group">
        <button type="button" class="btn btn-outline-secondary">5</button>
        <button type="button" class="btn btn-outline-secondary">6</button>
        <button type="button" class="btn btn-outline-secondary">7</button>
      </div>
      <div class="btn-group" role="group" aria-label="Third group">
        <button type="button" class="btn btn-outline-secondary">8</button>
      </div>
    </div>
    {% endcall %}
  </section>
{% endblock %}
