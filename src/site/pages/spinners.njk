{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Spinners · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Spinners</h1>
    <p class="lead">A lightweight indicator for in-flight work.</p>
  </header>

  <section>
    <h2>Border</h2>
    <p>The default. Use <code>.spinner-border</code> with <code>role="status"</code> and a visually hidden label so screen readers announce the loading state.</p>
    {% call ui.demo() %}
    <div class="spinner-border" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Grow</h2>
    <p>Swap to <code>.spinner-grow</code> for a pulsing dot. Same markup, same a11y story.</p>
    {% call ui.demo() %}
    <div class="spinner-grow" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Colors</h2>
    <p>Both spinners inherit from <code>currentcolor</code>, so any <code>.text-*</code> utility recolors them.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-3 align-items-center">
      <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-border text-success" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-border text-danger" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-border text-warning" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-border text-info" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-border text-body-secondary" role="status"><span class="visually-hidden">Loading...</span></div>
    </div>
    {% endcall %}

    <p>The grow variant takes the same utilities.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-3 align-items-center">
      <div class="spinner-grow text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-grow text-success" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-grow text-danger" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-grow text-warning" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-grow text-info" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-grow text-body-secondary" role="status"><span class="visually-hidden">Loading...</span></div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Add <code>.spinner-border-sm</code> or <code>.spinner-grow-sm</code> for the compact size used inside buttons and badges.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-3 align-items-center">
      <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-border spinner-border-sm" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-grow" role="status"><span class="visually-hidden">Loading...</span></div>
      <div class="spinner-grow spinner-grow-sm" role="status"><span class="visually-hidden">Loading...</span></div>
    </div>
    {% endcall %}

    <p>For one-off sizes, override the <code>--bs-spinner-width</code> and <code>--bs-spinner-height</code> CSS variables inline.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-3 align-items-center">
      <div class="spinner-border" role="status" style="--bs-spinner-width: 3rem; --bs-spinner-height: 3rem;">
        <span class="visually-hidden">Loading...</span>
      </div>
      <div class="spinner-grow" role="status" style="--bs-spinner-width: 3rem; --bs-spinner-height: 3rem;">
        <span class="visually-hidden">Loading...</span>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Alignment</h2>
    <p>Spinners are inline-block, so flex and margin utilities place them like any other inline element. Use <code>.ms-auto</code> to push one to the trailing edge of a flex row.</p>
    {% call ui.demo() %}
    <div class="d-flex align-items-center">
      <div class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></div>
      <span>Syncing inbox</span>
    </div>
    {% endcall %}

    <p>Center one inside a card or empty state by wrapping it in a flex container.</p>
    {% call ui.demo() %}
    <div class="card w-100">
      <div class="card-body d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>In buttons</h2>
    <p>Drop a small spinner inside a <code>.btn</code> to mark it as busy. Keep the label visible so the action stays readable.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2">
      <button type="button" class="btn btn-primary" disabled>
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        Loading
      </button>
      <button type="button" class="btn btn-primary" disabled>
        <span class="spinner-grow spinner-grow-sm" role="status" aria-hidden="true"></span>
        Loading
      </button>
      <button type="button" class="btn btn-outline-secondary" disabled>
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        Saving
      </button>
    </div>
    {% endcall %}

    <p>For the canonical icon-aware loading state, use <code>.btn-loading</code> instead. It swaps any leading or trailing icon for the spinner without shifting the label. See <a href="/buttons">Buttons</a>.</p>
  </section>
{% endblock %}
