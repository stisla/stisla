{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Tooltips · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Tooltips</h1>
    <p class="lead">A short floating label anchored to a trigger.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>Set <code>data-bs-toggle="tooltip"</code> and pass the label via <code>data-bs-title</code>. The tooltip initializes from a one-line scanner in <code>site.js</code>.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn-primary" data-bs-toggle="tooltip" data-bs-title="Saved 2 minutes ago">
      Hover for status
    </button>
    {% endcall %}
  </section>

  <section>
    <h2>Inverted by theme</h2>
    <p>The tooltip surface flips with the active theme. In light mode the chip reads as a near-black pill on a white page; in dark mode it inverts to near-white on the dark surface. The flip is automatic via <code>--bs-emphasis-color</code> and <code>--bs-body-bg</code>, no per-mode override needed.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2">
      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="tooltip" data-bs-title="Inverts with the page">
        Hover me
      </button>
      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="tooltip" data-bs-title="Try the theme toggle in the top nav">
        Then toggle theme
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Placements</h2>
    <p>Use <code>data-bs-placement</code> to anchor the chip on a specific side of the trigger.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2">
      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="Anchored above">
        Top
      </button>
      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Anchored right">
        Right
      </button>
      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="Anchored below">
        Bottom
      </button>
      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="Anchored left">
        Left
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>On a link</h2>
    <p>Tooltips also attach to inline elements. Useful for glossing acronyms or pointing at a destination.</p>
    {% call ui.demo() %}
    <p class="mb-0">
      The build runs on
      <a href="#" data-bs-toggle="tooltip" data-bs-title="GitHub Actions">CI</a>
      every push and posts a summary to
      <a href="#" data-bs-toggle="tooltip" data-bs-title="#releases on Slack">the release channel</a>.
    </p>
    {% endcall %}
  </section>

  <section>
    <h2>Icon-only trigger</h2>
    <p>Pair with <code>.btn-icon</code> to label a square action that has no visible text.</p>
    {% call ui.demo() %}
    <div class="d-flex gap-2">
      <button type="button" class="btn btn-outline-secondary btn-icon" data-bs-toggle="tooltip" data-bs-title="Edit" aria-label="Edit">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path></svg>
      </button>
      <button type="button" class="btn btn-outline-secondary btn-icon" data-bs-toggle="tooltip" data-bs-title="Duplicate" aria-label="Duplicate">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
      </button>
      <button type="button" class="btn btn-outline-secondary btn-icon" data-bs-toggle="tooltip" data-bs-title="Archive" aria-label="Archive">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 8 21 21 3 21 3 8"></polyline><rect x="1" y="3" width="22" height="5"></rect><line x1="10" y1="12" x2="14" y2="12"></line></svg>
      </button>
      <button type="button" class="btn btn-outline-danger btn-icon" data-bs-toggle="tooltip" data-bs-title="Delete" aria-label="Delete">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"></path><path d="M10 11v6"></path><path d="M14 11v6"></path><path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"></path></svg>
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>HTML content</h2>
    <p>Pass <code>data-bs-html="true"</code> to render the title as HTML instead of escaping it. Keep the markup short, tooltips aren't popovers.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="tooltip" data-bs-html="true" data-bs-title="Press <kbd class='kbd'>⌘</kbd>+<kbd class='kbd'>K</kbd> to search">
      Open command palette
    </button>
    {% endcall %}
  </section>

  <section>
    <h2>Long content</h2>
    <p>Content past <code>--bs-tooltip-max-width</code> (240px) wraps to a second line. Two lines is the practical ceiling, anything longer belongs in a popover.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="tooltip" data-bs-title="Only workspace owners can change billing details and downgrade the plan">
      Hover for the rule
    </button>
    {% endcall %}
  </section>

  <section>
    <h2>Disabled trigger</h2>
    <p>Disabled buttons don't fire pointer events, so wrap them in a focusable span and put the tooltip attributes on the wrapper.</p>
    {% call ui.demo() %}
    <span class="d-inline-block" tabindex="0" data-bs-toggle="tooltip" data-bs-title="Upgrade to enable exports">
      <button type="button" class="btn btn-primary" disabled style="pointer-events: none;">Export CSV</button>
    </span>
    {% endcall %}
  </section>
{% endblock %}
