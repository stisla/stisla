{#
  Kitchen sink. Standalone, not part of the docs site. No sidebar, navbar,
  rail, or prose wrapper. Just the framework bundle + every component packed
  into one scrollable board, used as an internal stress-test page for token
  overrides, presets, density, and dark-mode regressions. Not linked from
  anywhere; reach it directly at /kitchen-sink.
#}
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Kitchen sink</title>
  <script>
    (function () {
      var t = localStorage.getItem('stisla-theme');
      if (t === 'dark' || t === 'light') document.documentElement.dataset.theme = t;
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  {% if dev %}
    <link rel="stylesheet" href="/src/scss/bundles/stisla-full.scss" />
  {% else %}
    <link rel="stylesheet" href="/assets/stisla-full.css" />
  {% endif %}
  <style>
    body {
      background: var(--st-background);
      color: var(--st-foreground);
      font-family: var(--st-font-sans);
      margin: 0;
      padding: 2rem clamp(1rem, 3vw, 2.5rem) 4rem;
    }

    .ks {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
      max-width: 80rem;
      margin: 0 auto;
    }

    .ks-bar {
      position: sticky;
      top: 0.5rem;
      z-index: 10;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 1rem;
      padding: 0.5rem 0.75rem;
      background: var(--st-surface);
      border: 1px solid var(--st-border);
      border-radius: var(--st-radius);
      box-shadow: var(--st-shadow-sm);
    }
    .ks-bar__title {
      margin: 0;
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--st-muted-foreground);
      text-transform: uppercase;
    }
    .ks-bar__sep {
      align-self: stretch;
      width: 1px;
      background: var(--st-border);
      margin-inline: 0.25rem;
    }
    .ks-density {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      min-width: 14rem;
      flex: 1;
    }
    .ks-density__label {
      font-size: 0.8125rem;
      color: var(--st-muted-foreground);
    }
    .ks-density__value {
      font-family: var(--st-font-mono);
      font-size: 0.8125rem;
      min-width: 2.75rem;
      text-align: end;
    }

    .ks-section {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      padding-bottom: 2rem;
      border-bottom: 1px dashed var(--st-border);
    }
    .ks-section:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }
    .ks-label {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--st-muted-foreground);
    }

    .ks-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.75rem;
    }
    .ks-row--swatches { align-items: stretch; }
    .ks-row--swatches > * { min-width: 7rem; }

    .ks-stack { display: flex; flex-direction: column; gap: 0.75rem; }
    .ks-stack--fill > * { width: 100%; }

    .ks-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
      gap: 1rem;
      align-items: start;
    }
    .ks-grid--cards { gap: 1.25rem; }

    .ks-prose { max-width: 42rem; }

    /* Overlay surfaces sit inline for the board. Drop the fixed/absolute
       positioning the framework applies and drop the arrow that would
       dangle off the side without a trigger to anchor to. */
    .ks-overlay .popover,
    .ks-overlay .menu,
    .ks-overlay .tooltip {
      position: static;
      inset: auto;
      transform: none;
      display: block;
      opacity: 1;
      pointer-events: auto;
    }
    .ks-overlay .tooltip__arrow,
    .ks-overlay .popover__arrow { display: none; }

    /* Presets, inlined so the page stays self-contained and doesn't pull
       in the docs site stylesheet. Mirror src/site/styles/_customization-presets.scss. */
    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap');

    .preset-brutalist {
      --st-radius-sm: 0;
      --st-radius: 0;
      --st-radius-lg: 0;
      --checkbox-radius: 0;
      --slider-radius: 0;
      --switch-radius: 0;
      --st-switch-thumb-paint: linear-gradient(white, white);
      --progress-radius: 0;
      --meter-radius: 0;
      --badge-radius: 0;
      --st-shadow: 6px 6px 0 var(--st-foreground);
      --st-border: var(--st-foreground);
      --st-border-width: 2px;
      --st-font-sans: 'Space Grotesk', system-ui, -apple-system, sans-serif;
      font-family: var(--st-font-sans);
      font-weight: 500;
    }
    .preset-brutalist h1,
    .preset-brutalist h2,
    .preset-brutalist h3,
    .preset-brutalist .card__header,
    .preset-brutalist .dialog__title,
    .preset-brutalist .drawer__title { font-weight: 700; }

    .preset-violet {
      --st-primary: oklch(0.58 0.22 285);
      --st-primary-foreground: oklch(1 0 0);
    }
  </style>
</head>
<body>
<main class="ks" data-stisla-ks>

  <div class="ks-bar" role="toolbar" aria-label="Kitchen sink controls">
    <h1 class="ks-bar__title">Kitchen sink</h1>
    <span class="ks-bar__sep" aria-hidden="true"></span>
    <div class="toggle-group" data-stisla-toggle-group role="radiogroup" aria-label="Preset">
      <button type="button" class="toggle toggle--compact" role="radio" data-state="active" aria-checked="true" data-value="default" data-stisla-ks-preset="">Default</button>
      <button type="button" class="toggle toggle--compact" role="radio" aria-checked="false" data-value="brutalist" data-stisla-ks-preset="preset-brutalist">Brutalist</button>
      <button type="button" class="toggle toggle--compact" role="radio" aria-checked="false" data-value="violet" data-stisla-ks-preset="preset-violet">Violet</button>
    </div>
    <span class="ks-bar__sep" aria-hidden="true"></span>
    <div class="toggle-group" data-stisla-toggle-group role="radiogroup" aria-label="Theme">
      <button type="button" class="toggle toggle--compact" role="radio" data-state="active" aria-checked="true" data-value="light" data-stisla-ks-theme="light">Light</button>
      <button type="button" class="toggle toggle--compact" role="radio" aria-checked="false" data-value="dark" data-stisla-ks-theme="dark">Dark</button>
    </div>
    <span class="ks-bar__sep" aria-hidden="true"></span>
    <div class="ks-density">
      <label for="ksDensity" class="ks-density__label">Spacing base</label>
      <div class="slider slider--compact" id="ksDensity" data-stisla-slider data-stisla-ks-density data-min="0.18" data-max="0.32" data-step="0.01" data-value="0.25">
        <div class="slider__track"><div class="slider__range"></div></div>
        <div class="slider__thumb"></div>
      </div>
      <output for="ksDensity" class="ks-density__value">0.25rem</output>
    </div>
  </div>

  {# ── BUTTONS ────────────────────────────────────────────────────────── #}
  <section class="ks-section">
    <div class="ks-label">Buttons</div>

    <div class="ks-row">
      <button type="button" class="btn btn--primary">Primary</button>
      <button type="button" class="btn btn--neutral">Neutral</button>
      <button type="button" class="btn btn--tertiary">Tertiary</button>
      <button type="button" class="btn btn--danger">Danger</button>
      <button type="button" class="btn btn--outline btn--primary">Outline</button>
      <button type="button" class="btn btn--outline btn--neutral">Outline</button>
      <button type="button" class="btn btn--outline btn--danger">Outline</button>
      <button type="button" class="btn btn--ghost btn--neutral">Ghost</button>
      <button type="button" class="btn btn--ghost btn--primary">Ghost</button>
      <button type="button" class="btn btn--ghost btn--danger">Ghost</button>
      <button type="button" class="btn btn--soft btn--primary">Soft</button>
      <button type="button" class="btn btn--soft btn--danger">Soft</button>
    </div>

    <div class="ks-row">
      <button type="button" class="btn btn--primary btn--compact">Small</button>
      <button type="button" class="btn btn--primary">Default</button>
      <button type="button" class="btn btn--primary btn--roomy">Large</button>
      <button type="button" class="btn btn--primary"><i data-lucide="plus"></i>Leading</button>
      <button type="button" class="btn btn--primary">Trailing<i data-lucide="arrow-right"></i></button>
      <button type="button" class="btn btn--outline btn--neutral btn--icon-only" aria-label="Edit"><i data-lucide="pencil"></i></button>
      <button type="button" class="btn btn--ghost btn--neutral btn--icon-only btn--icon-round" aria-label="More"><i data-lucide="more-horizontal"></i></button>
      <button type="button" class="btn btn--primary" aria-pressed="true">Pressed</button>
      <button type="button" class="btn btn--primary" disabled>Disabled</button>
      <button type="button" class="btn btn--primary is-loading" aria-busy="true">Saving</button>
    </div>

    <div class="ks-row">
      <div class="btn-group" role="group" aria-label="Button group">
        <button type="button" class="btn btn--outline btn--neutral">Left</button>
        <button type="button" class="btn btn--outline btn--neutral" aria-pressed="true">Middle</button>
        <button type="button" class="btn btn--outline btn--neutral">Right</button>
      </div>
      <div class="btn-group btn-group--compact" role="group" aria-label="Small group">
        <button type="button" class="btn btn--outline btn--neutral"><i data-lucide="align-left"></i></button>
        <button type="button" class="btn btn--outline btn--neutral" aria-pressed="true"><i data-lucide="align-center"></i></button>
        <button type="button" class="btn btn--outline btn--neutral"><i data-lucide="align-right"></i></button>
      </div>
      <button type="button" class="toggle" data-stisla-toggle aria-pressed="true">Toggle on</button>
      <button type="button" class="toggle" data-stisla-toggle aria-pressed="false">Toggle off</button>
      <div class="toggle-group" data-stisla-toggle-group role="radiogroup" aria-label="View">
        <button type="button" class="toggle" role="radio" data-state="active" aria-checked="true" data-value="day">Day</button>
        <button type="button" class="toggle" role="radio" aria-checked="false" data-value="week">Week</button>
        <button type="button" class="toggle" role="radio" aria-checked="false" data-value="month">Month</button>
      </div>
    </div>
  </section>

  {# ── FORM CONTROLS ──────────────────────────────────────────────────── #}
  <section class="ks-section">
    <div class="ks-label">Form controls</div>

    <div class="ks-grid">
      <div class="field">
        <label class="field__label" for="ksInput">Email</label>
        <input type="email" class="input" id="ksInput" placeholder="you@example.com" />
        <div class="field__description">A short helper sits under the field.</div>
      </div>
      <div class="field">
        <label class="field__label" for="ksInputSm">Small</label>
        <input type="text" class="input input--compact" id="ksInputSm" placeholder="Small input" />
      </div>
      <div class="field">
        <label class="field__label" for="ksInputLg">Large</label>
        <input type="text" class="input input--roomy" id="ksInputLg" placeholder="Large input" />
      </div>
      <div class="field">
        <label class="field__label" for="ksInputErr">Invalid</label>
        <input type="email" class="input" id="ksInputErr" value="not-an-email" aria-invalid="true" aria-describedby="ksInputErrMsg" />
        <div id="ksInputErrMsg" class="field__error">Please enter a valid email address.</div>
      </div>
      <div class="field">
        <label class="field__label" for="ksInputDis">Disabled</label>
        <input type="text" class="input" id="ksInputDis" value="Disabled" disabled />
      </div>
      <div class="field">
        <label class="field__label" for="ksSelect">Select</label>
        <select class="select" id="ksSelect">
          <option selected>Pick one</option>
          <option>Indonesia</option>
          <option>Malaysia</option>
          <option>Singapore</option>
        </select>
      </div>
      <div class="field">
        <label class="field__label" for="ksTextarea">Textarea</label>
        <textarea class="textarea" id="ksTextarea" rows="3" placeholder="Multi-line input…"></textarea>
      </div>
      <div class="field">
        <label class="field__label" for="ksColor">Color</label>
        <input type="color" class="input" id="ksColor" value="#3b82f6" />
      </div>
    </div>

    <div class="ks-row">
      <div class="input-group">
        <span class="input-group__text"><i data-lucide="search"></i></span>
        <input type="search" class="input" placeholder="Search" />
      </div>
      <div class="input-group">
        <span class="input-group__text">@</span>
        <input type="text" class="input" placeholder="username" />
        <span class="input-group__text">@company.com</span>
      </div>
      <div class="input-group input-group--compact">
        <input type="text" class="input input--compact" value="https://stisla.dev" />
        <button type="button" class="btn btn--neutral btn--compact">Copy</button>
      </div>
    </div>

    <div class="ks-grid">
      <div class="field">
        <div class="field__item">
          <input class="checkbox" type="checkbox" id="ksCb1" checked />
          <label class="field__label" for="ksCb1">Checked</label>
        </div>
        <div class="field__item">
          <input class="checkbox" type="checkbox" id="ksCb2" />
          <label class="field__label" for="ksCb2">Unchecked</label>
        </div>
        <div class="field__item">
          <input class="checkbox" type="checkbox" id="ksCb3" aria-invalid="true" checked />
          <label class="field__label" for="ksCb3">Invalid + checked</label>
        </div>
        <div class="field__item">
          <input class="checkbox" type="checkbox" id="ksCb4" disabled checked />
          <label class="field__label" for="ksCb4">Disabled</label>
        </div>
      </div>
      <div class="field">
        <div class="field__item">
          <input class="radio" type="radio" name="ksRadio" id="ksRb1" checked />
          <label class="field__label" for="ksRb1">Option one</label>
        </div>
        <div class="field__item">
          <input class="radio" type="radio" name="ksRadio" id="ksRb2" />
          <label class="field__label" for="ksRb2">Option two</label>
        </div>
        <div class="field__item">
          <input class="radio" type="radio" name="ksRadio" id="ksRb3" aria-invalid="true" />
          <label class="field__label" for="ksRb3">Invalid</label>
        </div>
        <div class="field__item">
          <input class="radio" type="radio" name="ksRadioD" id="ksRb4" disabled />
          <label class="field__label" for="ksRb4">Disabled</label>
        </div>
      </div>
      <div class="field">
        <div class="field__item">
          <input class="switch" type="checkbox" role="switch" id="ksSw1" checked />
          <label class="field__label" for="ksSw1">Auto-update</label>
        </div>
        <div class="field__item">
          <input class="switch" type="checkbox" role="switch" id="ksSw2" />
          <label class="field__label" for="ksSw2">Notifications</label>
        </div>
        <div class="field__item">
          <input class="switch switch--roomy" type="checkbox" role="switch" id="ksSw3" checked />
          <label class="field__label" for="ksSw3">Large switch</label>
        </div>
      </div>
    </div>

    <div class="ks-grid">
      <div class="field">
        <label class="field__label" for="ksSlider1">Brightness</label>
        <div class="slider" id="ksSlider1" data-stisla-slider data-value="40">
          <div class="slider__track"><div class="slider__range"></div></div>
          <div class="slider__thumb"></div>
        </div>
      </div>
      <div class="field">
        <label class="field__label" for="ksSlider2">Small</label>
        <div class="slider slider--compact" id="ksSlider2" data-stisla-slider data-value="60">
          <div class="slider__track"><div class="slider__range"></div></div>
          <div class="slider__thumb"></div>
        </div>
      </div>
      <div class="field">
        <label class="field__label" for="ksSlider3">Large</label>
        <div class="slider slider--roomy" id="ksSlider3" data-stisla-slider data-value="80">
          <div class="slider__track"><div class="slider__range"></div></div>
          <div class="slider__thumb"></div>
        </div>
      </div>
    </div>
  </section>

  {# ── SURFACES ──────────────────────────────────────────────────────── #}
  <section class="ks-section">
    <div class="ks-label">Surfaces</div>

    <div class="ks-row">
      <span class="badge">Default</span>
      <span class="badge badge--primary">Primary</span>
      <span class="badge badge--success">Success</span>
      <span class="badge badge--warning">Warning</span>
      <span class="badge badge--danger">Danger</span>
      <span class="badge badge--info">Info</span>
      <span class="badge badge--soft badge--primary">Soft</span>
      <span class="badge badge--soft badge--success">Soft</span>
      <span class="badge badge--soft badge--warning">Soft</span>
      <span class="badge badge--soft badge--danger">Soft</span>
      <span class="badge badge--soft badge--success"><i data-lucide="check"></i>Active</span>
      <span class="badge badge--soft badge--warning"><i data-lucide="clock"></i>Pending</span>
    </div>

    <div class="ks-row">
      <span class="icon-box icon-box--primary"><i data-lucide="zap"></i></span>
      <span class="icon-box icon-box--success"><i data-lucide="check"></i></span>
      <span class="icon-box icon-box--warning"><i data-lucide="clock"></i></span>
      <span class="icon-box icon-box--danger"><i data-lucide="alert-triangle"></i></span>
      <span class="icon-box icon-box--info"><i data-lucide="info"></i></span>
      <span class="icon-box icon-box--primary icon-box--round"><i data-lucide="bell"></i></span>
      <span class="icon-box icon-box--primary icon-box--compact"><i data-lucide="zap"></i></span>
      <span class="icon-box icon-box--primary"><i data-lucide="zap"></i></span>
      <span class="icon-box icon-box--primary icon-box--roomy"><i data-lucide="zap"></i></span>
      <kbd class="kbd">?</kbd>
      <kbd class="kbd"><kbd class="kbd">⌘</kbd><kbd class="kbd">K</kbd></kbd>
      <kbd class="kbd"><kbd class="kbd">Ctrl</kbd><kbd class="kbd">Shift</kbd><kbd class="kbd">P</kbd></kbd>
      <a href="#" class="link">Inline link</a>
      <a href="#" class="link" style="--link-color: var(--st-success);">Success link</a>
      <a href="#" class="link" style="--link-color: var(--st-danger);">Danger link</a>
    </div>

    <div class="ks-stack ks-stack--fill">
      <div class="alert alert--neutral"><i data-lucide="info"></i><div>Neutral alert with a leading icon.</div></div>
      <div class="alert alert--primary"><i data-lucide="info"></i><div>Heads up, your trial ends in 3 days.</div></div>
      <div class="alert alert--success"><i data-lucide="check-circle-2"></i><div>Your changes have been saved successfully.</div></div>
      <div class="alert alert--warning"><i data-lucide="triangle-alert"></i><div>Some features may not work.</div></div>
      <div class="alert alert--danger">
        <i data-lucide="x-circle"></i>
        <div class="alert__title">Payment failed</div>
        <div class="alert__description">We couldn't charge your card. Update billing details and retry.</div>
        <div class="alert__action">
          <button type="button" class="btn btn--ghost btn--neutral btn--compact">Dismiss</button>
          <button type="button" class="btn btn--danger btn--compact">Retry</button>
        </div>
      </div>
      <div class="alert alert--info"><i data-lucide="info"></i><div>An info alert with <a href="#" class="alert__link">an inline link</a>.</div></div>
    </div>

    <div class="ks-grid ks-grid--cards">
      <div class="card">
        <div class="card__body">
          <h5 class="card__title">Card title</h5>
          <h6 class="card__subtitle">Card subtitle</h6>
          <p class="card__text">Quick example text to build on the card title and make up the bulk of the card's content.</p>
          <a href="#" class="card__link">Card link</a>
          <a href="#" class="card__link">Another link</a>
        </div>
      </div>
      <div class="card">
        <div class="card__header">
          Featured
          <button type="button" class="btn btn--neutral btn--compact ms-auto">Action</button>
        </div>
        <div class="card__body">
          <h5 class="card__title">With header & footer</h5>
          <p class="card__text">Body sits between a transparent header and a tinted footer.</p>
          <button type="button" class="btn btn--primary">Go somewhere</button>
        </div>
        <div class="card__footer">
          <span class="fs-2 text-muted-foreground">2 days ago</span>
        </div>
      </div>
      <div class="card card--flat">
        <div class="card__body">
          <h5 class="card__title">Flat card</h5>
          <p class="card__text">No drop shadow. Reads as a frame, not a raised surface.</p>
          <hr class="separator" />
          <p class="card__text">Below a separator.</p>
        </div>
      </div>
      <div class="card">
        <ul class="list-group list-group--flush">
          <li class="list-group__item">List item one</li>
          <li class="list-group__item" data-state="active" aria-current="true">Active item</li>
          <li class="list-group__item">List item three</li>
          <li class="list-group__item" aria-disabled="true">Disabled item</li>
        </ul>
      </div>
    </div>

    <div class="ks-stack ks-stack--fill">
      <div class="media">
        <div class="media__figure">
          <span class="icon-box icon-box--primary"><i data-lucide="package"></i></span>
        </div>
        <div class="media__content">
          <div class="media__title">Order #ATL-2918</div>
          <div class="media__description">Out for delivery, arrives today by 6 PM.</div>
        </div>
        <div class="media__action">
          <button type="button" class="btn btn--outline btn--neutral btn--compact">Track</button>
        </div>
      </div>
      <div class="media">
        <div class="media__figure">
          <span class="avatar avatar--circle" data-stisla-avatar>
            <img class="avatar__image" src="https://i.pravatar.cc/96?img=12" alt="" />
            <span class="avatar__fallback">JC</span>
          </span>
        </div>
        <div class="media__content">
          <div class="media__title">Joseph Cooper</div>
          <div class="media__description">Pushed 3 commits to atlas/main.</div>
          <div class="media__meta">2 minutes ago</div>
        </div>
        <div class="media__action">
          <button type="button" class="btn btn--ghost btn--neutral btn--icon-only btn--compact" aria-label="More"><i data-lucide="more-horizontal"></i></button>
        </div>
      </div>
    </div>
  </section>

  {# ── MEDIA ─────────────────────────────────────────────────────────── #}
  <section class="ks-section">
    <div class="ks-label">Media</div>

    <div class="ks-row">
      <span class="avatar avatar--compact">SM</span>
      <span class="avatar">ND</span>
      <span class="avatar avatar--roomy">LG</span>
      <span class="avatar avatar--spacious">XL</span>
