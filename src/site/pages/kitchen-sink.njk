<script src="https://unpkg.com/lucide@latest"></script>
<script>
  lucide.createIcons();

  // Controls strip: preset wrapper class, theme attribute, and density var.
  (function () {
    var root = document.querySelector('[data-stisla-ks]');
    if (!root) return;

    var presetButtons = root.querySelectorAll('[data-stisla-ks-preset]');
    presetButtons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var next = btn.getAttribute('data-stisla-ks-preset') || '';
        presetButtons.forEach(function (b) {
          var c = b.getAttribute('data-stisla-ks-preset');
          if (c) root.classList.remove(c);
        });
        if (next) root.classList.add(next);
      });
    });

    var themeButtons = root.querySelectorAll('[data-stisla-ks-theme]');
    themeButtons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var next = btn.getAttribute('data-stisla-ks-theme');
        document.documentElement.dataset.theme = next;
      });
    });

    var slider = root.querySelector('[data-stisla-ks-density]');
    var out = root.querySelector('.ks-density__value');
    if (slider) {
      slider.addEventListener('stisla:slider:input', function (e) {
        var v = e.detail.value;
        root.style.setProperty('--st-spacing', v + 'rem');
        if (out) out.value = parseFloat(v).toFixed(2) + 'rem';
      });
    }
  })();
</script>
