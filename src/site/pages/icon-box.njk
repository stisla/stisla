{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Icon box · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Icon box</h1>
    <p class="lead">A square, tinted container for a single icon.</p>
  </header>

  <section>
    <h2>Variants</h2>
    <p>Pair <code>.icon-box</code> with <code>.icon-box-{state}</code> for a tint in the matching brand color. The background sits at 15% and the icon holds the solid color.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2">
      <span class="icon-box icon-box-primary"><i data-lucide="zap"></i></span>
      <span class="icon-box icon-box-secondary"><i data-lucide="settings"></i></span>
      <span class="icon-box icon-box-success"><i data-lucide="check"></i></span>
      <span class="icon-box icon-box-danger"><i data-lucide="alert-triangle"></i></span>
      <span class="icon-box icon-box-warning"><i data-lucide="clock"></i></span>
      <span class="icon-box icon-box-info"><i data-lucide="info"></i></span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Shape</h2>
    <p>Stack Bootstrap's rounded utilities on top to switch shape without redefining anything. Use <code>.rounded-circle</code> for a circle or <code>.rounded-0</code> for a hard square.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <span class="icon-box icon-box-primary"><i data-lucide="bell"></i></span>
      <span class="icon-box icon-box-primary rounded-circle"><i data-lucide="bell"></i></span>
      <span class="icon-box icon-box-primary rounded-0"><i data-lucide="bell"></i></span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>In a row</h2>
    <p>Reads well as a leading element next to a title and supporting copy.</p>
    {% call ui.demo() %}
    <div class="card">
      <ul class="list-group list-group-flush">
        <li class="list-group-item d-flex align-items-center gap-3">
          <span class="icon-box icon-box-success"><i data-lucide="hard-drive"></i></span>
          <div class="flex-grow-1">
            <div class="fw-medium">Backups</div>
            <div class="small text-body-secondary">Daily snapshot completed</div>
          </div>
          <span class="badge badge-light-success">On</span>
        </li>
        <li class="list-group-item d-flex align-items-center gap-3">
          <span class="icon-box icon-box-warning"><i data-lucide="bell"></i></span>
          <div class="flex-grow-1">
            <div class="fw-medium">Alerts</div>
            <div class="small text-body-secondary">Two services need attention</div>
          </div>
          <span class="badge badge-light-warning">2</span>
        </li>
        <li class="list-group-item d-flex align-items-center gap-3">
          <span class="icon-box icon-box-danger"><i data-lucide="shield-off"></i></span>
          <div class="flex-grow-1">
            <div class="fw-medium">Firewall</div>
            <div class="small text-body-secondary">Disabled by an admin</div>
          </div>
          <span class="badge badge-light-danger">Off</span>
        </li>
      </ul>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Custom color</h2>
    <p>Override <code>--bs-icon-box-bg</code> and <code>--bs-icon-box-color</code> inline for one-off tints that sit outside the theme palette.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2">
      <span class="icon-box" style="--bs-icon-box-bg: rgba(168, 85, 247, 0.15); --bs-icon-box-color: #a855f7;">
        <i data-lucide="sparkles"></i>
      </span>
      <span class="icon-box" style="--bs-icon-box-bg: rgba(236, 72, 153, 0.15); --bs-icon-box-color: #ec4899;">
        <i data-lucide="heart"></i>
      </span>
      <span class="icon-box" style="--bs-icon-box-bg: rgba(20, 184, 166, 0.15); --bs-icon-box-color: #14b8a6;">
        <i data-lucide="leaf"></i>
      </span>
    </div>
    {% endcall %}
  </section>
{% endblock %}
