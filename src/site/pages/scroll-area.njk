    {% endcall %}
  </section>

  <section>
    <h2>Both axes</h2>
    <p>A bounded box with content larger than its viewport scrolls in both directions. The two bars share the same skin.</p>
    {% call ui.demo() %}
    <div class="scroll-area scroll-area--bordered" data-stisla-scroll-area style="height: 18rem;">
      <table class="table" style="min-width: 48rem; margin: 0;">
        <thead>
          <tr><th>Project</th><th>Owner</th><th>Stage</th><th>Region</th><th>Updated</th><th>Status</th></tr>
        </thead>
