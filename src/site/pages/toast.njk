  {# Demo bindings — wires the JS-helper buttons to live Stisla.toast calls.
     Lives outside any ui.demo() block so it doesn't appear in the source
     viewer; only the markup with data-* attributes does. #}
  <script>
    document.addEventListener('click', (e) => {
      const pos = e.target.closest('[data-demo-toast-position]');
      if (pos) {
        const name = pos.getAttribute('data-demo-toast-position');
        Stisla.toast({
          title: name.replace('-', ' '),
          description: 'Mounted in the ' + name + ' region.',
          region: '.toast-region--' + name,
        });
        return;
      }

      const shortcut = e.target.closest('[data-demo-toast-shortcut]');
      if (shortcut) {
        const kind = shortcut.getAttribute('data-demo-toast-shortcut');
        if (kind === 'success') Stisla.toast.success('Saved', { description: 'Your changes are saved.' });
        if (kind === 'error')   Stisla.toast.error('Couldn’t upload', { description: 'Network dropped halfway through.' });
        if (kind === 'warning') Stisla.toast.warning('Storage almost full', { description: 'You’re at 94% of the workspace quota.' });
        if (kind === 'info')    Stisla.toast.info('New version available', { description: 'Refresh to pick up the latest dashboard build.' });
        return;
      }

      if (e.target.closest('[data-demo-toast-action]')) {
        Stisla.toast({
          title: 'Project moved to trash',
          description: '"Redesign" will be deleted in 30 days.',
          action: {
            label: 'Undo',
            onClick: () => Stisla.toast.success('Restored'),
          },
        });
        return;
      }

      if (e.target.closest('[data-demo-toast-promise]')) {
        const willResolve = (window.__toastPromiseDemo = !window.__toastPromiseDemo);
        const fakeApi = new Promise((res, rej) => {
          setTimeout(() => {
            if (willResolve) res({ name: 'changes' });
            else rej(new Error('Network error'));
          }, 1500);
        });
        Stisla.toast.promise(fakeApi, {
          loading: 'Saving changes…',
          success: (data) => 'Saved ' + data.name,
          error: (err) => 'Failed: ' + err.message,
        });
      }
    });
  </script>
