{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Checks & radios · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Checks &amp; radios</h1>
    <p class="lead">Native checkbox and radio inputs styled on the framework. See <a href="/switch" class="link">Switch</a> for the track-and-thumb variant.</p>
  </header>

  <section>
    <h2>Checkbox</h2>
    <p>Wrap an <code>&lt;input type="checkbox"&gt;</code> in <code>.form-check</code> and pair it with a <code>.form-check__label</code> tied via <code>for</code>/<code>id</code>.</p>
    {% call ui.demo() %}
    <div class="demo-stack" style="max-width: 24rem;">
      <div class="form-check">
        <input class="form-check__input" type="checkbox" id="defaultCheck" />
        <label class="form-check__label" for="defaultCheck">Default checkbox</label>
      </div>
      <div class="form-check">
        <input class="form-check__input" type="checkbox" id="checkedCheck" checked />
        <label class="form-check__label" for="checkedCheck">Checked by default</label>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Radio</h2>
    <p>Group radios by giving them a shared <code>name</code>. The browser handles single-selection within the group.</p>
    {% call ui.demo() %}
    <div class="demo-stack" style="max-width: 24rem;">
      <div class="form-check">
        <input class="form-check__input" type="radio" name="defaultRadio" id="defaultRadio1" checked />
        <label class="form-check__label" for="defaultRadio1">First option</label>
      </div>
      <div class="form-check">
        <input class="form-check__input" type="radio" name="defaultRadio" id="defaultRadio2" />
        <label class="form-check__label" for="defaultRadio2">Second option</label>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Inline</h2>
    <p>Add <code>.form-check--inline</code> to line items up on the same row.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <div class="form-check form-check--inline">
        <input class="form-check__input" type="checkbox" id="inlineCheck1" />
        <label class="form-check__label" for="inlineCheck1">One</label>
      </div>
      <div class="form-check form-check--inline">
        <input class="form-check__input" type="checkbox" id="inlineCheck2" />
        <label class="form-check__label" for="inlineCheck2">Two</label>
      </div>
      <div class="form-check form-check--inline">
        <input class="form-check__input" type="checkbox" id="inlineCheck3" />
        <label class="form-check__label" for="inlineCheck3">Three</label>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Indeterminate</h2>
    <p>The indeterminate state is set from script. There's no HTML attribute for it. Useful as a parent of a partially-selected group.</p>
    {% call ui.demo() %}
    <div class="demo-stack" style="max-width: 24rem;">
      <div class="form-check">
        <input class="form-check__input" type="checkbox" id="indeterminateCheck" />
        <label class="form-check__label" for="indeterminateCheck">Select all</label>
      </div>
      <script>
        document.getElementById('indeterminateCheck').indeterminate = true;
      </script>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Reverse</h2>
    <p>Add <code>.form-check--reverse</code> to flip the label to the start and the input to the end.</p>
    {% call ui.demo() %}
    <div class="demo-stack" style="max-width: 24rem;">
      <div class="form-check form-check--reverse">
        <input class="form-check__input" type="checkbox" id="reverseCheck" />
        <label class="form-check__label" for="reverseCheck">Reversed checkbox</label>
      </div>
      <div class="form-check form-check--reverse">
        <input class="form-check__input" type="radio" name="reverseRadio" id="reverseRadio" checked />
        <label class="form-check__label" for="reverseRadio">Reversed radio</label>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Disabled</h2>
    <p>Add <code>disabled</code> to dim the input and its label, and block interaction.</p>
    {% call ui.demo() %}
    <div class="demo-stack" style="max-width: 24rem;">
      <div class="form-check">
        <input class="form-check__input" type="checkbox" id="disabledCheck" disabled />
        <label class="form-check__label" for="disabledCheck">Disabled checkbox</label>
      </div>
      <div class="form-check">
        <input class="form-check__input" type="checkbox" id="disabledCheckedCheck" checked disabled />
        <label class="form-check__label" for="disabledCheckedCheck">Disabled, checked</label>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Browser validation</h2>
    <p>Pair <code>required</code> with the native <code>:user-invalid</code> pseudo. The browser fires it after the user interacts with the field, and clears it the moment the constraint is satisfied. Use for inline validation where the affordance owns its own state.</p>
    {% call ui.demo() %}
    <div class="demo-stack" style="max-width: 24rem;">
      <div class="form-check">
        <input class="form-check__input" type="checkbox" id="reqTerms" required />
        <label class="form-check__label" for="reqTerms">Accept the terms</label>
      </div>
      <div class="form-check">
        <input class="form-check__input" type="radio" name="reqPlan" id="reqPlanBasic" required />
        <label class="form-check__label" for="reqPlanBasic">Basic plan</label>
      </div>
      <div class="form-check">
        <input class="form-check__input" type="radio" name="reqPlan" id="reqPlanPro" required />
        <label class="form-check__label" for="reqPlanPro">Pro plan</label>
      </div>
    </div>
    {% endcall %}
    <p>The fields above look valid until you interact with them. Click in then click away (or try submitting an enclosing form) to trigger <code>:user-invalid</code>. Check the box or pick a radio and the red clears on its own.</p>
  </section>

  <section>
    <h2>Server validation</h2>
    <p>Set <code>aria-invalid="true"</code> from your form library. The attribute is sticky. Frameworks like React Hook Form, Formik, vee-validate, and Rails form helpers manage this based on their own error state. Stisla just paints the red while the attribute is present; remove it when your validator considers the field resolved.</p>
    {% call ui.demo() %}
    <div class="demo-stack" style="max-width: 24rem;">
      <div class="form-check">
        <input class="form-check__input" type="checkbox" id="srvTerms" aria-invalid="true" />
        <label class="form-check__label" for="srvTerms">Accept the terms</label>
      </div>
      <div class="form-check">
        <input class="form-check__input" type="checkbox" id="srvTermsChecked" aria-invalid="true" checked />
        <label class="form-check__label" for="srvTermsChecked">Accept the terms (checked, server still flagged)</label>
      </div>
      <div class="form-check">
        <input class="form-check__input" type="radio" name="srvPlan" id="srvPlanBasic" aria-invalid="true" />
        <label class="form-check__label" for="srvPlanBasic">Basic plan</label>
      </div>
      <div class="form-check">
        <input class="form-check__input" type="radio" name="srvPlan" id="srvPlanPro" aria-invalid="true" checked />
        <label class="form-check__label" for="srvPlanPro">Pro plan (selected, server still flagged)</label>
      </div>
    </div>
    {% endcall %}
    <p>The red border stays even after you check or select. That is the point. Server errors should not dismiss themselves on touch. The checked variants show both signals composing at once. Primary fill says "this is selected", red rim says "and the server still considers it invalid".</p>
  </section>

  <section>
    <h2>Without labels</h2>
    <p>Drop the <code>.form-check</code> wrapper to use a bare <code>.form-check__input</code>. Always pair with an <code>aria-label</code> for accessibility.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <input class="form-check__input" type="checkbox" aria-label="Bare checkbox" />
      <input class="form-check__input" type="radio" aria-label="Bare radio" checked />
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Customization</h2>
    <p>Seven variables retune <code>.form-check__input</code> without touching component CSS. Override on the input itself, on the <code>.form-check</code> wrapper, on a parent scope, or on <code>:root</code>. The cascade scopes the change.</p>
    <div class="prose">
      <table>
        <thead>
          <tr>
            <th>Variable</th>
            <th>Default</th>
            <th>Use</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--form-check-size</code></td>
            <td>calc(1rem * var(--st-density))</td>
            <td>Box dimension; checkbox renders square, radio inherits and renders round</td>
          </tr>
          <tr>
            <td><code>--form-check-radius</code></td>
            <td>0.25rem</td>
            <td>Checkbox corner radius; radio overrides to 50%</td>
          </tr>
          <tr>
            <td><code>--form-check-bg</code></td>
            <td>var(--st-surface)</td>
            <td>Unchecked background</td>
          </tr>
          <tr>
            <td><code>--form-check-border</code></td>
            <td>var(--st-border)</td>
            <td>Unchecked border</td>
          </tr>
          <tr>
            <td><code>--form-check-checked-bg</code></td>
            <td>var(--st-primary)</td>
            <td>Checked or indeterminate background</td>
          </tr>
          <tr>
            <td><code>--form-check-checked-color</code></td>
            <td>var(--st-primary-foreground)</td>
            <td>Indicator color reference (the SVG itself is a literal white that pairs with the default primary; recolor the indicator by replacing <code>--form-check-indicator</code> instead)</td>
          </tr>
          <tr>
            <td><code>--form-check-indicator</code></td>
            <td>SVG data URL (checkmark, dash, or dot)</td>
            <td>Glyph painted over <code>--form-check-checked-bg</code>; checked, indeterminate, and radio states each set their own SVG</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p>Checkbox and radio share the same variable surface. The radio reads the same defaults and only flips <code>--form-check-radius</code> to 50% and swaps <code>--form-check-indicator</code> to the dot SVG. Override either var on the radio's input to retune just that shape.</p>
  </section>
{% endblock %}
