{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Buttons · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Buttons</h1>
    <p class="lead">A clickable control that triggers an action.</p>
  </header>

  <section>
    <h2>Primary</h2>
    <p>
      The main call to action. Use one per surface for the action you most
      want the user to take.
    </p>
    {% call ui.demo() %}
    <button type="button" class="btn btn--primary">Primary</button>
    {% endcall %}
  </section>

  <section>
    <h2>Neutral</h2>
    <p>
      A quieter button next to primary. Use for actions that should sit
      alongside primary without competing for attention, like Cancel next
      to Save or Filter next to Search.
    </p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--neutral">Neutral</button>
      <button type="button" class="btn btn--outline btn--neutral">Outline</button>
    </div>
    {% endcall %}
    <p>The canonical pairing in context.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary">Save changes</button>
      <button type="button" class="btn btn--outline btn--neutral">Cancel</button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Tertiary</h2>
    <p>
      An alternative to primary when the brand color is already taken on the
      page and a second prominent action needs to stand apart. The fill
      flips by theme, dark in light mode and light in dark mode.
    </p>
    {% call ui.demo() %}
    <button type="button" class="btn btn--tertiary">Tertiary</button>
    {% endcall %}
  </section>

  <section>
    <h2>Danger</h2>
    <p>
      For destructive actions like Delete, Remove, or Discard. The filled
      red is the safe default for a confirm dialog. Outline and light fit
      softer surfaces such as row-level deletes inside a dense table.
    </p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--danger">Danger</button>
      <button type="button" class="btn btn--outline btn--danger">Outline</button>
      <button type="button" class="btn btn--soft btn--danger">Soft</button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Ghost</h2>
    <p>
      No background, no border, just a colored label. Use for low-stakes
      actions in toolbars, in-card cancels, or quiet inline triggers. Hover
      paints a soft tint so the affordance shows up on interaction.
    </p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--ghost btn--neutral">Cancel</button>
      <button type="button" class="btn btn--ghost btn--primary">View details</button>
      <button type="button" class="btn btn--ghost btn--danger">Remove</button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Custom color</h2>
    <p>
      For one-off colors outside the shipped tones, set
      <code>--btn-tone</code> and <code>--btn-color</code> inline. The
      bg, hover, active, rim, and bevel all derive from
      <code>--btn-tone</code>, so a one-line override carries every state.
    </p>
    <p>
      If the same color appears in three or more places, promote it to a
      project-scoped class. The shipped tones (primary, neutral, tertiary,
      danger) are the curated set with verified text contrast across light
      and dark.
    </p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn" style="--btn-tone: oklch(0.55 0.18 149); --btn-color: white;">
        Custom green
      </button>
      <button type="button" class="btn" style="--btn-tone: oklch(0.55 0.15 285); --btn-color: white;">
        Custom violet
      </button>
      <button type="button" class="btn" style="--btn-tone: oklch(0.65 0.18 55); --btn-color: white;">
        Custom orange
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Heights are pinned across small, default, and large regardless of content.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary btn--sm">Small</button>
      <button type="button" class="btn btn--primary">Default</button>
      <button type="button" class="btn btn--primary btn--lg">Large</button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>With icon</h2>
    <p>
      Icons drop into <code>.btn</code> via flexbox <code>gap</code>. Any
      inline <code>&lt;svg&gt;</code> or <code>&lt;i&gt;</code> scales to
      the button's font size.
    </p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary">
        <i data-lucide="plus"></i>
        Leading icon
      </button>
      <button type="button" class="btn btn--primary">
        Trailing icon
        <i data-lucide="arrow-right"></i>
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Icon only</h2>
    <p>
      Add <code>.btn--icon-only</code> for a square button at any size.
      Pair with <code>aria-label</code> so the action stays announced. Add
      <code>.btn--icon-round</code> for a circular silhouette.
    </p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary btn--icon-only btn--sm" aria-label="Add">
        <i data-lucide="plus"></i>
      </button>
      <button type="button" class="btn btn--primary btn--icon-only" aria-label="Add">
        <i data-lucide="plus"></i>
      </button>
      <button type="button" class="btn btn--primary btn--icon-only btn--lg" aria-label="Add">
        <i data-lucide="plus"></i>
      </button>
      <button type="button" class="btn btn--outline btn--danger btn--icon-only" aria-label="Delete">
        <i data-lucide="trash-2"></i>
      </button>
      <button type="button" class="btn btn--outline btn--neutral btn--icon-only" aria-label="Edit">
        <i data-lucide="pencil"></i>
      </button>
      <button type="button" class="btn btn--ghost btn--neutral btn--icon-only btn--icon-round" aria-label="More">
        <i data-lucide="more-horizontal"></i>
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>States</h2>
    <p>
      <code>aria-pressed="true"</code> applies the pressed-in fill on any
      tone. Native <code>:disabled</code> applies on form controls;
      <code>aria-disabled="true"</code> and <code>tabindex="-1"</code>
      mirror the same behavior on link buttons.
    </p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary" aria-pressed="true">Pressed</button>
      <button type="button" class="btn btn--primary" disabled>Disabled button</button>
      <a href="#" role="button" class="btn btn--primary" aria-disabled="true" tabindex="-1">Disabled link</a>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Loading</h2>
    <p>
      Toggle <code>.is-loading</code> from JS to show a leading spinner.
      The label stays visible. Any leading or trailing icons hide so the
      spinner takes their place. Click is blocked while the class is
      applied. Pair with <code>aria-busy="true"</code>.
    </p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary is-loading btn--sm" aria-busy="true">Saving</button>
      <button type="button" class="btn btn--primary is-loading" aria-busy="true">Saving</button>
      <button type="button" class="btn btn--primary is-loading btn--lg" aria-busy="true">Saving</button>
      <button type="button" class="btn btn--outline btn--neutral is-loading" aria-busy="true">Loading</button>
      <button type="button" class="btn btn--danger btn--icon-only is-loading" aria-busy="true" aria-label="Deleting"></button>
    </div>
    {% endcall %}
    <p>With icons, the spinner replaces them in place.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary is-loading" aria-busy="true">
        <i data-lucide="plus"></i>
        Adding
      </button>
      <button type="button" class="btn btn--primary is-loading" aria-busy="true">
        Continuing
        <i data-lucide="arrow-right"></i>
      </button>
    </div>
    {% endcall %}
    <p>Click to try. The state auto-clears after two seconds.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn--primary" data-demo-loading="2000">
      <i data-lucide="save"></i>
      Save changes
    </button>
    {% endcall %}
  </section>

  <section>
    <h2>Works on any element</h2>
    <p>
      <code>.btn</code> renders the same on <code>&lt;button&gt;</code>,
      <code>&lt;a&gt;</code>, and form inputs.
    </p>
    {% call ui.demo() %}
    <div class="demo-row">
      <button type="button" class="btn btn--primary">&lt;button&gt;</button>
      <a href="#" role="button" class="btn btn--primary">&lt;a&gt;</a>
      <input type="submit" class="btn btn--primary" value="<input type=submit>" />
    </div>
    {% endcall %}
  </section>
{% endblock %}
