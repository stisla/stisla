{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Placeholders · Stisla{% endblock %}

{% block content %}
  <header>
    <h1>Placeholders</h1>
    <p class="lead">A skeleton stand-in for content that hasn't loaded yet.</p>
  </header>

  <section>
    <h2>Example</h2>
    <p>The same card in two states. The loading card mirrors the real card's layout so nothing jumps when content arrives. The bars are a neutral muted gray by default, so nothing competes with the real content.</p>
    {% call ui.demo() %}
    <div class="demo-grid">
      <div class="card">
        <div class="card__body">
          <h5 class="card__title">Quarterly review</h5>
          <p class="card__text">Wraps up the metrics, customer wins, and what's queued for next quarter.</p>
          <a href="#" class="btn btn--primary">Open report</a>
        </div>
      </div>
      <div class="card" aria-hidden="true">
        <div class="card__body">
          <span class="placeholder placeholder--glow mb-2" style="width: 50%"></span>
          <p class="d-flex flex-column gap-2 w-100">
            <span class="placeholder placeholder--glow" style="width: 80%"></span>
            <span class="placeholder placeholder--glow" style="width: 70%"></span>
            <span class="placeholder placeholder--glow" style="width: 30%"></span>
          </p>
          <span class="placeholder placeholder--glow mt-2" aria-hidden="true" style="width: 6rem; height: 2.25rem"></span>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Basic</h2>
    <p>Apply <code>.placeholder</code> to any inline element and size it via an inline style. The bar fills with a neutral muted gray at half opacity and shows a wait cursor.</p>
    {% call ui.demo() %}
    <p class="text-muted-foreground m-0" aria-hidden="true">
      <span class="placeholder" style="width: 50%"></span>
    </p>
    {% endcall %}
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Two height modifiers sit alongside the default. <code>.placeholder--compact</code> trims the bar for inline captions; <code>.placeholder--roomy</code> bulks it up for headings.</p>
    {% call ui.demo() %}
    <div class="text-muted-foreground d-flex flex-column gap-2" aria-hidden="true">
      <span class="placeholder placeholder--roomy" style="width: 100%"></span>
      <span class="placeholder" style="width: 100%"></span>
      <span class="placeholder placeholder--compact" style="width: 100%"></span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Colors</h2>
    <p>The default is a neutral muted gray. Set <code>--placeholder-bg</code> to tint a bar to any token.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-column gap-2" aria-hidden="true">
      <span class="placeholder" style="width: 100%"></span>
      <span class="placeholder" style="width: 100%; --placeholder-bg: var(--st-primary)"></span>
      <span class="placeholder" style="width: 100%; --placeholder-bg: var(--st-success)"></span>
      <span class="placeholder" style="width: 100%; --placeholder-bg: var(--st-danger)"></span>
      <span class="placeholder" style="width: 100%; --placeholder-bg: var(--st-warning)"></span>
      <span class="placeholder" style="width: 100%; --placeholder-bg: var(--st-info)"></span>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Animation</h2>
    <p>Add <code>.placeholder--glow</code> to a bar for a pulsing opacity loop, or <code>.placeholder--wave</code> for a shimmer that sweeps left to right. They're modifiers on the bar, so put the class on each bar you want animated.</p>
    {% call ui.demo() %}
    <div class="demo-stack text-muted-foreground" aria-hidden="true">
      <div class="d-flex flex-column gap-2">
        <span class="placeholder placeholder--glow" style="width: 100%"></span>
        <span class="placeholder placeholder--glow" style="width: 70%"></span>
      </div>
      <div class="d-flex flex-column gap-2">
        <span class="placeholder placeholder--wave" style="width: 100%"></span>
        <span class="placeholder placeholder--wave" style="width: 70%"></span>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Customization</h2>
    <p>These variables retune <code>.placeholder</code> without touching component CSS. Override on <code>.placeholder</code> itself, on a parent scope, or on <code>:root</code>. The cascade scopes the change.</p>
    <table>
      <thead>
        <tr>
          <th>Variable</th>
          <th>Use</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>--placeholder-bg</code></td>
          <td>Fill color; defaults to a neutral muted gray</td>
        </tr>
        <tr>
          <td><code>--placeholder-opacity</code></td>
          <td>Opacity applied over the fill</td>
        </tr>
        <tr>
          <td><code>--placeholder-radius</code></td>
          <td>Corner radius</td>
        </tr>
        <tr>
          <td><code>--placeholder-height</code></td>
          <td>Block height; size modifiers reassign this</td>
        </tr>
      </tbody>
    </table>
  </section>
{% endblock %}
