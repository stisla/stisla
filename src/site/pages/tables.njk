{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Tables · Stisla v3{% endblock %}

{% set img_maya = "https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=facearea&facepad=2.5&w=120&h=120&q=80" %}
{% set img_mateo = "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=facearea&facepad=2.5&w=120&h=120&q=80" %}
{% set img_sara = "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=facearea&facepad=2.5&w=120&h=120&q=80" %}
{% set img_theo = "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=facearea&facepad=2.5&w=120&h=120&q=80" %}
{% set img_alex = "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=facearea&facepad=2.5&w=120&h=120&q=80" %}

{% block content %}
  <header>
    <h1>Tables</h1>
    <p class="lead">A flat data grid for rows of structured records.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>Wrap your data in <code>.table</code>. The first and last column cells line up with the 20px card body gutter so a table drops into a <code>.card</code> flush.</p>
    {% call ui.demo() %}
    <table class="table">
      <thead>
        <tr>
          <th scope="col">Plan</th>
          <th scope="col">Seats</th>
          <th scope="col">Storage</th>
          <th scope="col" class="text-end">Price</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th scope="row">Starter</th>
          <td>3</td>
          <td>10 GB</td>
          <td class="text-end">$0/mo</td>
        </tr>
        <tr>
          <th scope="row">Team</th>
          <td>15</td>
          <td>100 GB</td>
          <td class="text-end">$29/mo</td>
        </tr>
        <tr>
          <th scope="row">Business</th>
          <td>50</td>
          <td>1 TB</td>
          <td class="text-end">$99/mo</td>
        </tr>
        <tr>
          <th scope="row">Enterprise</th>
          <td>Unlimited</td>
          <td>Custom</td>
          <td class="text-end">Talk to sales</td>
        </tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Variants</h2>
    <p>Drop a <code>.table-{state}</code> class on a <code>&lt;tr&gt;</code> or <code>&lt;th&gt;</code> to tint that row or cell. Uses BS5's <code>$table-variants</code> loop.</p>
    {% call ui.demo() %}
    <table class="table">
      <thead>
        <tr>
          <th scope="col">Variant</th>
          <th scope="col">Event</th>
          <th scope="col">Recorded</th>
        </tr>
      </thead>
      <tbody>
        {% for v in ["primary", "secondary", "success", "danger", "warning", "info"] %}
        <tr class="table-{{ v }}">
          <th scope="row" class="text-capitalize">{{ v }}</th>
          <td>Audit event #{{ 100 + loop.index0 }}</td>
          <td>{{ loop.index0 + 1 }} min ago</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Striped rows</h2>
    <p>Add <code>.table-striped</code> to zebra-stripe every other row in the body.</p>
    {% call ui.demo() %}
    <table class="table table-striped">
      <thead>
        <tr>
          <th scope="col">Region</th>
          <th scope="col">Latency p50</th>
          <th scope="col">Latency p99</th>
          <th scope="col" class="text-end">Requests / min</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>us-east-1</td><td>42 ms</td><td>180 ms</td><td class="text-end">12,840</td></tr>
        <tr><td>us-west-2</td><td>58 ms</td><td>220 ms</td><td class="text-end">9,210</td></tr>
        <tr><td>eu-west-1</td><td>61 ms</td><td>240 ms</td><td class="text-end">7,455</td></tr>
        <tr><td>ap-southeast-1</td><td>74 ms</td><td>310 ms</td><td class="text-end">3,902</td></tr>
        <tr><td>sa-east-1</td><td>110 ms</td><td>420 ms</td><td class="text-end">1,288</td></tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Striped columns</h2>
    <p>Use <code>.table-striped-columns</code> when the table reads column-first.</p>
    {% call ui.demo() %}
    <table class="table table-striped-columns">
      <thead>
        <tr>
          <th scope="col">Quarter</th>
          <th scope="col">Q1</th>
          <th scope="col">Q2</th>
          <th scope="col">Q3</th>
          <th scope="col">Q4</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th scope="row">New accounts</th>
          <td>418</td><td>502</td><td>611</td><td>730</td>
        </tr>
        <tr>
          <th scope="row">Churned</th>
          <td>62</td><td>71</td><td>54</td><td>48</td>
        </tr>
        <tr>
          <th scope="row">Net new ARR</th>
          <td>$182k</td><td>$214k</td><td>$273k</td><td>$331k</td>
        </tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Hoverable rows</h2>
    <p>Add <code>.table-hover</code> to highlight the row under the cursor. Combine with <code>.table-striped</code> as needed.</p>
    {% call ui.demo() %}
    <table class="table table-hover">
      <thead>
        <tr>
          <th scope="col">Endpoint</th>
          <th scope="col">Method</th>
          <th scope="col">Calls (24h)</th>
          <th scope="col" class="text-end">Error rate</th>
        </tr>
      </thead>
      <tbody>
        <tr><td><code>/v1/charges</code></td><td>POST</td><td>48,210</td><td class="text-end">0.12%</td></tr>
        <tr><td><code>/v1/customers</code></td><td>GET</td><td>31,089</td><td class="text-end">0.04%</td></tr>
        <tr><td><code>/v1/invoices</code></td><td>POST</td><td>9,402</td><td class="text-end">0.31%</td></tr>
        <tr><td><code>/v1/webhooks</code></td><td>POST</td><td>2,118</td><td class="text-end">1.84%</td></tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Active row</h2>
    <p>Highlight a single row or cell with <code>.table-active</code>. Stronger than the hover tint so it persists.</p>
    {% call ui.demo() %}
    <table class="table">
      <thead>
        <tr>
          <th scope="col">Branch</th>
          <th scope="col">Last commit</th>
          <th scope="col">Author</th>
          <th scope="col" class="text-end">Behind / Ahead</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>main</td><td>Bump axios to 1.7.4</td><td>Mateo Reyes</td><td class="text-end">0 / 0</td></tr>
        <tr class="table-active"><td>feat/billing-v2</td><td>Add proration preview</td><td>Maya Singh</td><td class="text-end">0 / 14</td></tr>
        <tr><td>fix/race-on-replay</td><td>Drain queue before close</td><td>Theo Wright</td><td class="text-end">3 / 2</td></tr>
        <tr><td>chore/upgrade-node-20</td><td>Pin engines field</td><td>Sara Lin</td><td class="text-end">6 / 1</td></tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Bordered</h2>
    <p><code>.table-bordered</code> draws a border on every side of every cell.</p>
    {% call ui.demo() %}
    <table class="table table-bordered">
      <thead>
        <tr>
          <th scope="col">Cluster</th>
          <th scope="col">Nodes</th>
          <th scope="col">CPU</th>
          <th scope="col">Memory</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>prod-edge</td><td>24</td><td>62%</td><td>71%</td></tr>
        <tr><td>prod-core</td><td>48</td><td>54%</td><td>68%</td></tr>
        <tr><td>staging</td><td>6</td><td>18%</td><td>22%</td></tr>
      </tbody>
    </table>
    {% endcall %}

    <p>Pair with <code>.border-{state}</code> for a tinted border.</p>
    {% call ui.demo() %}
    <table class="table table-bordered border-primary">
      <thead>
        <tr>
          <th scope="col">Cluster</th>
          <th scope="col">Nodes</th>
          <th scope="col">CPU</th>
          <th scope="col">Memory</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>prod-edge</td><td>24</td><td>62%</td><td>71%</td></tr>
        <tr><td>prod-core</td><td>48</td><td>54%</td><td>68%</td></tr>
        <tr><td>staging</td><td>6</td><td>18%</td><td>22%</td></tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Borderless</h2>
    <p><code>.table-borderless</code> strips every row and cell border for a soft list look.</p>
    {% call ui.demo() %}
    <table class="table table-borderless">
      <thead>
        <tr>
          <th scope="col">Project</th>
          <th scope="col">Owner</th>
          <th scope="col" class="text-end">Open issues</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>billing-service</td><td>Maya Singh</td><td class="text-end">12</td></tr>
        <tr><td>auth-gateway</td><td>Mateo Reyes</td><td class="text-end">4</td></tr>
        <tr><td>events-pipeline</td><td>Sara Lin</td><td class="text-end">7</td></tr>
        <tr><td>web-dashboard</td><td>Theo Wright</td><td class="text-end">23</td></tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Small</h2>
    <p><code>.table-sm</code> halves the cell padding for denser rows. Edge padding is unchanged so the flush-in-card alignment holds.</p>
    {% call ui.demo() %}
    <table class="table table-sm">
      <thead>
        <tr>
          <th scope="col">Key</th>
          <th scope="col">Value</th>
          <th scope="col">Last edited</th>
        </tr>
      </thead>
      <tbody>
        <tr><td><code>SMTP_HOST</code></td><td>smtp.postmark.io</td><td>Maya · 3 days ago</td></tr>
        <tr><td><code>SMTP_PORT</code></td><td>587</td><td>Maya · 3 days ago</td></tr>
        <tr><td><code>S3_BUCKET</code></td><td>stisla-assets-prod</td><td>Theo · last week</td></tr>
        <tr><td><code>FEATURE_BILLING_V2</code></td><td>true</td><td>Mateo · 1 hour ago</td></tr>
        <tr><td><code>RATE_LIMIT_RPM</code></td><td>600</td><td>Sara · yesterday</td></tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Vertical alignment</h2>
    <p>Cell content sits at the top by default. Use <code>.align-middle</code> on the table, row, or cell when rows mix multi-line text with shorter values.</p>
    {% call ui.demo() %}
    <table class="table align-middle">
      <thead>
        <tr>
          <th scope="col">Document</th>
          <th scope="col">Summary</th>
          <th scope="col" class="text-end">Pages</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Onboarding handbook</td>
          <td>Day-1 setup, IT accounts, payroll forms, and the company-wide reading list new hires work through in their first week.</td>
          <td class="text-end">42</td>
        </tr>
        <tr>
          <td>Security policy</td>
          <td>Device requirements, password rules, incident reporting, and the quarterly review schedule.</td>
          <td class="text-end">18</td>
        </tr>
        <tr>
          <td>Engineering RFCs</td>
          <td>Active proposals up for review this cycle. Each row links to the long-form doc.</td>
          <td class="text-end">7</td>
        </tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Caption</h2>
    <p>A <code>&lt;caption&gt;</code> sits below the table and reads like a footnote. Promote it above the table with <code>.caption-top</code>.</p>
    {% call ui.demo() %}
    <table class="table">
      <caption>Last refreshed at 09:42 UTC</caption>
      <thead>
        <tr>
          <th scope="col">Job</th>
          <th scope="col">Schedule</th>
          <th scope="col">Last run</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>weekly-invoice-rollup</td><td>Mon 02:00 UTC</td><td>2 days ago · succeeded</td></tr>
        <tr><td>nightly-vacuum</td><td>Daily 03:30 UTC</td><td>6 hours ago · succeeded</td></tr>
        <tr><td>hourly-replay</td><td>Hourly :15</td><td>27 min ago · failed</td></tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>Header alt</h2>
    <p>Apply <code>.table-header-alt</code> on the <code>&lt;thead&gt;</code> to opt the header row onto <code>--bs-surface-alt</code>. Same two-tone language as <code>.card-header-alt</code>.</p>
    {% call ui.demo() %}
    <table class="table">
      <thead class="table-header-alt">
        <tr>
          <th scope="col">Customer</th>
          <th scope="col">Plan</th>
          <th scope="col">MRR</th>
          <th scope="col" class="text-end">Renews</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Acme Corp</td><td>Business</td><td>$1,490</td><td class="text-end">Aug 12</td></tr>
        <tr><td>Riverway Ltd</td><td>Team</td><td>$580</td><td class="text-end">Sep 04</td></tr>
        <tr><td>Northwind</td><td>Enterprise</td><td>$8,200</td><td class="text-end">Oct 22</td></tr>
        <tr><td>Globex</td><td>Team</td><td>$580</td><td class="text-end">Nov 09</td></tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>With status badges</h2>
    <p>Drop a <code>.badge</code> into a cell to flag state. Soft <code>.badge-light-{state}</code> variants read cleaner inside a dense row than solid fills.</p>
    {% call ui.demo() %}
    <table class="table table-hover align-middle">
      <thead class="table-header-alt">
        <tr>
          <th scope="col">Invoice</th>
          <th scope="col">Client</th>
          <th scope="col">Amount</th>
          <th scope="col">Due</th>
          <th scope="col">Status</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>INV-1042</code></td>
          <td>Acme Corp</td>
          <td>$4,800.00</td>
          <td>Jun 15</td>
          <td><span class="badge badge-light-info"><i data-lucide="send"></i> Sent</span></td>
        </tr>
        <tr>
          <td><code>INV-1041</code></td>
          <td>Riverway Ltd</td>
          <td>$1,250.00</td>
          <td>Jun 10</td>
          <td><span class="badge badge-light-success"><i data-lucide="check"></i> Paid</span></td>
        </tr>
        <tr>
          <td><code>INV-1040</code></td>
          <td>Northwind</td>
          <td>$9,310.00</td>
          <td>May 28</td>
          <td><span class="badge badge-light-danger"><i data-lucide="alert-triangle"></i> Overdue</span></td>
        </tr>
        <tr>
          <td><code>INV-1039</code></td>
          <td>Globex</td>
          <td>$2,140.00</td>
          <td>Jun 22</td>
          <td><span class="badge badge-light-warning"><i data-lucide="clock"></i> Draft</span></td>
        </tr>
        <tr>
          <td><code>INV-1038</code></td>
          <td>Initech</td>
          <td>$680.00</td>
          <td>Jun 30</td>
          <td><span class="badge badge-light-secondary">Scheduled</span></td>
        </tr>
      </tbody>
    </table>
    {% endcall %}
  </section>

  <section>
    <h2>With user avatars</h2>
    <p>Stack an <code>&lt;img&gt;</code> and a <code>div</code> in a flex cell to pair an avatar with a name and a secondary line. The image keeps its natural shape, so reach for <code>.rounded-circle</code> and a width attribute.</p>
    {% call ui.demo() %}
    <table class="table align-middle">
      <thead class="table-header-alt">
        <tr>
          <th scope="col">Member</th>
          <th scope="col">Role</th>
          <th scope="col">Joined</th>
          <th scope="col">Status</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>
            <div class="d-flex align-items-center gap-2">
              <img src="{{ img_maya }}" alt="" class="rounded-circle" width="32" height="32" />
              <div>
                <div>Maya Singh</div>
                <div class="text-body-secondary">maya@acme.co</div>
              </div>
            </div>
          </td>
          <td>Admin</td>
          <td>Jan 2024</td>
          <td><span class="badge badge-light-success">Active</span></td>
        </tr>
        <tr>
          <td>
            <div class="d-flex align-items-center gap-2">
              <img src="{{ img_mateo }}" alt="" class="rounded-circle" width="32" height="32" />
              <div>
                <div>Mateo Reyes</div>
                <div class="text-body-secondary">mateo@acme.co</div>
              </div>
            </div>
          </td>
          <td>Editor</td>
          <td>Mar 2024</td>
          <td><span class="badge badge-light-success">Active</span></td>
        </tr>
        <tr>
          <td>
            <div class="d-flex align-items-center gap-2">
              <img src="{{ img_sara }}" alt="" class="rounded-circle" width="32" height="32" />
              <div>
                <div>Sara Lin</div>
                <div class="text-body-secondary">sara@acme.co</div>
              </div>
            </div>
          </td>
          <td>Viewer</td>
          <td>May 2024</td>
          <td><span class="badge badge-light-warning">Invite pending</span></td>
        </tr>
        <tr>
          <td>
            <div class="d-flex align-items-center gap-2">
              <img src="{{ img_theo }}" alt="" class="rounded-circle" width="32" height="32" />
              <div>
