  <section>
    <h2>With row actions</h2>
    <p>Trailing buttons go in the last cell with <code>.text-end</code>. Use <code>.btn-icon</code> for icon-only chrome and a ghost variant so the buttons sit quiet until the row is hovered.</p>
    {% call ui.demo() %}
    <table class="table table-hover align-middle">
      <thead class="table-header-alt">
        <tr>
          <th scope="col">API key</th>
          <th scope="col">Scope</th>
