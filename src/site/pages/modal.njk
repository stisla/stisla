{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Modal · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Modal</h1>
    <p class="lead">An overlay dialog that holds focus until the user resolves a task.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>A trigger opens the modal via <code>data-stisla-modal-trigger="&lt;id&gt;"</code>. The dialog carries an optional <code>.modal__header</code> with the title, a <code>.modal__body</code> for content, and an optional <code>.modal__footer</code> for actions. <code>.modal__close</code> is a floating frosted chip that sits inside <code>.modal__content</code> so it works whether or not a header is present.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn--primary" data-stisla-modal-trigger="modalBasic">
      Invite a teammate
    </button>

    <div class="modal" id="modalBasic" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-labelledby="modalBasicLabel" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close">
            <i data-lucide="x"></i>
          </button>
          <div class="modal__header">
            <h3 class="modal__title" id="modalBasicLabel">Invite a teammate</h3>
          </div>
          <div class="modal__body">
            <p>Send a link by email. The invite expires in seven days.</p>
            <label for="modalBasicEmail" class="form-label">Email</label>
            <input type="email" class="form-control" id="modalBasicEmail" placeholder="name@example.com" autocomplete="email">
          </div>
          <div class="modal__footer">
            <button type="button" class="btn btn--ghost btn--neutral" data-stisla-modal-dismiss>Cancel</button>
            <button type="button" class="btn btn--primary" data-stisla-modal-dismiss>Send invite</button>
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Add <code>.modal--sm</code>, <code>.modal--lg</code>, or <code>.modal--xl</code> on the <code>.modal</code> root to swap widths. The default sits in the middle of the scale. <code>.modal--almost-fullscreen</code> keeps a 2.5rem breathing strip around the dialog so the page still hints through; <code>.modal--fullscreen</code> edge-bleeds the dialog to the viewport.</p>
    {% call ui.demo() %}
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-modal-trigger="modalSm">Small</button>
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-modal-trigger="modalDefault">Default</button>
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-modal-trigger="modalLg">Large</button>
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-modal-trigger="modalXl">Extra large</button>
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-modal-trigger="modalAlmostFs">Almost fullscreen</button>
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-modal-trigger="modalFs">Fullscreen</button>
    </div>

    <div class="modal modal--sm" id="modalSm" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__header"><h3 class="modal__title">Small</h3></div>
          <div class="modal__body">
            <p style="margin: 0;">A compact card for confirmations and lightweight pickers.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="modal" id="modalDefault" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__header"><h3 class="modal__title">Default</h3></div>
          <div class="modal__body">
            <p style="margin: 0;">The canonical width for an invite form, an edit dialog, or a focused capture.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="modal modal--lg" id="modalLg" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__header"><h3 class="modal__title">Large</h3></div>
          <div class="modal__body">
            <p style="margin: 0;">Room for a settings panel, a property inspector, or a small dashboard.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="modal modal--xl" id="modalXl" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__header"><h3 class="modal__title">Extra large</h3></div>
          <div class="modal__body">
            <p style="margin: 0;">A canvas for media, rich detail views, or a side-by-side comparison.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="modal modal--almost-fullscreen" id="modalAlmostFs" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__header"><h3 class="modal__title">Almost fullscreen</h3></div>
          <div class="modal__body">
            <p style="margin: 0;">A breathing strip around the dialog so the page still hints through. Useful when you want immersion without losing the surrounding context entirely.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="modal modal--fullscreen" id="modalFs" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__header"><h3 class="modal__title">Fullscreen</h3></div>
          <div class="modal__body">
            <p style="margin: 0;">Edge to edge for an immersive flow. Useful for onboarding or a focused editor.</p>
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Positioning</h2>
    <p>The dialog centers vertically by default. Add <code>.modal__dialog--top</code> to drop in from above, or <code>.modal__dialog--bottom</code> to anchor it to the lower edge.</p>
    {% call ui.demo() %}
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-modal-trigger="modalTop">Top</button>
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-modal-trigger="modalCenter">Center</button>
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-modal-trigger="modalBottom">Bottom</button>
    </div>

    <div class="modal" id="modalTop" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog modal__dialog--top">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__header"><h3 class="modal__title">Pinned to top</h3></div>
          <div class="modal__body">
            <p style="margin: 0;">Reads as a notification surface dropping in from above.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="modal" id="modalCenter" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__header"><h3 class="modal__title">Centered</h3></div>
          <div class="modal__body">
            <p style="margin: 0;">The standard choice for confirmations and focused tasks.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="modal" id="modalBottom" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog modal__dialog--bottom">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__header"><h3 class="modal__title">Pinned to bottom</h3></div>
          <div class="modal__body">
            <p style="margin: 0;">Reads as a sheet on mobile, an action drawer on desktop.</p>
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Scrollable</h2>
    <p>Add <code>.modal__dialog--scrollable</code> to cap the dialog at the viewport. The body scrolls while the header and footer stay pinned.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn--primary" data-stisla-modal-trigger="modalScroll">
      Read terms
    </button>

    <div class="modal" id="modalScroll" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-labelledby="modalScrollLabel" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog modal__dialog--scrollable">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__header">
            <h3 class="modal__title" id="modalScrollLabel">Terms of service</h3>
          </div>
          <div class="modal__body">
            <p>Welcome. By using this service you agree to the terms below. Please read carefully before continuing.</p>
            <p>You may use the service for any lawful purpose. You may not use it to do harm, to interfere with other users, or to break the law where you live or where our servers run.</p>
            <p>We collect the minimum data needed to deliver the product. We don't sell it, we don't share it with advertisers, and we delete it when you ask.</p>
            <p>You own the content you put in. We get a limited license to store, process, and display it back to you and to anyone you've shared it with.</p>
            <p>The service is provided as-is. We work hard to keep it up, but we can't promise zero downtime. If something breaks and costs you money, our liability is capped at what you've paid us in the last twelve months.</p>
            <p>We may update these terms. If we do, we'll tell you in-app and give you a chance to read the new version before it takes effect.</p>
            <p>Questions go to <a href="#" class="link">support@example.com</a>. We try to respond within one business day.</p>
            <p>Last updated 12 May 2026.</p>
            <p style="margin: 0;">Thanks for being here.</p>
          </div>
          <div class="modal__footer">
            <button type="button" class="btn btn--ghost btn--neutral" data-stisla-modal-dismiss>Decline</button>
            <button type="button" class="btn btn--primary" data-stisla-modal-dismiss>Accept</button>
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Static backdrop</h2>
    <p>Set <code>data-stisla-modal-backdrop="static"</code> and <code>data-stisla-modal-keyboard="false"</code> to force a deliberate dismiss. Clicking the backdrop wobbles the dialog; <kbd>Esc</kbd> stays inert. Explicit dismiss controls still close.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn--primary" data-stisla-modal-trigger="modalStatic">
      Set a password
    </button>

    <div class="modal" id="modalStatic" data-stisla-modal data-stisla-modal-backdrop="static" data-stisla-modal-keyboard="false" data-state="closed" role="dialog" aria-modal="true" aria-labelledby="modalStaticLabel" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <div class="modal__header">
            <h3 class="modal__title" id="modalStaticLabel">Choose a password</h3>
          </div>
          <div class="modal__body">
            <label for="staticPwd" class="form-label">New password</label>
            <input type="password" class="form-control" id="staticPwd" autocomplete="new-password">
            <p class="form-text" style="margin-top: 0.25rem;">At least twelve characters. Mix letters, numbers, and a symbol.</p>
          </div>
          <div class="modal__footer">
            <button type="button" class="btn btn--ghost btn--neutral" data-stisla-modal-dismiss>Cancel</button>
            <button type="button" class="btn btn--primary" data-stisla-modal-dismiss>Save password</button>
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Media hero</h2>
    <p>Drop the header when the leading row is media. The floating close still sits at the top right and reads cleanly against the image.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn--primary" data-stisla-modal-trigger="modalHero">
      Open
    </button>

    <div class="modal" id="modalHero" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-labelledby="modalHeroLabel" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close">
            <i data-lucide="x"></i>
          </button>
          <img src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=1200&q=80" alt="" style="display: block; width: 100%; height: auto;">
          <div class="modal__body">
            <h4 id="modalHeroLabel" style="margin: 0 0 0.25rem; font-size: 1.0625rem; font-weight: 600;">Autumn release</h4>
            <p class="text-muted-foreground" style="margin: 0;">A round-up of what's new this season, with notes on what's still in flight.</p>
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Lightbox</h2>
    <p>Override the surface vars on a single dialog to turn it into a frame for media. The blurred backdrop and the floating <code>.modal__close</code> carry the affordance.</p>
    {% call ui.demo() %}
    <a href="#" data-stisla-modal-trigger="modalLightbox" style="display: inline-block; cursor: zoom-in;">
      <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600&q=80" alt="" width="240" height="160" style="border-radius: var(--st-radius); object-fit: cover;">
    </a>

    <div class="modal modal--xl" id="modalLightbox" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1" style="--modal-bg: transparent; --modal-border-color: transparent; --modal-shadow: none;">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close">
            <i data-lucide="x"></i>
          </button>
          <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=2000&q=85" alt="" style="display: block; width: 100%; height: auto; max-height: calc(100dvh - 5rem); object-fit: contain; border-radius: var(--st-radius);">
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Confirmation</h2>
    <p>An alert-dialog pattern for destructive actions. A tinted icon sets the tone, the heading names the action, the description explains the consequence.</p>
    {% call ui.demo() %}
    <button type="button" class="btn btn--outline btn--danger" data-stisla-modal-trigger="modalConfirm">
      Delete workspace
    </button>

    <div class="modal modal--sm" id="modalConfirm" data-stisla-modal data-state="closed" role="alertdialog" aria-modal="true" aria-labelledby="modalConfirmLabel" aria-describedby="modalConfirmDesc" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close"><i data-lucide="x"></i></button>
          <div class="modal__body" style="text-align: center; padding-top: 1.5rem;">
            <span class="icon-box icon-box--danger icon-box--round" style="--icon-box-size: 3rem; --icon-box-icon-size: 1.25rem; margin-bottom: 0.75rem;">
              <i data-lucide="trash-2"></i>
            </span>
            <h3 class="modal__title" id="modalConfirmLabel" style="margin: 0 0 0.25rem;">Delete this workspace?</h3>
            <p class="text-muted-foreground" id="modalConfirmDesc" style="margin: 0;">This removes every project, file, and member. The action can't be undone.</p>
          </div>
          <div class="modal__footer" style="justify-content: center;">
            <button type="button" class="btn btn--ghost btn--neutral" data-stisla-modal-dismiss>Cancel</button>
            <button type="button" class="btn btn--danger" data-stisla-modal-dismiss>Delete</button>
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Success</h2>
    <p>A celebratory state for the end of a flow. The icon sits on top, the heading and description fill the middle, and a single block button takes the user to the next step.</p>
    {% call ui.demo() %}
    <button type="button" class="btn" data-stisla-modal-trigger="modalSuccess" style="--btn-tone: var(--st-success); --btn-color: var(--st-success-foreground);">
      Submit order
    </button>

    <div class="modal modal--sm" id="modalSuccess" data-stisla-modal data-state="closed" role="dialog" aria-modal="true" aria-labelledby="modalSuccessLabel" aria-hidden="true" tabindex="-1">
      <div class="modal__backdrop" data-stisla-modal-dismiss></div>
      <div class="modal__dialog">
        <div class="modal__content">
          <button type="button" class="modal__close" data-stisla-modal-dismiss aria-label="Close">
            <i data-lucide="x"></i>
          </button>
          <div class="modal__body" style="text-align: center; padding-top: 1.5rem;">
            <span class="icon-box icon-box--success icon-box--round" style="--icon-box-size: 3.5rem; --icon-box-icon-size: 1.5rem; margin-bottom: 0.75rem;">
              <i data-lucide="check"></i>
            </span>
            <h3 class="modal__title" id="modalSuccessLabel" style="margin: 0 0 0.25rem;">Order placed</h3>
            <p class="text-muted-foreground" style="margin: 0;">We've emailed the receipt and a tracking link. Delivery lands in two to three business days.</p>
          </div>
          <div class="modal__footer">
            <button type="button" class="btn" data-stisla-modal-dismiss style="--btn-tone: var(--st-success); --btn-color: var(--st-success-foreground); width: 100%;">View order</button>
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Customization</h2>
    <p>Twenty-two variables retune <code>.modal</code> without touching component CSS. Override on the <code>.modal</code> element, on a parent scope, or on <code>:root</code>. Size modifiers <code>--sm</code> / <code>--lg</code> / <code>--xl</code> retune <code>--modal-width</code> in their own scope. The dark-mode block flips the close chip from a solid dark overlay to a subtle light translucent overlay so it reads against the deep dark surface.</p>
    <div class="prose">
      <h3>Geometry</h3>
      <table>
        <thead>
          <tr><th>Variable</th><th>Default</th><th>Use</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--modal-width</code></td>
            <td>28rem</td>
            <td>Max dialog width. Retuned by <code>.modal--sm</code> / <code>--lg</code> / <code>--xl</code> in modifier scope.</td>
          </tr>
          <tr>
            <td><code>--modal-margin</code></td>
            <td>1rem</td>
            <td>Breathing space between dialog and viewport edge.</td>
          </tr>
          <tr>
            <td><code>--modal-padding</code></td>
            <td>calc(1.25rem * var(--st-density))</td>
            <td>Header, body, and footer inset.</td>
          </tr>
          <tr>
            <td><code>--modal-radius</code></td>
            <td>var(--st-radius-lg)</td>
            <td>Content corner radius. Large-surface tier, matches card and accordion.</td>
          </tr>
          <tr>
            <td><code>--modal-z-index</code></td>
            <td>1055</td>
            <td>Stack level. Sits above sidebar and navbar.</td>
          </tr>
        </tbody>
      </table>

      <h3>Surface</h3>
      <table>
        <thead>
          <tr><th>Variable</th><th>Default</th><th>Use</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--modal-bg</code></td>
            <td>var(--st-surface)</td>
            <td>Content card background.</td>
          </tr>
          <tr>
            <td><code>--modal-color</code></td>
            <td>var(--st-foreground)</td>
            <td>Body and title text.</td>
          </tr>
          <tr>
            <td><code>--modal-border-color</code></td>
            <td>var(--st-border)</td>
            <td>Subtle content rim.</td>
          </tr>
          <tr>
            <td><code>--modal-shadow</code></td>
            <td>0 10px 40px -10px color-mix(in oklch, black 35%, transparent)</td>
            <td>Lift off the page. Set to <code>none</code> for a flat dialog.</td>
          </tr>
        </tbody>
      </table>

      <h3>Backdrop</h3>
      <table>
        <thead>
          <tr><th>Variable</th><th>Default</th><th>Use</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--modal-backdrop-bg</code></td>
            <td>oklch(0 0 0 / 0.55)</td>
            <td>Translucent dim layer. Solid dark in both themes so the modal reads as the foreground.</td>
          </tr>
          <tr>
            <td><code>--modal-backdrop-blur</code></td>
            <td>12px</td>
            <td>Backdrop blur radius. Set to 0 for a flat dim.</td>
          </tr>
        </tbody>
      </table>

      <h3>Title</h3>
      <table>
        <thead>
          <tr><th>Variable</th><th>Default</th><th>Use</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--modal-title-font-size</code></td>
            <td>1.125rem</td>
            <td>Title text size. Independent of the heading tag wrapping it.</td>
          </tr>
          <tr>
            <td><code>--modal-title-font-weight</code></td>
            <td>600</td>
            <td>Title weight.</td>
          </tr>
        </tbody>
      </table>

      <h3>Close chip</h3>
      <table>
        <thead>
          <tr><th>Variable</th><th>Default</th><th>Use</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--modal-close-size</code></td>
            <td>1.75rem</td>
            <td>Width and height of the dismiss chip.</td>
          </tr>
          <tr>
            <td><code>--modal-close-bg</code></td>
            <td>oklch(0 0 0 / 0.55) light, oklch(1 0 0 / 0.1) dark</td>
            <td>Frosted chip background. Solid dark over light surface; subtle light translucent over dark surface.</td>
          </tr>
          <tr>
            <td><code>--modal-close-bg-hover</code></td>
            <td>oklch(0 0 0 / 0.7) light, oklch(1 0 0 / 0.18) dark</td>
            <td>Hover fill. Same inversion logic as the rest state.</td>
          </tr>
          <tr>
            <td><code>--modal-close-color</code></td>
            <td>oklch(1 0 0 / 0.92) light, oklch(1 0 0 / 0.85) dark</td>
            <td>Icon glyph color. Stays white in both themes so the chip reads over any surface.</td>
          </tr>
          <tr>
            <td><code>--modal-close-color-hover</code></td>
            <td>oklch(1 0 0)</td>
            <td>Icon glyph color on hover. Pure white in both themes.</td>
          </tr>
        </tbody>
      </table>

      <h3>Footer</h3>
      <table>
        <thead>
          <tr><th>Variable</th><th>Default</th><th>Use</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--modal-footer-padding-y</code></td>
            <td>calc(0.875rem * var(--st-density))</td>
            <td>Vertical padding inside the footer. Slightly tighter than the body padding so the seam reads as an action row.</td>
          </tr>
          <tr>
            <td><code>--modal-footer-bg</code></td>
            <td>var(--st-surface-2)</td>
            <td>Footer background. The alt-surface tier sets the action row apart from the body without a bold paint. Set to <code>transparent</code> for a flat footer.</td>
          </tr>
          <tr>
            <td><code>--modal-footer-border-color</code></td>
            <td>var(--st-border)</td>
            <td>Top divider line. Set to <code>transparent</code> to drop the seam entirely.</td>
          </tr>
        </tbody>
      </table>

      <h3>Motion</h3>
      <table>
        <thead>
          <tr><th>Variable</th><th>Default</th><th>Use</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--modal-transition-duration</code></td>
            <td>0.2s</td>
            <td>Open and close fade plus dialog slide. Zeroed under <code>prefers-reduced-motion</code>.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
{% endblock %}
