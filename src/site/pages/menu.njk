{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Menu · Stisla{% endblock %}

{% block content %}
  <header>
    <h1>Menu</h1>
    <p class="lead">A floating menu of links or actions surfaced from a trigger.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>A trigger opens the menu via <code>data-stisla-menu-trigger="&lt;id&gt;"</code>. The menu carries the matching <code>id</code> plus <code>data-stisla-menu</code>. The root <code>.menu</code> only provides positioning context. Floating UI computes the actual placement and keeps the menu anchored on scroll or resize.</p>
    {% call ui.demo() %}
    <div class="menu">
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddBasic" aria-haspopup="menu" aria-expanded="false" aria-controls="ddBasic">
        Actions
      </button>
      <div class="menu__popup" id="ddBasic" data-stisla-menu role="menu" data-state="closed">
        <button type="button" class="menu__item" role="menuitem">Profile</button>
        <button type="button" class="menu__item" role="menuitem">Settings</button>
        <button type="button" class="menu__item" role="menuitem">Sign out</button>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Keyboard</h2>
    <p>The trigger behaves like a menu button. Open it with <kbd>Enter</kbd>, <kbd>Space</kbd>, or <kbd>ArrowDown</kbd>; the first enabled item takes focus.</p>
    <ul>
      <li><kbd>ArrowDown</kbd> / <kbd>ArrowUp</kbd>: move focus through enabled items (wraps at the ends)</li>
      <li><kbd>Home</kbd> / <kbd>End</kbd>: focus the first / last enabled item</li>
      <li><kbd>Enter</kbd> / <kbd>Space</kbd>: activate the focused item</li>
      <li><kbd>Escape</kbd>: close the menu and return focus to the trigger</li>
      <li><kbd>Tab</kbd>: close the menu and move focus to the next element on the page</li>
    </ul>
  </section>

  <section>
    <h2>With icons</h2>
    <p>Drop an <code>&lt;svg&gt;</code> or <code>&lt;i data-lucide&gt;</code> as the first child of an item. The icon pins to 1rem and inherits the row color on hover so it tracks the surface naturally.</p>
    {% call ui.demo() %}
    <div class="menu">
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddIcons" aria-haspopup="menu" aria-expanded="false" aria-controls="ddIcons">
        Account
      </button>
      <div class="menu__popup" id="ddIcons" data-stisla-menu role="menu" data-state="closed">
        <a href="#" class="menu__item" role="menuitem">
          <i data-lucide="user"></i>
          <span>Profile</span>
        </a>
        <a href="#" class="menu__item" role="menuitem">
          <i data-lucide="settings"></i>
          <span>Settings</span>
        </a>
        <a href="#" class="menu__item" role="menuitem">
          <i data-lucide="bell"></i>
          <span>Notifications</span>
        </a>
        <hr class="menu__separator" role="separator">
        <a href="#" class="menu__item" role="menuitem">
          <i data-lucide="log-out"></i>
          <span>Sign out</span>
        </a>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Headers and dividers</h2>
    <p>Use <code>.menu__group-label</code> to label a section and <code>.menu__separator</code> to separate groups. Wrap rows in a <code>role="group"</code> with <code>aria-labelledby</code> pointing at the header so screen readers announce the grouping.</p>
    {% call ui.demo() %}
    <div class="menu">
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddGroups" aria-haspopup="menu" aria-expanded="false" aria-controls="ddGroups">
        Workspace
      </button>
      <div class="menu__popup" id="ddGroups" data-stisla-menu role="menu" data-state="closed">
        <div class="menu__group" role="group" aria-labelledby="ddGroupsAccount">
          <h3 class="menu__group-label" id="ddGroupsAccount">Account</h3>
          <a href="#" class="menu__item" role="menuitem">Profile</a>
          <a href="#" class="menu__item" role="menuitem">Billing</a>
        </div>
        <hr class="menu__separator" role="separator">
        <div class="menu__group" role="group" aria-labelledby="ddGroupsWorkspace">
          <h3 class="menu__group-label" id="ddGroupsWorkspace">Workspace</h3>
          <a href="#" class="menu__item" role="menuitem">Members</a>
          <a href="#" class="menu__item" role="menuitem">Settings</a>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Active and disabled</h2>
    <p>Mark the user's currently-applied choice with <code>aria-current="true"</code> or <code>data-state="active"</code>. Both paint <code>--st-highlight</code> as the persistent selected fill. Disabled rows take <code>aria-disabled="true"</code> on anchors or the native <code>disabled</code> attribute on buttons.</p>
    {% call ui.demo() %}
    <div class="menu">
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddSort" aria-haspopup="menu" aria-expanded="false" aria-controls="ddSort">
        Sort by
      </button>
      <div class="menu__popup" id="ddSort" data-stisla-menu role="menu" data-state="closed">
        <button type="button" class="menu__item" role="menuitem" aria-current="true">Newest first</button>
        <button type="button" class="menu__item" role="menuitem">Oldest first</button>
        <button type="button" class="menu__item" role="menuitem">Alphabetical</button>
        <button type="button" class="menu__item" role="menuitem" disabled>By owner (Pro)</button>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Destructive items</h2>
    <p>Add <code>.menu__item--danger</code> for actions that delete data or sign the user out. The color flips to <code>--st-danger</code> and hover paints a soft danger tint instead of the standard accent fill so the row never reads like a routine choice.</p>
    {% call ui.demo() %}
    <div class="menu">
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddDanger" aria-haspopup="menu" aria-expanded="false" aria-controls="ddDanger">
        Manage project
      </button>
      <div class="menu__popup" id="ddDanger" data-stisla-menu role="menu" data-state="closed">
        <button type="button" class="menu__item" role="menuitem">
          <i data-lucide="pencil"></i>
          <span>Rename</span>
        </button>
        <button type="button" class="menu__item" role="menuitem">
          <i data-lucide="copy"></i>
          <span>Duplicate</span>
        </button>
        <button type="button" class="menu__item" role="menuitem">
          <i data-lucide="archive"></i>
          <span>Archive</span>
        </button>
        <hr class="menu__separator" role="separator">
        <button type="button" class="menu__item menu__item--danger" role="menuitem">
          <i data-lucide="trash-2"></i>
          <span>Delete project</span>
        </button>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Checkbox items</h2>
    <p>Items with <code>role="menuitemcheckbox"</code> toggle between checked and unchecked on click. The framework flips <code>data-state</code> and <code>aria-checked</code>; the leading <code>.menu__indicator</code> slot paints the check glyph when checked. The menu stays open between toggles via <code>data-stisla-menu-auto-close="outside"</code>.</p>
    {% call ui.demo() %}
    <div class="menu">
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddCheck" aria-haspopup="menu" aria-expanded="false" aria-controls="ddCheck">
        View
      </button>
      <div class="menu__popup" id="ddCheck" data-stisla-menu data-stisla-menu-auto-close="outside" role="menu" data-state="closed">
        <button type="button" class="menu__item" role="menuitemcheckbox" data-state="checked" aria-checked="true">
          <span class="menu__indicator"><i data-lucide="check"></i></span>
          <span>Show grid</span>
        </button>
        <button type="button" class="menu__item" role="menuitemcheckbox" data-state="unchecked" aria-checked="false">
          <span class="menu__indicator"><i data-lucide="check"></i></span>
          <span>Show ruler</span>
        </button>
        <button type="button" class="menu__item" role="menuitemcheckbox" data-state="checked" aria-checked="true">
          <span class="menu__indicator"><i data-lucide="check"></i></span>
          <span>Snap to pixels</span>
        </button>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Radio items</h2>
    <p>Items with <code>role="menuitemradio"</code> inside a <code>role="group"</code> behave like a radio group. Clicking one item checks it and unchecks every sibling in the same group. They use the same indicator slot as checkbox items.</p>
    {% call ui.demo() %}
    <div class="menu">
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddRadio" aria-haspopup="menu" aria-expanded="false" aria-controls="ddRadio">
        Theme
      </button>
      <div class="menu__popup" id="ddRadio" data-stisla-menu data-stisla-menu-auto-close="outside" role="menu" data-state="closed">
        <div role="group" aria-labelledby="ddRadioHeader" class="d-flex flex-column" style="gap: 2px;">
          <h3 class="menu__group-label" id="ddRadioHeader">Appearance</h3>
          <button type="button" class="menu__item" role="menuitemradio" data-state="checked" aria-checked="true">
            <span class="menu__indicator"><i data-lucide="check"></i></span>
            <span>Light</span>
          </button>
          <button type="button" class="menu__item" role="menuitemradio" data-state="unchecked" aria-checked="false">
            <span class="menu__indicator"><i data-lucide="check"></i></span>
            <span>Dark</span>
          </button>
          <button type="button" class="menu__item" role="menuitemradio" data-state="unchecked" aria-checked="false">
            <span class="menu__indicator"><i data-lucide="check"></i></span>
            <span>System</span>
          </button>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Item shortcuts</h2>
    <p>Append a <code>.menu__shortcut</code> chip after the label and auto-margin pushes it to the trailing edge of the row. Pair with <code>&lt;kbd&gt;</code> for the keystroke glyphs. The chip color inherits in hover and active paint so it stays readable on the highlight surface.</p>
    {% call ui.demo() %}
    <div class="menu">
      <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddShortcut" aria-haspopup="menu" aria-expanded="false" aria-controls="ddShortcut">
        File
      </button>
      <div class="menu__popup" id="ddShortcut" data-stisla-menu role="menu" data-state="closed" style="min-width: 14rem;">
        <button type="button" class="menu__item" role="menuitem">
          <span>New file</span>
          <span class="menu__shortcut"><kbd>⌘</kbd><kbd>N</kbd></span>
        </button>
        <button type="button" class="menu__item" role="menuitem">
          <span>Open…</span>
          <span class="menu__shortcut"><kbd>⌘</kbd><kbd>O</kbd></span>
        </button>
        <button type="button" class="menu__item" role="menuitem">
          <span>Save</span>
          <span class="menu__shortcut"><kbd>⌘</kbd><kbd>S</kbd></span>
        </button>
        <hr class="menu__separator" role="separator">
        <button type="button" class="menu__item" role="menuitem">
          <span>Print</span>
          <span class="menu__shortcut"><kbd>⌘</kbd><kbd>P</kbd></span>
        </button>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Form inside</h2>
    <p>Drop a form into the menu and set <code>data-stisla-menu-auto-close="outside"</code> so clicks inside don't dismiss the menu while the user fills out fields. The menu auto-sizes its height to the viewport, so long content scrolls inside.</p>
    {% call ui.demo() %}
    <div class="menu">
      <button type="button" class="btn btn--primary" data-stisla-menu-trigger="ddForm" aria-haspopup="menu" aria-expanded="false" aria-controls="ddForm">
        Sign in
      </button>
      <form class="menu__popup gap-3" id="ddForm" data-stisla-menu data-stisla-menu-auto-close="outside" data-state="closed" style="min-width: 18rem; padding: 0.75rem">
        <div class="field" style="--field-gap: 0.25rem;">
          <label for="ddFormEmail" class="field__label">Email</label>
          <input type="email" class="input" id="ddFormEmail" placeholder="you@example.com">
        </div>
        <div class="field" style="--field-gap: 0.25rem;">
          <label for="ddFormPassword" class="field__label">Password</label>
          <input type="password" class="input" id="ddFormPassword">
        </div>
        <div class="field">
          <label class="field__item" for="ddFormRemember">
            <input type="checkbox" class="checkbox" id="ddFormRemember">
            <span class="field__label">Remember me</span>
          </label>
        </div>
        <button type="submit" class="btn btn--primary btn--block">Sign in</button>
      </form>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Placement</h2>
    <p>Set <code>data-stisla-menu-placement</code> on the menu to override the default <code>bottom-start</code>. Floating UI flips the menu automatically when it would overflow the viewport, so the value is a preference. It isn't a hard constraint.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap align-items-center gap-2">
      <div class="menu">
        <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddTop" aria-haspopup="menu" aria-expanded="false" aria-controls="ddTop">
          Top
        </button>
        <div class="menu__popup" id="ddTop" data-stisla-menu data-stisla-menu-placement="top" role="menu" data-state="closed">
          <button type="button" class="menu__item" role="menuitem">Action</button>
          <button type="button" class="menu__item" role="menuitem">Another action</button>
        </div>
      </div>
      <div class="menu">
        <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddRight" aria-haspopup="menu" aria-expanded="false" aria-controls="ddRight">
          Right
        </button>
        <div class="menu__popup" id="ddRight" data-stisla-menu data-stisla-menu-placement="right-start" role="menu" data-state="closed">
          <button type="button" class="menu__item" role="menuitem">Action</button>
          <button type="button" class="menu__item" role="menuitem">Another action</button>
        </div>
      </div>
      <div class="menu">
        <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddLeft" aria-haspopup="menu" aria-expanded="false" aria-controls="ddLeft">
          Left
        </button>
        <div class="menu__popup" id="ddLeft" data-stisla-menu data-stisla-menu-placement="left-start" role="menu" data-state="closed">
          <button type="button" class="menu__item" role="menuitem">Action</button>
          <button type="button" class="menu__item" role="menuitem">Another action</button>
        </div>
      </div>
      <div class="menu">
        <button type="button" class="btn btn--outline btn--neutral" data-stisla-menu-trigger="ddBottomEnd" aria-haspopup="menu" aria-expanded="false" aria-controls="ddBottomEnd">
          Bottom-end
        </button>
        <div class="menu__popup" id="ddBottomEnd" data-stisla-menu data-stisla-menu-placement="bottom-end" role="menu" data-state="closed">
          <button type="button" class="menu__item" role="menuitem">Action</button>
          <button type="button" class="menu__item" role="menuitem">Another action</button>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Events</h2>
    <p>Four events fire on the <code>.menu</code> root. The <code>opening</code> and <code>closing</code> events are cancelable.</p>
    <p><code>stisla:menu:opening</code> fires before the menu mounts. Call <code>preventDefault()</code> to abort.</p>
    <p><code>stisla:menu:opened</code> fires once the menu is positioned and focus has moved to the first item.</p>
    <p><code>stisla:menu:closing</code> fires before the menu dismisses. Call <code>preventDefault()</code> to keep it open.</p>
    <p><code>stisla:menu:closed</code> fires once the menu is hidden and focus has returned to the trigger.</p>
  </section>

  <section>
    <h2>Customization</h2>
    <p>Every variable that retunes <code>.menu</code> is below. Override on a single menu, on a parent scope, or on <code>:root</code>. The concentric inner radius derives from <code>--menu-radius</code> minus <code>--menu-padding-inline</code> so the rows stay inset when the outer chip rounds.</p>
    <h3>Geometry</h3>
    <table>
      <thead>
        <tr><th>Variable</th><th>Use</th></tr>
      </thead>
      <tbody>
        <tr><td><code>--menu-min-width</code></td><td>Lower bound on menu width. Long labels grow past it.</td></tr>
        <tr><td><code>--menu-padding-block</code></td><td>Top and bottom inner padding around the row stack.</td></tr>
        <tr><td><code>--menu-padding-inline</code></td><td>Left and right inner padding. Drives the concentric inset.</td></tr>
        <tr><td><code>--menu-radius</code></td><td>Outer chip radius. Medium tier, matches btn / input / popover.</td></tr>
        <tr><td><code>--menu-item-radius</code></td><td>Row radius. Derived; rarely overridden directly.</td></tr>
        <tr><td><code>--menu-gap</code></td><td>Vertical gap between rows.</td></tr>
        <tr><td><code>--menu-z-index</code></td><td>Stack level. Below drawer (1045) and dialog (1055).</td></tr>
        <tr><td><code>--menu-font-size</code></td><td>Row text size.</td></tr>
      </tbody>
    </table>

    <h3>Surface</h3>
    <table>
      <thead>
        <tr><th>Variable</th><th>Use</th></tr>
      </thead>
      <tbody>
        <tr><td><code>--menu-bg</code></td><td>Menu background.</td></tr>
        <tr><td><code>--menu-color</code></td><td>Rest text color.</td></tr>
        <tr><td><code>--menu-border-width</code></td><td>Outer rim thickness; set <code>0</code> to drop it.</td></tr>
        <tr><td><code>--menu-border-color</code></td><td>Outer rim.</td></tr>
        <tr><td><code>--menu-shadow</code></td><td>Lift off the page.</td></tr>
      </tbody>
    </table>

    <h3>Item</h3>
    <table>
      <thead>
        <tr><th>Variable</th><th>Use</th></tr>
      </thead>
      <tbody>
        <tr><td><code>--menu-item-padding-block</code></td><td>Top and bottom inset.</td></tr>
        <tr><td><code>--menu-item-padding-inline</code></td><td>Left and right inset.</td></tr>
        <tr><td><code>--menu-item-min-height</code></td><td>Click-target floor.</td></tr>
        <tr><td><code>--menu-item-gap</code></td><td>Space between icon, label, indicator, shortcut.</td></tr>
        <tr><td><code>--menu-item-color</code></td><td>Rest row text color.</td></tr>
        <tr><td><code>--menu-item-icon-size</code></td><td>Leading icon and indicator footprint.</td></tr>
        <tr><td><code>--menu-item-icon-color</code></td><td>Leading icon color. Defaults to the row text; pin it to a fixed color here.</td></tr>
      </tbody>
    </table>

    <h3>Item states</h3>
    <table>
      <thead>
        <tr><th>Variable</th><th>Use</th></tr>
      </thead>
      <tbody>
        <tr><td><code>--menu-item-bg-hover</code></td><td>Hover and <code>[data-highlighted]</code> fill.</td></tr>
        <tr><td><code>--menu-item-color-hover</code></td><td>Hover text.</td></tr>
        <tr><td><code>--menu-item-bg-active</code></td><td><code>aria-current</code> / <code>data-state="active"</code> fill.</td></tr>
        <tr><td><code>--menu-item-color-active</code></td><td>Active text.</td></tr>
        <tr><td><code>--menu-item-color-disabled</code></td><td>Disabled row color.</td></tr>
        <tr><td><code>--menu-item-color-danger</code></td><td>Destructive row color.</td></tr>
        <tr><td><code>--menu-item-bg-danger-hover</code></td><td>Destructive hover fill. Soft tint instead of the standard accent.</td></tr>
      </tbody>
    </table>

    <h3>Group label</h3>
    <table>
      <thead>
        <tr><th>Variable</th><th>Use</th></tr>
      </thead>
      <tbody>
        <tr><td><code>--menu-group-label-padding-block</code></td><td>Section label top and bottom inset.</td></tr>
        <tr><td><code>--menu-group-label-padding-inline</code></td><td>Section label left and right inset.</td></tr>
        <tr><td><code>--menu-group-label-font-size</code></td><td>Section label text size.</td></tr>
        <tr><td><code>--menu-group-label-font-weight</code></td><td>Section label weight.</td></tr>
        <tr><td><code>--menu-group-label-color</code></td><td>Section label color.</td></tr>
      </tbody>
    </table>

    <h3>Separator</h3>
    <table>
      <thead>
        <tr><th>Variable</th><th>Use</th></tr>
      </thead>
      <tbody>
        <tr><td><code>--menu-separator-color</code></td><td>Separator line.</td></tr>
        <tr><td><code>--menu-separator-margin-block</code></td><td>Breathing space above and below.</td></tr>
      </tbody>
    </table>

    <h3>Shortcut + motion</h3>
    <table>
      <thead>
        <tr><th>Variable</th><th>Use</th></tr>
      </thead>
      <tbody>
        <tr><td><code>--menu-shortcut-color</code></td><td>Trailing keystroke chip color.</td></tr>
        <tr><td><code>--menu-shortcut-font-size</code></td><td>Shortcut chip text size.</td></tr>
        <tr><td><code>--menu-transition-duration</code></td><td>Open and close fade. Zeroed under <code>prefers-reduced-motion</code>.</td></tr>
      </tbody>
    </table>
  </section>
{% endblock %}
