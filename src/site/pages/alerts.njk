{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Alerts · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Alerts</h1>
    <p class="lead">A contextual feedback strip.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>Use <code>.alert</code> on its own for a neutral message.</p>
    {% call ui.demo() %}
    <div class="alert w-100">
      <i data-lucide="info"></i>
      Some neutral message here.
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Variants</h2>
    <p>Add a state modifier like <code>.alert-success</code> or <code>.alert-danger</code>. Background and border tint to the state, the icon takes its full color, and body text stays neutral so the message reads at a glance.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-column gap-2 w-100">
      <div class="alert">
        <i data-lucide="info"></i>
        <div>Some neutral message here.</div>
      </div>
      <div class="alert alert-danger">
        <i data-lucide="x-circle"></i>
        <div>Payment failed. Check your card details.</div>
      </div>
      <div class="alert alert-info">
        <i data-lucide="info"></i>
        <div>Some useful information here.</div>
      </div>
      <div class="alert alert-success">
        <i data-lucide="check-circle-2"></i>
        <div>Your changes have been saved successfully.</div>
      </div>
      <div class="alert alert-warning">
        <i data-lucide="triangle-alert"></i>
        <div>Some features may not work.</div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Without icon</h2>
    <p>There's no icon wrapper class. The leading icon is any direct <code>&lt;svg&gt;</code> or <code>&lt;i&gt;</code> child. Skip it and the row reflows around the text.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-column gap-2 w-100">
      <div class="alert alert-primary">Heads up, your trial ends in 3 days.</div>
      <div class="alert alert-success">Your changes have been saved successfully.</div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>With heading and description</h2>
    <p>Add <code>.alert-description</code> for a stacked layout. The heading sits above the description, the icon aligns with the heading, and the row gains a bit of breathing room.</p>
    {% call ui.demo() %}
    <div class="alert w-100">
      <i data-lucide="info"></i>
      <div class="alert-heading">Alert Title</div>
      <div class="alert-description">Alert Description</div>
    </div>
    {% endcall %}

    <p>Same layout, stateful variant.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-column gap-2 w-100">
      <div class="alert alert-info">
        <i data-lucide="info"></i>
        <div class="alert-heading">Heads up</div>
        <div class="alert-description">A new version is available. Refresh to load it.</div>
      </div>
      <div class="alert alert-warning">
        <i data-lucide="triangle-alert"></i>
        <div class="alert-heading">Unsaved changes</div>
        <div class="alert-description">Leaving this page will discard your edits.</div>
      </div>
      <div class="alert alert-danger">
        <i data-lucide="x-circle"></i>
        <div class="alert-heading">Payment failed</div>
        <div class="alert-description">We couldn't charge your card. Update billing details and retry.</div>
      </div>
    </div>
    {% endcall %}

    <p>Without an icon the heading and description take the leading column.</p>
    {% call ui.demo() %}
    <div class="alert w-100">
      <div class="alert-heading">No icon</div>
      <div class="alert-description">The icon column collapses when no <code>&lt;svg&gt;</code> / <code>&lt;i&gt;</code> child is present.</div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Action slot</h2>
    <p><code>.alert-action</code> is the trailing slot. It pushes to the right on single-line alerts and centers vertically when a description is present. Drop in a button, link, or close control.</p>
    {% call ui.demo() %}
    <div class="alert w-100">
      <i data-lucide="info"></i>
      <div>Message deleted successfully.</div>
      <div class="alert-action">
        <button type="button" class="btn btn-secondary btn-sm">Undo</button>
      </div>
    </div>
    {% endcall %}

    <p>Multiple actions and stateful variants.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-column gap-2 w-100">
      <div class="alert alert-warning">
        <i data-lucide="triangle-alert"></i>
        <div>Your session is about to expire.</div>
        <div class="alert-action">
          <button type="button" class="btn btn-ghost-secondary btn-sm">Stay</button>
          <button type="button" class="btn btn-warning btn-sm">Extend</button>
        </div>
      </div>
      <div class="alert alert-info">
        <i data-lucide="info"></i>
        <div class="alert-heading">New version available</div>
        <div class="alert-description">Reload to pick up the latest changes.</div>
        <div class="alert-action">
          <button type="button" class="btn btn-info btn-sm">Reload</button>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Dismissible</h2>
    <p>Put a <code>.btn-close</code> with <code>data-bsdismiss="alert"</code> inside <code>.alert-action</code>. Bootstrap's dismiss JS still fires and the close sits in flow next to any other action. Skip the <code>.alert-dismissible</code> class. Its absolute positioning isn't needed here.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-column gap-2 w-100">
      <div class="alert alert-success fade show">
        <i data-lucide="check-circle-2"></i>
        <div>Your changes have been saved.</div>
        <div class="alert-action">
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      </div>
      <div class="alert alert-danger fade show">
        <i data-lucide="x-circle"></i>
        <div class="alert-heading">Couldn't connect</div>
        <div class="alert-description">We lost contact with the server. Try again in a moment.</div>
        <div class="alert-action">
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Link color</h2>
    <p>Use <code>.alert-link</code> for inline links so they pick up the variant color without extra utility classes.</p>
    {% call ui.demo() %}
    <div class="alert alert-info w-100">
      <i data-lucide="info"></i>
      <div>A simple info alert with <a href="#" class="alert-link">an example link</a>.</div>
    </div>
    {% endcall %}
  </section>
{% endblock %}
