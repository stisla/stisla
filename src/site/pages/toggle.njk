{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Toggle · Stisla{% endblock %}

{% block content %}
  <header>
    <h1>Toggle</h1>
    <p class="lead">A two-state press button. Outline-neutral at rest, highlight-filled when active.</p>
    <p>For collections of toggles in a pill container, see <a class="link" href="/toggle-group">Toggle group</a>.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>Add <code>data-stisla-toggle</code> to a <code>&lt;button class="toggle"&gt;</code>. Clicking flips <code>aria-pressed</code>.</p>
    {% call ui.demo() %}
    <button type="button" class="toggle" data-stisla-toggle aria-pressed="true">
      <i data-lucide="bell"></i>
      Notifications on
    </button>
    {% endcall %}
  </section>

  <section>
    <h2>Keyboard</h2>
    <p>The toggle behaves like a native <code>&lt;button&gt;</code> with a sticky pressed state.</p>
    <ul>
      <li><kbd>Tab</kbd>: focus the toggle</li>
      <li><kbd>Space</kbd> / <kbd>Enter</kbd>: flip <code>aria-pressed</code></li>
    </ul>
  </section>

  <section>
    <h2>Form data</h2>
    <p>For a toggle whose state submits with a form, use a hidden <code>&lt;input class="toggle-input"&gt;</code> paired with a sibling <code>&lt;label class="toggle"&gt;</code>. The browser owns selection, so no JS is needed.</p>
    {% call ui.demo() %}
    <div>
      <input type="checkbox" class="toggle-input" id="newsletterToggle" name="newsletter" checked>
      <label class="toggle" for="newsletterToggle">
        <i data-lucide="mail"></i>
        Subscribe to newsletter
      </label>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Add <code>.toggle--compact</code> or <code>.toggle--roomy</code> to match the <code>.btn</code> size cadence.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <button type="button" class="toggle toggle--compact" data-stisla-toggle aria-pressed="true">Bold</button>
      <button type="button" class="toggle" data-stisla-toggle aria-pressed="true">Bold</button>
      <button type="button" class="toggle toggle--roomy" data-stisla-toggle aria-pressed="true">Bold</button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Icon-only</h2>
    <p>Add <code>.toggle--icon-only</code> for a square slot (mirrors <code>.btn--icon-only</code>). Add an <code>aria-label</code> so the affordance is named for assistive tech.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <button type="button" class="toggle toggle--icon-only" data-stisla-toggle aria-pressed="false" aria-label="Bold">
        <i data-lucide="bold"></i>
      </button>
      <button type="button" class="toggle toggle--icon-only" data-stisla-toggle aria-pressed="true" aria-label="Italic">
        <i data-lucide="italic"></i>
      </button>
      <button type="button" class="toggle toggle--icon-only" data-stisla-toggle aria-pressed="false" aria-label="Underline">
        <i data-lucide="underline"></i>
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Icon-round</h2>
    <p>Add <code>.toggle--icon-round</code> alongside <code>.toggle--icon-only</code> for a circular silhouette. Same opt-out as <code>.btn--icon-round</code>. The radius forces a fully pilled corner.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <button type="button" class="toggle toggle--icon-only toggle--icon-round" data-stisla-toggle aria-pressed="false" aria-label="Like">
        <i data-lucide="thumbs-up"></i>
      </button>
      <button type="button" class="toggle toggle--icon-only toggle--icon-round" data-stisla-toggle aria-pressed="true" aria-label="Love">
        <i data-lucide="heart"></i>
      </button>
      <button type="button" class="toggle toggle--icon-only toggle--icon-round" data-stisla-toggle aria-pressed="false" aria-label="Star">
        <i data-lucide="star"></i>
      </button>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Disabled</h2>
    <p>Native <code>:disabled</code> on the button (or on the paired <code>.toggle-input</code>) dims the chip and blocks pointer events.</p>
    {% call ui.demo() %}
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <button type="button" class="toggle" data-stisla-toggle aria-pressed="false" disabled>Off, disabled</button>
      <button type="button" class="toggle" data-stisla-toggle aria-pressed="true" disabled>On, disabled</button>
      <input type="checkbox" class="toggle-input" id="toggleDisabledForm" disabled>
      <label class="toggle" for="toggleDisabledForm">Form, disabled</label>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Events</h2>
    <p>Two events fire on the toggle. Both carry the upcoming or new state in <code>detail.pressed</code>.</p>
    <p><code>stisla:toggle:changing</code> fires before the flip and is cancelable. Call <code>preventDefault()</code> on the event to keep the current state (useful when an external check has to confirm the flip first).</p>
    <p><code>stisla:toggle:changed</code> fires after the flip lands. Use it to mirror the state somewhere else or to save the choice.</p>
  </section>

  <section>
    <h2>Customization</h2>
    <p>Sixteen variables retune <code>.toggle</code>. Geometry mirrors <code>.btn</code>. Surface variables follow the interactional trio (rest, accent hover, highlight active). It's the same vocabulary sidebar, list-group, table and pagination use for selected state.</p>
    <table>
      <thead>
        <tr>
          <th>Variable</th>
          <th>Use</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>--toggle-radius</code></td>
          <td>Corner radius.</td>
        </tr>
        <tr>
          <td><code>--toggle-height</code></td>
          <td>Hard single-line height. The compact and roomy modifiers reassign this.</td>
        </tr>
        <tr>
          <td><code>--toggle-padding-inline</code></td>
          <td>Horizontal padding; the compact and roomy modifiers reassign this.</td>
        </tr>
        <tr>
          <td><code>--toggle-gap</code></td>
          <td>Space between an icon and its label inside the chip.</td>
        </tr>
        <tr>
          <td><code>--toggle-font-size</code></td>
          <td>Label size.</td>
        </tr>
        <tr>
          <td><code>--toggle-font-weight</code></td>
          <td>Label weight.</td>
        </tr>
        <tr>
          <td><code>--toggle-bg</code></td>
          <td>Rest fill.</td>
        </tr>
        <tr>
          <td><code>--toggle-color</code></td>
          <td>Rest text color.</td>
        </tr>
        <tr>
          <td><code>--toggle-border-color</code></td>
          <td>Rim color.</td>
        </tr>
        <tr>
          <td><code>--toggle-border-width</code></td>
          <td>Rim thickness.</td>
        </tr>
        <tr>
          <td><code>--toggle-bg-hover</code></td>
          <td>Hover fill (transient).</td>
        </tr>
        <tr>
          <td><code>--toggle-color-hover</code></td>
          <td>Hover text color.</td>
        </tr>
        <tr>
          <td><code>--toggle-bg-active</code></td>
          <td>Active fill (persistent).</td>
        </tr>
        <tr>
          <td><code>--toggle-color-active</code></td>
          <td>Active text color.</td>
        </tr>
        <tr>
          <td><code>--toggle-border-color-active</code></td>
          <td>Active rim. Default matches the bg so the chip reads as a clean solid fill. Override it for a distinct rim.</td>
        </tr>
        <tr>
          <td><code>--toggle-ring</code></td>
          <td>Focus outline color.</td>
        </tr>
      </tbody>
    </table>
  </section>
{% endblock %}
