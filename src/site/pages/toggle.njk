{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Toggle · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Toggle</h1>
    <p class="lead">A button-shaped affordance backed by a native input. Use for option pickers and segmented controls.</p>
  </header>

  <section>
    <h2>How it works</h2>
    <p>A hidden <code>&lt;input class="toggle"&gt;</code> sits next to a <code>&lt;label class="btn"&gt;</code>. The input owns the state (checkbox <code>:checked</code> for a single toggle, radio for a one-of-many group). The label is the visible affordance, paired via <code>for</code> / <code>id</code>. No JS — the browser's native input handling drives everything.</p>
    <p>The visual is fixed: outline-neutral by default, accent fill when selected. The label uses <code>class="btn"</code> for shape (height, padding, density, focus ring), and the toggle's rules overwrite the color layer on top.</p>
    <p><strong>Shape modifiers compose</strong> — pair <code>.btn--sm</code> / <code>.btn--lg</code> / <code>.btn--icon-only</code> / <code>.btn--icon-round</code> on the label and they apply as expected. <strong>Tone modifiers do not</strong> — <code>.btn--primary</code> / <code>.btn--danger</code> are silently ignored because a segmented control reads as "pick one of these", not "trigger this action". If you need a tone-colored toggle, that's a different pattern (custom CSS at the consumer level).</p>
  </section>

  <section>
    <h2>Single toggle</h2>
    <p>A checkbox-backed toggle for a single on / off setting. Use when the affordance is part of a settings row and the on state has a discrete meaning.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <input type="checkbox" class="toggle" id="toggleBold" autocomplete="off" />
      <label class="btn" for="toggleBold">Bold</label>
      <input type="checkbox" class="toggle" id="toggleItalic" autocomplete="off" checked />
      <label class="btn" for="toggleItalic">Italic</label>
      <input type="checkbox" class="toggle" id="toggleUnderline" autocomplete="off" />
      <label class="btn" for="toggleUnderline">Underline</label>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Segmented (radio)</h2>
    <p>Radio inputs sharing a <code>name</code> make a one-of-many picker. The browser handles single-selection within the group.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <input type="radio" class="toggle" name="rangeToggle" id="rangeDay" autocomplete="off" checked />
      <label class="btn" for="rangeDay">Day</label>
      <input type="radio" class="toggle" name="rangeToggle" id="rangeWeek" autocomplete="off" />
      <label class="btn" for="rangeWeek">Week</label>
      <input type="radio" class="toggle" name="rangeToggle" id="rangeMonth" autocomplete="off" />
      <label class="btn" for="rangeMonth">Month</label>
      <input type="radio" class="toggle" name="rangeToggle" id="rangeYear" autocomplete="off" />
      <label class="btn" for="rangeYear">Year</label>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Icon only</h2>
    <p>Pair with <code>.btn--icon-only</code> on the label for a compact picker. Add an <code>aria-label</code> so the affordance is named for assistive tech.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <input type="radio" class="toggle" name="alignToggle" id="alignLeft" autocomplete="off" checked />
      <label class="btn btn--icon-only" for="alignLeft" aria-label="Align left">
        <i data-lucide="align-left"></i>
      </label>
      <input type="radio" class="toggle" name="alignToggle" id="alignCenter" autocomplete="off" />
      <label class="btn btn--icon-only" for="alignCenter" aria-label="Align center">
        <i data-lucide="align-center"></i>
      </label>
      <input type="radio" class="toggle" name="alignToggle" id="alignRight" autocomplete="off" />
      <label class="btn btn--icon-only" for="alignRight" aria-label="Align right">
        <i data-lucide="align-right"></i>
      </label>
      <input type="radio" class="toggle" name="alignToggle" id="alignJustify" autocomplete="off" />
      <label class="btn btn--icon-only" for="alignJustify" aria-label="Justify">
        <i data-lucide="align-justify"></i>
      </label>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Add <code>.btn--sm</code> or <code>.btn--lg</code> on the label to scale the shape. Density still multiplies through.</p>
    {% call ui.demo() %}
    <div class="demo-stack">
      <div class="demo-row">
        <input type="radio" class="toggle" name="sizeSmToggle" id="sizeSm1" autocomplete="off" checked />
        <label class="btn btn--sm" for="sizeSm1">Compact</label>
        <input type="radio" class="toggle" name="sizeSmToggle" id="sizeSm2" autocomplete="off" />
        <label class="btn btn--sm" for="sizeSm2">Cozy</label>
        <input type="radio" class="toggle" name="sizeSmToggle" id="sizeSm3" autocomplete="off" />
        <label class="btn btn--sm" for="sizeSm3">Comfortable</label>
      </div>
      <div class="demo-row">
        <input type="radio" class="toggle" name="sizeLgToggle" id="sizeLg1" autocomplete="off" />
        <label class="btn btn--lg" for="sizeLg1">Day</label>
        <input type="radio" class="toggle" name="sizeLgToggle" id="sizeLg2" autocomplete="off" checked />
        <label class="btn btn--lg" for="sizeLg2">Week</label>
        <input type="radio" class="toggle" name="sizeLgToggle" id="sizeLg3" autocomplete="off" />
        <label class="btn btn--lg" for="sizeLg3">Month</label>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Mix and match shape modifiers</h2>
    <p>Stack any <code>.btn</code> shape modifier on the label. The toggle owns the color layer; shapes just compose. Icon + text in a segmented group, or icon-only with a round silhouette, both work as expected.</p>
    {% call ui.demo() %}
    <div class="demo-stack">
      <div class="demo-row">
        <input type="radio" class="toggle" name="viewMode" id="viewList" autocomplete="off" checked />
        <label class="btn" for="viewList">
          <i data-lucide="list"></i>
          List
        </label>
        <input type="radio" class="toggle" name="viewMode" id="viewGrid" autocomplete="off" />
        <label class="btn" for="viewGrid">
          <i data-lucide="layout-grid"></i>
          Grid
        </label>
        <input type="radio" class="toggle" name="viewMode" id="viewKanban" autocomplete="off" />
        <label class="btn" for="viewKanban">
          <i data-lucide="columns-3"></i>
          Kanban
        </label>
      </div>
      <div class="demo-row">
        <input type="radio" class="toggle" name="reaction" id="reactLike" autocomplete="off" />
        <label class="btn btn--icon-only btn--icon-round" for="reactLike" aria-label="Like">
          <i data-lucide="thumbs-up"></i>
        </label>
        <input type="radio" class="toggle" name="reaction" id="reactLove" autocomplete="off" checked />
        <label class="btn btn--icon-only btn--icon-round" for="reactLove" aria-label="Love">
          <i data-lucide="heart"></i>
        </label>
        <input type="radio" class="toggle" name="reaction" id="reactLaugh" autocomplete="off" />
        <label class="btn btn--icon-only btn--icon-round" for="reactLaugh" aria-label="Laugh">
          <i data-lucide="laugh"></i>
        </label>
        <input type="radio" class="toggle" name="reaction" id="reactCelebrate" autocomplete="off" />
        <label class="btn btn--icon-only btn--icon-round" for="reactCelebrate" aria-label="Celebrate">
          <i data-lucide="party-popper"></i>
        </label>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Disabled</h2>
    <p>Disable the input directly. The label dims with it and stops responding to clicks.</p>
    {% call ui.demo() %}
    <div class="demo-row">
      <input type="checkbox" class="toggle" id="disabledOff" autocomplete="off" disabled />
      <label class="btn" for="disabledOff">Off, disabled</label>
      <input type="checkbox" class="toggle" id="disabledOn" autocomplete="off" checked disabled />
      <label class="btn" for="disabledOn">On, disabled</label>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Versus <code>.btn-group</code></h2>
    <p><code>.toggle</code> is an HTML-only pattern. No JS, the browser's native input state is the source of truth. Use when the selected value should land in form data, or when you need a one-of-many picker without writing handlers.</p>
    <p>For tab-like UI where the selected state lives in script (active tab on a panel, view mode on a chart, segment in a wizard), use the planned <code>.btn-group[data-state="active"]</code> pattern instead. Same visual, different state ownership.</p>
  </section>
{% endblock %}
