{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Tabs · Stisla v3{% endblock %}

{% block content %}
  <header>
    <h1>Tabs</h1>
    <p class="lead">A tab strip that swaps a panel of content on click.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>Use buttons as the tab triggers and pair them with a <code>.tab-content</code> wrapper. Each trigger needs <code>data-bs-toggle="tab"</code> and a <code>data-bs-target</code> pointing at its pane. See <a href="/navs">Navs</a> for the static row variants.</p>
    {% call ui.demo() %}
    <div class="w-100">
      <ul class="nav nav-tabs" id="tabsBasic" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="tabsBasic-home-tab" data-bs-toggle="tab" data-bs-target="#tabsBasic-home" type="button" role="tab" aria-controls="tabsBasic-home" aria-selected="true">Home</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tabsBasic-profile-tab" data-bs-toggle="tab" data-bs-target="#tabsBasic-profile" type="button" role="tab" aria-controls="tabsBasic-profile" aria-selected="false">Profile</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tabsBasic-contact-tab" data-bs-toggle="tab" data-bs-target="#tabsBasic-contact" type="button" role="tab" aria-controls="tabsBasic-contact" aria-selected="false">Contact</button>
        </li>
      </ul>
      <div class="tab-content border border-top-0 rounded-bottom p-3" id="tabsBasicContent">
        <div class="tab-pane show active" id="tabsBasic-home" role="tabpanel" aria-labelledby="tabsBasic-home-tab" tabindex="0">
          <p class="mb-0">Home pane. Swap to another tab and this stays in the DOM.</p>
        </div>
        <div class="tab-pane" id="tabsBasic-profile" role="tabpanel" aria-labelledby="tabsBasic-profile-tab" tabindex="0">
          <p class="mb-0">Profile pane content.</p>
        </div>
        <div class="tab-pane" id="tabsBasic-contact" role="tabpanel" aria-labelledby="tabsBasic-contact-tab" tabindex="0">
          <p class="mb-0">Contact pane content.</p>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Pills</h2>
    <p>Swap <code>.nav-tabs</code> for <code>.nav-pills</code> and use <code>data-bs-toggle="pill"</code> on the triggers. The pane container can drop the border for a flush look.</p>
    {% call ui.demo() %}
    <div class="w-100">
      <ul class="nav nav-pills mb-3" id="tabsPills" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="tabsPills-home-tab" data-bs-toggle="pill" data-bs-target="#tabsPills-home" type="button" role="tab" aria-controls="tabsPills-home" aria-selected="true">Home</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tabsPills-profile-tab" data-bs-toggle="pill" data-bs-target="#tabsPills-profile" type="button" role="tab" aria-controls="tabsPills-profile" aria-selected="false">Profile</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tabsPills-contact-tab" data-bs-toggle="pill" data-bs-target="#tabsPills-contact" type="button" role="tab" aria-controls="tabsPills-contact" aria-selected="false">Contact</button>
        </li>
      </ul>
      <div class="tab-content" id="tabsPillsContent">
        <div class="tab-pane show active" id="tabsPills-home" role="tabpanel" aria-labelledby="tabsPills-home-tab" tabindex="0">
          <p class="mb-0">Home pane.</p>
        </div>
        <div class="tab-pane" id="tabsPills-profile" role="tabpanel" aria-labelledby="tabsPills-profile-tab" tabindex="0">
          <p class="mb-0">Profile pane.</p>
        </div>
        <div class="tab-pane" id="tabsPills-contact" role="tabpanel" aria-labelledby="tabsPills-contact-tab" tabindex="0">
          <p class="mb-0">Contact pane.</p>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Underline</h2>
    <p>The <code>.nav-underline</code> variant pairs the same way as tabs and pills. The active trigger gets an underline marker.</p>
    {% call ui.demo() %}
    <div class="w-100">
      <ul class="nav nav-underline mb-3" id="tabsUnderline" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="tabsUnderline-overview-tab" data-bs-toggle="tab" data-bs-target="#tabsUnderline-overview" type="button" role="tab" aria-controls="tabsUnderline-overview" aria-selected="true">Overview</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tabsUnderline-activity-tab" data-bs-toggle="tab" data-bs-target="#tabsUnderline-activity" type="button" role="tab" aria-controls="tabsUnderline-activity" aria-selected="false">Activity</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tabsUnderline-settings-tab" data-bs-toggle="tab" data-bs-target="#tabsUnderline-settings" type="button" role="tab" aria-controls="tabsUnderline-settings" aria-selected="false">Settings</button>
        </li>
      </ul>
      <div class="tab-content" id="tabsUnderlineContent">
        <div class="tab-pane show active" id="tabsUnderline-overview" role="tabpanel" aria-labelledby="tabsUnderline-overview-tab" tabindex="0">
          <p class="mb-0">Overview pane.</p>
        </div>
        <div class="tab-pane" id="tabsUnderline-activity" role="tabpanel" aria-labelledby="tabsUnderline-activity-tab" tabindex="0">
          <p class="mb-0">Activity pane.</p>
        </div>
        <div class="tab-pane" id="tabsUnderline-settings" role="tabpanel" aria-labelledby="tabsUnderline-settings-tab" tabindex="0">
          <p class="mb-0">Settings pane.</p>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Fade animation</h2>
    <p>Add <code>.fade</code> to every <code>.tab-pane</code> and keep <code>.show</code> on the initially active pane. Bootstrap cross-fades the panels on switch.</p>
    {% call ui.demo() %}
    <div class="w-100">
      <ul class="nav nav-tabs" id="tabsFade" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="tabsFade-home-tab" data-bs-toggle="tab" data-bs-target="#tabsFade-home" type="button" role="tab" aria-controls="tabsFade-home" aria-selected="true">Home</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tabsFade-profile-tab" data-bs-toggle="tab" data-bs-target="#tabsFade-profile" type="button" role="tab" aria-controls="tabsFade-profile" aria-selected="false">Profile</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tabsFade-contact-tab" data-bs-toggle="tab" data-bs-target="#tabsFade-contact" type="button" role="tab" aria-controls="tabsFade-contact" aria-selected="false">Contact</button>
        </li>
      </ul>
      <div class="tab-content border border-top-0 rounded-bottom p-3" id="tabsFadeContent">
        <div class="tab-pane fade show active" id="tabsFade-home" role="tabpanel" aria-labelledby="tabsFade-home-tab" tabindex="0">
          <p class="mb-0">Home pane fades in.</p>
        </div>
        <div class="tab-pane fade" id="tabsFade-profile" role="tabpanel" aria-labelledby="tabsFade-profile-tab" tabindex="0">
          <p class="mb-0">Profile pane fades in.</p>
        </div>
        <div class="tab-pane fade" id="tabsFade-contact" role="tabpanel" aria-labelledby="tabsFade-contact-tab" tabindex="0">
          <p class="mb-0">Contact pane fades in.</p>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Vertical pills</h2>
    <p>Combine <code>.flex-column</code> with <code>.nav-pills</code> and seat the pane container beside the strip in a grid row. Add <code>aria-orientation="vertical"</code> on the tab list for assistive tech.</p>
    {% call ui.demo() %}
    <div class="row g-3 w-100">
      <div class="col-sm-4 col-md-3">
        <ul class="nav nav-pills flex-column" id="tabsVertical" role="tablist" aria-orientation="vertical">
          <li class="nav-item" role="presentation">
            <button class="nav-link active w-100 text-start" id="tabsVertical-account-tab" data-bs-toggle="pill" data-bs-target="#tabsVertical-account" type="button" role="tab" aria-controls="tabsVertical-account" aria-selected="true">Account</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link w-100 text-start" id="tabsVertical-billing-tab" data-bs-toggle="pill" data-bs-target="#tabsVertical-billing" type="button" role="tab" aria-controls="tabsVertical-billing" aria-selected="false">Billing</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link w-100 text-start" id="tabsVertical-team-tab" data-bs-toggle="pill" data-bs-target="#tabsVertical-team" type="button" role="tab" aria-controls="tabsVertical-team" aria-selected="false">Team</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link w-100 text-start" id="tabsVertical-notifications-tab" data-bs-toggle="pill" data-bs-target="#tabsVertical-notifications" type="button" role="tab" aria-controls="tabsVertical-notifications" aria-selected="false">Notifications</button>
          </li>
        </ul>
      </div>
      <div class="col-sm-8 col-md-9">
        <div class="tab-content" id="tabsVerticalContent">
          <div class="tab-pane fade show active" id="tabsVertical-account" role="tabpanel" aria-labelledby="tabsVertical-account-tab" tabindex="0">
            <p class="mb-0">Account settings live here.</p>
          </div>
          <div class="tab-pane fade" id="tabsVertical-billing" role="tabpanel" aria-labelledby="tabsVertical-billing-tab" tabindex="0">
            <p class="mb-0">Billing details, invoices, and payment methods.</p>
          </div>
          <div class="tab-pane fade" id="tabsVertical-team" role="tabpanel" aria-labelledby="tabsVertical-team-tab" tabindex="0">
            <p class="mb-0">Members of your workspace.</p>
          </div>
          <div class="tab-pane fade" id="tabsVertical-notifications" role="tabpanel" aria-labelledby="tabsVertical-notifications-tab" tabindex="0">
            <p class="mb-0">Email and in-app notification preferences.</p>
          </div>
        </div>
      </div>
    </div>
    {% endcall %}
  </section>
{% endblock %}
