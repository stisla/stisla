{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Customization · Stisla v3{% endblock %}

{#
  Architecture proof for Phase 1 (V3.md). One showcase, replayed under five
  presets applied via inline --st-* overrides. If any preset doesn't reshape
  the components correctly, the token model has a hole.

  Each preset wraps `showcase()` in a scoped `<div style="--st-…">` block so
  the override applies only to that subtree.
#}

{%- macro showcase() -%}
<div class="demo-row demo-row--top demo-row--gap-md">
  <div class="card" style="width: 16rem;">
    <div class="card__header">Card title</div>
    <div class="card__body">
      <p class="card__text">A card with a header, body, and footer to show every padding and surface tier respond to the preset.</p>
      <div class="demo-row">
        <button type="button" class="btn btn--primary">Primary</button>
        <button type="button" class="btn btn--outline btn--neutral">Cancel</button>
      </div>
    </div>
    <div class="card__footer">
      <span class="small text-muted-foreground">Footer note</span>
    </div>
  </div>
  <div class="demo-stack">
    <div class="demo-row">
      <button type="button" class="btn btn--primary">Primary</button>
      <button type="button" class="btn btn--neutral">Neutral</button>
      <button type="button" class="btn btn--tertiary">Tertiary</button>
    </div>
    <div class="demo-row">
      <button type="button" class="btn btn--outline btn--primary">Outline</button>
      <button type="button" class="btn btn--ghost btn--primary">Ghost</button>
      <button type="button" class="btn btn--soft btn--primary">Soft</button>
    </div>
    <div class="demo-row">
      <button type="button" class="btn btn--primary btn--sm">Small</button>
      <button type="button" class="btn btn--primary">Default</button>
      <button type="button" class="btn btn--primary btn--lg">Large</button>
    </div>
  </div>
</div>
{%- endmacro %}

{% block content %}
  <header>
    <h1>Customization</h1>
    <p class="lead">
      Reshape every component by overriding root tokens. No CSS edits.
    </p>
  </header>

  <section>
    <h2>How it works</h2>
    <p>
      All visual decisions live in 30 <code>--st-*</code> tokens. Set one or
      more at <code>:root</code> and every component picks up the change.
      Scope them to a wrapper to theme one subtree. Components inside read
      their tokens via <code>var()</code>, so they pick up whatever values
      are in scope without rebuilding.
    </p>
    <p>
      Each preset below applies overrides via an inline <code>style</code>
      attribute on the section wrapper. The component markup is identical
      in every preset.
    </p>
  </section>

  <section>
    <h2>Default</h2>
    <p>The token surface as it ships. Reference for comparison.</p>
    {% call ui.demo() %}
    {{ showcase() }}
    {% endcall %}
  </section>

  <section>
    <h2>Brutalist</h2>
    <p>
      Zero radius and a solid offset shadow. Identity flip from two knobs.
    </p>
    {% call ui.demo() %}
    <div style="--st-radius: 0; --st-shadow: 4px 4px 0 black;">
      {{ showcase() }}
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Soft</h2>
    <p>Larger radius, softer ambient shadow.</p>
    {% call ui.demo() %}
    <div style="--st-radius: 1rem; --st-shadow: 0 12px 32px rgba(0,0,0,.10), 0 4px 8px rgba(0,0,0,.04);">
      {{ showcase() }}
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Dense</h2>
    <p>
      Density at <code>0.875</code> shrinks padding proportionally across
      every component.
    </p>
    {% call ui.demo() %}
    <div style="--st-density: 0.875;">
      {{ showcase() }}
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Violet primary</h2>
    <p>
      Swap the brand color. Every primary-toned surface picks up the new
      hue, including ghost and light variants that derive from it.
    </p>
    {% call ui.demo() %}
    <div style="--st-primary: oklch(0.58 0.22 285);">
      {{ showcase() }}
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Warm neutrals</h2>
    <p>
      Default neutrals ship as pure gray. To retint, override the nine
      neutral tokens on a wrapper. Components inside read those tokens via
      <code>var()</code> and pick up the new values automatically. Intents
      (primary, success, warning, danger, info) stay vivid at their
      authored values. Only the neutral tier shifts.
    </p>
    {% call ui.demo() %}
    <div style="
      --st-background:       oklch(0.97  0.018 30);
      --st-foreground:       oklch(0.27  0.018 30);
      --st-surface:          oklch(0.985 0.012 30);
      --st-surface-2:        oklch(0.95  0.025 30);
      --st-surface-3:        oklch(0.92  0.030 30);
      --st-border:           oklch(0.88  0.028 30);
      --st-muted-foreground: oklch(0.52  0.060 30);
      --st-neutral:          oklch(0.90  0.022 30);
      --st-accent:           oklch(0.96  0.018 30);
      background: var(--st-background);
      padding: 1.5rem;
      border-radius: var(--st-radius);
    ">
      {{ showcase() }}
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Cool neutrals</h2>
    <p>
      Same shape, different hue. Swap <code>30</code> for <code>240</code>
      in each OKLCH literal. Any hue from 0 to 360 works. Match it to the
      brand color (or anything else) and the whole UI follows.
    </p>
    {% call ui.demo() %}
    <div style="
      --st-background:       oklch(0.97  0.018 240);
      --st-foreground:       oklch(0.27  0.018 240);
      --st-surface:          oklch(0.985 0.012 240);
      --st-surface-2:        oklch(0.95  0.025 240);
      --st-surface-3:        oklch(0.92  0.030 240);
      --st-border:           oklch(0.88  0.028 240);
      --st-muted-foreground: oklch(0.52  0.060 240);
      --st-neutral:          oklch(0.90  0.022 240);
      --st-accent:           oklch(0.96  0.018 240);
      background: var(--st-background);
      padding: 1.5rem;
      border-radius: var(--st-radius);
    ">
      {{ showcase() }}
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Per-component override</h2>
    <p>
      Set a component-scoped token to retune one family without touching
      the global radius. Here the buttons get a fully rounded silhouette
      while cards keep the default radius.
    </p>
    {% call ui.demo() %}
    <div style="--st-btn-radius: 9999px;">
      {{ showcase() }}
    </div>
    {% endcall %}
  </section>
{% endblock %}
