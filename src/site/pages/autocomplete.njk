{% extends "layouts/base.njk" %}
{% import "partials/_demo.njk" as ui %}

{% block title %}Autocomplete · Stisla{% endblock %}

{% block content %}
  <header>
    <h1>Autocomplete</h1>
    <p class="lead">An input that suggests options as the user types.</p>
    <p>Reach for Autocomplete when users type their own value and you want to help them along with suggestions. Picking a suggestion replaces the typed text with the chosen value. Single value only. For a non-typeable picker, use <a class="link" href="/select">Select</a>. For multi-select with chips, use <a class="link" href="/combobox">Combobox</a>.</p>
  </header>

  <section>
    <h2>Basic</h2>
    <p>The default authoring style is an <code>&lt;input&gt;</code> with <code>list="…"</code> referencing a <code>&lt;datalist&gt;</code>. Without JS the browser shows its native datalist UI; with JS, the native UI is suppressed and a styled popup takes over.</p>
    {% call ui.demo() %}
    <div class="field" style="max-width: 24rem;">
      <label for="basicAuto" class="field__label">Country</label>
      <input type="text" class="autocomplete" id="basicAuto" name="country" list="countries" data-stisla-autocomplete placeholder="Search countries">
      <datalist id="countries">
        <option value="Indonesia">
        <option value="Malaysia">
        <option value="Singapore">
        <option value="Philippines">
        <option value="Thailand">
        <option value="Vietnam">
        <option value="Brunei">
        <option value="Cambodia">
        <option value="Laos">
        <option value="Myanmar">
      </datalist>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Keyboard</h2>
    <p>The input behaves like a typing field with suggestions layered on top.</p>
    <ul>
      <li><kbd>ArrowDown</kbd>: open the popup or move highlight down</li>
      <li><kbd>ArrowUp</kbd>: move highlight up</li>
      <li><kbd>Enter</kbd>: pick the highlighted suggestion</li>
      <li><kbd>Escape</kbd>: close the popup, keep the typed text</li>
      <li><kbd>Tab</kbd>: close and move focus to the next field</li>
    </ul>
  </section>

  <section>
    <h2>From inline JSON</h2>
    <p>For dynamic option sets, drop a JSON array on <code>data-options</code>. Each entry is either a string (value = label) or an object with <code>value</code> and <code>label</code>.</p>
    {% call ui.demo() %}
    <div class="field" style="max-width: 24rem;">
      <label for="jsonAuto" class="field__label">Framework</label>
      <input type="text" class="autocomplete" id="jsonAuto" name="framework" data-stisla-autocomplete placeholder="Search frameworks" data-options='["React", "Vue", "Svelte", "Solid", "Angular", "Lit", "Qwik", "Astro"]'>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Minimum length</h2>
    <p>Set <code>data-stisla-autocomplete-min-length</code> to wait for a few characters before showing suggestions. Useful for long lists where typing a single letter would dump dozens of rows.</p>
    {% call ui.demo() %}
    <div class="field" style="max-width: 24rem;">
      <label for="minLengthAuto" class="field__label">City (min 2 chars)</label>
      <input type="text" class="autocomplete" id="minLengthAuto" data-stisla-autocomplete data-stisla-autocomplete-min-length="2" placeholder="Type at least 2 characters" data-options='["Jakarta", "Jambi", "Bandung", "Bali", "Surabaya", "Semarang", "Medan", "Makassar"]'>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Add <code>.autocomplete--compact</code> or <code>.autocomplete--roomy</code> for the small or large variant. Sizes match the input scale.</p>
    {% call ui.demo() %}
    <div class="demo-stack" style="max-width: 24rem;">
      <input type="text" class="autocomplete autocomplete--compact" data-stisla-autocomplete placeholder="Small" data-options='["Apple", "Banana", "Cherry"]' aria-label="Small autocomplete">
      <input type="text" class="autocomplete" data-stisla-autocomplete placeholder="Default" data-options='["Apple", "Banana", "Cherry"]' aria-label="Default autocomplete">
      <input type="text" class="autocomplete autocomplete--roomy" data-stisla-autocomplete placeholder="Large" data-options='["Apple", "Banana", "Cherry"]' aria-label="Large autocomplete">
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Disabled</h2>
    <p>Add <code>disabled</code> to block interaction and dim the field. The popup won't open.</p>
    {% call ui.demo() %}
    <div class="field" style="max-width: 24rem;">
      <label for="disabledAuto" class="field__label">Country</label>
      <input type="text" class="autocomplete" id="disabledAuto" data-stisla-autocomplete disabled placeholder="Search countries" data-options='["Indonesia", "Malaysia"]'>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Invalid</h2>
    <p>Set <code>aria-invalid="true"</code> on the input. The field shape inherits form-field-base's invalid handling, so the border paints red.</p>
    {% call ui.demo() %}
    <div class="field" style="max-width: 24rem;">
      <label for="invalidAuto" class="field__label">Country</label>
      <input type="text" class="autocomplete" id="invalidAuto" data-stisla-autocomplete aria-invalid="true" aria-describedby="invalidAutoError" placeholder="Search countries" data-options='["Indonesia", "Malaysia"]'>
      <div id="invalidAutoError" class="field__error">Pick a country to continue.</div>
    </div>
    {% endcall %}
  </section>

  <section>
    <h2>Events</h2>
    <p>Listen for <code>stisla:autocomplete:select</code> to react when the user picks a suggestion. The input's native <code>input</code> and <code>change</code> events fire too, so existing form code keeps working.</p>
    {% call ui.demo() %}
    <div class="field" style="max-width: 24rem;">
      <label for="eventAuto" class="field__label">Tag</label>
      <input type="text" class="autocomplete" id="eventAuto" data-stisla-autocomplete placeholder="Pick a tag" data-options='["Bug", "Docs", "Feature", "Performance"]'>
      <div id="eventAutoOut" class="field__description">Current: (none)</div>
    </div>
    <script>
      (function () {
        var el = document.getElementById('eventAuto');
        var out = document.getElementById('eventAutoOut');
        el.addEventListener('stisla:autocomplete:select', function (e) {
          out.textContent = 'Current: ' + e.detail.value;
        });
      })();
    </script>
    {% endcall %}
  </section>

  <section>
    <h2>Customization</h2>
    <p>The input reuses <code>--autocomplete-*</code> variables that mirror the input surface. The popup adds more <code>--autocomplete-*</code> variables that follow the same surface recipe as <a class="link" href="/menu">Menu</a>, <a class="link" href="/select">Select</a>, and <a class="link" href="/combobox">Combobox</a>.</p>
    <table>
      <thead><tr><th>Variable</th><th>Use</th></tr></thead>
      <tbody>
        <tr><td><code>--autocomplete-height</code></td><td>Input height (matches <code>.input</code>)</td></tr>
        <tr><td><code>--autocomplete-padding-inline</code></td><td>Input horizontal padding</td></tr>
        <tr><td><code>--autocomplete-radius</code></td><td>Corner radius, shared by input and popup</td></tr>
        <tr><td><code>--autocomplete-bg</code></td><td>Surface, shared by input and popup</td></tr>
        <tr><td><code>--autocomplete-item-bg-hover</code></td><td>Highlighted row background</td></tr>
      </tbody>
    </table>
  </section>
{% endblock %}
