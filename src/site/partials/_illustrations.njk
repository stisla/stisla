{#
  Stisla illustration set — 21 soft volumetric metaphors for empty states,
  dialogs, status screens (success / warning / error), and onboarding.
  Markup only; all colour lives in the .illustration component (driven by
  --illus-accent / --illus-badge). Each macro takes a unique `u` so gradient
  ids never collide when several are inlined on one page. viewBox is 200x200.
#}

{% macro defs(u) %}
<defs>
  <linearGradient id="gl-{{ u }}" x1=".15" y1=".05" x2=".85" y2=".95"><stop class="il-g0" offset="0"/><stop class="il-g1" offset="1"/></linearGradient>
  <linearGradient id="gm-{{ u }}" x1=".15" y1=".05" x2=".85" y2=".95"><stop class="il-g1" offset="0"/><stop class="il-g2" offset="1"/></linearGradient>
  <linearGradient id="gd-{{ u }}" x1=".15" y1=".05" x2=".85" y2=".95"><stop class="il-g2" offset="0"/><stop class="il-g3" offset="1"/></linearGradient>
</defs>
{% endmacro %}

{% macro stage() %}
  <circle class="il-disc-o" cx="100" cy="94" r="72"/>
  <circle class="il-disc-i" cx="100" cy="94" r="55"/>
{% endmacro %}

{# Additive pip: a Stisla squircle (brand shape) on a white sticker-ring, in
   the accent hue — deliberately not the generic red circle. #}
{% macro plus(cx, cy) %}
  <g class="il-badge">
    <rect x="{{ cx - 15 }}" y="{{ cy - 15 }}" width="30" height="30" rx="11" fill="#fff"/>
    <rect x="{{ cx - 13 }}" y="{{ cy - 13 }}" width="26" height="26" rx="9" fill="var(--_b)"/>
    <rect x="{{ cx - 6 }}" y="{{ cy - 1.6 }}" width="12" height="3.2" rx="1.6" fill="#fff"/>
    <rect x="{{ cx - 1.6 }}" y="{{ cy - 6 }}" width="3.2" height="12" rx="1.6" fill="#fff"/>
  </g>
{% endmacro %}

{% macro cross(cx, cy) %}
  <g class="il-badge" transform="rotate(45 {{ cx }} {{ cy }})">
    <rect x="{{ cx - 15 }}" y="{{ cy - 15 }}" width="30" height="30" rx="11" fill="#fff" transform="rotate(-45 {{ cx }} {{ cy }})"/>
    <rect x="{{ cx - 13 }}" y="{{ cy - 13 }}" width="26" height="26" rx="9" fill="var(--_b)" transform="rotate(-45 {{ cx }} {{ cy }})"/>
    <rect x="{{ cx - 6 }}" y="{{ cy - 1.6 }}" width="12" height="3.2" rx="1.6" fill="#fff"/>
    <rect x="{{ cx - 1.6 }}" y="{{ cy - 6 }}" width="3.2" height="12" rx="1.6" fill="#fff"/>
  </g>
{% endmacro %}

{% macro dot(cx, cy) %}
  <g class="il-badge"><circle cx="{{ cx }}" cy="{{ cy }}" r="11" fill="var(--_b)"/></g>
{% endmacro %}

{# Optional corner pip. Reserved for ADDITIVE states (plus); error/empty states
   pass nothing. kind: 'plus' | 'cross' | 'dot' | false. #}
{% macro mark(kind, cx, cy) %}
  {%- if kind == 'plus' -%}{{ plus(cx, cy) }}
  {%- elif kind == 'cross' -%}{{ cross(cx, cy) }}
  {%- elif kind == 'dot' -%}{{ dot(cx, cy) }}
  {%- endif -%}
{% endmacro %}

{# 1 ── Folder ────────────────────────────────────────────────────── #}
{% macro folder(u, badge='plus') %}
<svg viewBox="0 0 200 200" class="illustration illustration--animate" role="img" aria-label="Empty folder">
  {{ defs(u) }}{{ stage() }}
  <g class="il-obj">
    <path d="M46 74h30l10 12h64a9 9 0 0 1 9 9v38a9 9 0 0 1-9 9H46a9 9 0 0 1-9-9V83a9 9 0 0 1 9-9z" fill="url(#gm-{{ u }})"/>
    <path d="M40 98h120a4 4 0 0 1 4 4l-6 36a10 10 0 0 1-10 9H52a10 10 0 0 1-10-9l-6-36a4 4 0 0 1 4-4z" fill="url(#gl-{{ u }})"/>
    <rect x="48" y="101" width="104" height="5" rx="2.5" fill="#fff" opacity=".3"/>
  </g>
  {{ mark(badge, 150, 70) }}
</svg>
{% endmacro %}

