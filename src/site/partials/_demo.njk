{#
  Component demo block: framed preview on top, source HTML below.
  Single source of truth via Nunjucks {% call %} — the body is rendered once
  and shown twice (live + Shiki-highlighted).

  Short snippets render uncollapsed. Snippets longer than COLLAPSE_LINES get
  the View Code / Hide Code toggle: code clipped with a fade-out gradient
  until expanded, then capped at max-height with overflow-auto.

  Light/dark token colors come from Shiki's dual-theme CSS vars (--shiki-dark),
  so theme switching is pure CSS: no JS swap.

  The wrapping `.demo` carries `.not-prose` so the rendered preview and
  Shiki code listing are exempt from prose typography rules (the page
  wrapper is `.main-container.prose`, and component demos are not prose
  content). Pass `prose=true` for demos whose preview IS prose content
  (e.g. the .prose article showcase on /typography); that drops
  `.not-prose` so the inner content picks up framework prose styling.

  Usage:
    {% import "partials/_demo.njk" as ui %}
    {% call ui.demo() %}
    <div class="d-flex flex-wrap align-items-center gap-2">
      <button type="button" class="btn btn-primary">Primary</button>
    </div>
    {% endcall %}
#}
{%- macro demo(prose=false) -%}
{%- set src = caller() -%}
{%- set deded = src | dedent -%}
{%- set collapsible = (deded.split('\n') | length) > 5 -%}
<div class="demo{% if not prose %} not-prose{% endif %}">
  <div class="demo-preview">{{ src | safe }}</div>
  <div class="demo-code"{% if collapsible %} data-demo-code{% endif %}>
    <div class="demo-code-source">{{ deded | highlight('html') | safe }}</div>
    {%- if collapsible %}
    <button type="button" class="demo-code-toggle btn btn--compact btn--ghost btn--neutral" data-demo-code-toggle aria-expanded="false">
      <span class="demo-code-toggle-show">View Code</span>
      <span class="demo-code-toggle-hide">Hide Code</span>
    </button>
    {%- endif %}
  </div>
</div>
{%- endmacro -%}

{#
  Standalone code block: no live preview, no collapse toggle. Use for snippets
  that show example JS, config, or markup that wouldn't render meaningfully on
  the page (API calls, build config, etc.). Optional `title` shows a filename
  or label bar above the code; `lang` picks the Shiki grammar (default html).

  Usage:
    {% call ui.code(lang='js', title='site.js') %}
    const spy = Stisla.bs.ScrollSpy.getInstance(el);
    spy.refresh();
    {% endcall %}
#}
{%- macro code(lang='html', title=null) -%}
{%- set src = caller() -%}
{%- set deded = src | dedent -%}
<div class="demo demo-standalone not-prose">
  {%- if title %}
  <div class="demo-code-title">{{ title }}</div>
  {%- endif %}
  <div class="demo-code-source">{{ deded | highlight(lang) | safe }}</div>
</div>
{%- endmacro -%}
