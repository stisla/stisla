{% extends "layouts/auth.njk" %}

{% block title %}Sign in · Meridian{% endblock %}

{% block auth %}
<div>
  <h1 class="fs-6 fw-bold m-0">Welcome back</h1>
  <p class="text-muted-foreground m-0 mt-1">Sign in to your Meridian dashboard.</p>
</div>

<form class="d-flex flex-column gap-4">
  <div class="field">
    <label for="loginEmail" class="field__label">Email</label>
    <div class="input-group">
      <span class="input-group__text">{{ "solar:letter-linear" | icon }}</span>
      <input type="email" class="input" id="loginEmail" placeholder="you@meridian.com" autocomplete="email" />
    </div>
  </div>

  <div class="field">
    <div class="d-flex align-items-center justify-content-between gap-2">
      <label for="loginPassword" class="field__label">Password</label>
      <a href="/dashboard/forgot.html" class="link fs-1">Forgot?</a>
    </div>
    <div class="input-group">
      <span class="input-group__text">{{ "solar:lock-keyhole-linear" | icon }}</span>
      <input type="password" class="input" id="loginPassword" placeholder="••••••••••" autocomplete="current-password" />
      <button type="button" class="input-group__text" data-password-toggle aria-controls="loginPassword" aria-label="Show password" aria-pressed="false">{{ "solar:eye-linear" | icon }}</button>
    </div>
  </div>

  <div class="field__item">
    <input class="checkbox" type="checkbox" id="loginRemember" />
    <label class="field__label" for="loginRemember">Keep me signed in</label>
  </div>

  <a href="/dashboard/" class="btn btn--primary btn--block btn--roomy">Sign in {{ "solar:arrow-right-linear" | icon }}</a>
</form>

<p class="text-center fs-2 text-muted-foreground m-0">New to Meridian? <a href="/dashboard/register.html" class="link">Create an account</a></p>
{% endblock %}
