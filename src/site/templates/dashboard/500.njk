{% extends "layouts/error.njk" %}

{% block title %}500 · Meridian{% endblock %}

{% block error %}
<div class="empty-state empty-state--danger">
  <span class="empty-state__media">{{ "solar:danger-triangle-linear" | icon }}</span>
  <h3 class="empty-state__title">Something went wrong</h3>
  <p class="empty-state__text">An unexpected error occurred on our end. Try again in a moment.</p>
  <div class="empty-state__action flex-column">
    <a href="/dashboard/" class="btn btn--primary">{{ "solar:widget-linear" | icon }} Back to dashboard</a>
    <a href="#" class="btn btn--ghost btn--neutral">{{ "solar:refresh-linear" | icon }} Try again</a>
  </div>
</div>
{% endblock %}
