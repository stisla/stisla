{% extends "layouts/app.njk" %}
{% set nav_active = "products" %}

{% block title %}New product · Meridian{% endblock %}

{#
  Create / edit product form. Same template serves both — "Edit" prefills the
  controls server-side. Reuses the .order-form layout + sticky .order-form__bar
  from the order form (a generic form-page shell, not order-specific).
#}

{% block page %}
<div class="page content">
  <div class="content__container">
    <header class="page__header">
      <div class="page__headline">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb__item"><a href="/dashboard/">Dashboard</a></li>
            <li class="breadcrumb__item"><a href="/dashboard/products.html">Products</a></li>
            <li class="breadcrumb__item" aria-current="page">New product</li>
          </ol>
        </nav>
        <h1 class="page__title">New product</h1>
        <p class="page__description">Add a product to your catalog with pricing, inventory, and images.</p>
      </div>
    </header>

    <div class="page__body">
      <form class="order-form">
        <div class="row g-3">
          {# ---- Main column ---- #}
          <div class="col-12 col-lg-8">
            <div class="d-flex flex-column gap-3">
              {# Details #}
              <div class="card">
                <div class="card__header"><span class="card__title">Product details</span></div>
                <div class="card__body">
                  <div class="field">
                    <label for="prodName" class="field__label">Title</label>
                    <input type="text" class="input" id="prodName" placeholder="e.g. Espresso Beans 2kg" />
                  </div>
                  <div class="field">
                    <label for="prodDesc" class="field__label">Description</label>
                    <textarea class="textarea" id="prodDesc" rows="4" placeholder="Describe the product for your storefront."></textarea>
                  </div>
                </div>
              </div>

              {# Media #}
              <div class="card">
                <div class="card__header"><span class="card__title">Media</span></div>
                <div class="card__body">
                  <div class="field">
                    <label for="prodImages" class="field__label">Images</label>
                    <input type="file" class="input" id="prodImages" accept="image/*" multiple />
                    <p class="field__description">PNG or JPG, up to 5 MB each. The first image is the thumbnail.</p>
                  </div>
                </div>
              </div>

              {# Pricing #}
              <div class="card">
                <div class="card__header"><span class="card__title">Pricing</span></div>
                <div class="card__body">
                  <div class="row g-3">
                    <div class="col-12 col-sm-6">
                      <div class="field">
                        <label for="prodPrice" class="field__label">Price</label>
                        <div class="input-group">
                          <span class="input-group__text">$</span>
                          <input type="number" class="input" id="prodPrice" placeholder="0.00" min="0" step="0.01" />
                        </div>
                      </div>
                    </div>
                    <div class="col-12 col-sm-6">
                      <div class="field">
                        <label for="prodCompare" class="field__label">Compare-at price</label>
                        <div class="input-group">
                          <span class="input-group__text">$</span>
                          <input type="number" class="input" id="prodCompare" placeholder="0.00" min="0" step="0.01" />
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              {# Inventory #}
              <div class="card">
                <div class="card__header"><span class="card__title">Inventory</span></div>
                <div class="card__body">
                  <div class="row g-3">
                    <div class="col-12 col-sm-6">
                      <div class="field">
                        <label for="prodSku" class="field__label">SKU</label>
                        <input type="text" class="input" id="prodSku" placeholder="ESP-2000" />
                      </div>
                    </div>
                    <div class="col-12 col-sm-6">
                      <div class="field">
                        <label for="prodQty" class="field__label">Quantity</label>
                        <input type="number" class="input" id="prodQty" value="0" min="0" />
                      </div>
                    </div>
                  </div>
                  <div class="field">
                    <div class="field__item">
                      <input class="switch" type="checkbox" role="switch" id="prodTrack" checked />
                      <label class="field__label" for="prodTrack">Track quantity</label>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          {# ---- Side column ---- #}
          <div class="col-12 col-lg-4">
            <div class="d-flex flex-column gap-3">
              {# Status #}
              <div class="card">
                <div class="card__header"><span class="card__title">Status</span></div>
                <div class="card__body">
                  <div class="field">
                    <label for="prodStatus" class="field__label">Status</label>
                    <select class="select" id="prodStatus" data-stisla-select>
                      <option value="active" selected>Active</option>
                      <option value="draft">Draft</option>
                      <option value="archived">Archived</option>
                    </select>
                  </div>
                </div>
              </div>

              {# Organization #}
              <div class="card">
                <div class="card__header"><span class="card__title">Organization</span></div>
                <div class="card__body">
                  <div class="field">
                    <label for="prodCategory" class="field__label">Category</label>
                    <select class="select" id="prodCategory" data-stisla-select data-placeholder="Select category">
                      <option value=""></option>
                      <option value="coffee">Coffee</option>
                      <option value="equipment">Equipment</option>
                      <option value="supplies">Supplies</option>
                      <option value="gifts">Gifts</option>
                    </select>
                  </div>
                  <div class="field">
                    <label for="prodTags" class="field__label">Tags</label>
                    <select class="select" id="prodTags" multiple data-stisla-select data-placeholder="Add tags">
                      <option value="featured">Featured</option>
                      <option value="new">New</option>
                      <option value="sale">Sale</option>
                      <option value="seasonal">Seasonal</option>
                    </select>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="order-form__bar">
          <div class="me-auto">
            <span class="badge badge--warning badge--soft">
              {{ "solar:pen-2-linear" | icon }}
              Draft
            </span>
          </div>
          <a href="/dashboard/products.html" class="btn btn--ghost btn--neutral">Cancel</a>
          <button type="submit" class="btn btn--primary">{{ "solar:check-circle-linear" | icon }} Save product</button>
        </div>
      </form>
    </div>
  </div>
</div>
{% endblock %}
