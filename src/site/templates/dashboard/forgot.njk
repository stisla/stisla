{% extends "layouts/auth.njk" %}

{% block title %}Reset password · Meridian{% endblock %}

{% block auth %}
<div>
  <h1 class="fs-6 fw-bold m-0">Reset password</h1>
  <p class="text-muted-foreground m-0 mt-1">Enter your email and we'll send a reset link.</p>
</div>

<form class="d-flex flex-column gap-4">
  <div class="field">
    <label for="forgotEmail" class="field__label">Email</label>
    <div class="input-group">
      <span class="input-group__text">{{ "solar:letter-linear" | icon }}</span>
      <input type="email" class="input" id="forgotEmail" placeholder="you@meridian.com" autocomplete="email" />
    </div>
  </div>

  <button type="button" class="btn btn--primary btn--block btn--roomy">Send reset link {{ "solar:arrow-right-linear" | icon }}</button>
</form>

<p class="text-center m-0">
  <a href="/dashboard/login.html" class="btn btn--ghost btn--neutral btn--compact">{{ "solar:arrow-left-linear" | icon }} Back to sign in</a>
</p>
{% endblock %}
