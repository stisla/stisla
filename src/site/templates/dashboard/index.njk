{% extends "layouts/app.njk" %}
{% set nav_active = "dashboard" %}

{% block title %}Dashboard · Meridian{% endblock %}

{#
  Abstract placeholder logo marks for the Top Customers tiles. Monochrome,
  drawn in currentColor so each mark tracks the avatar tile's text token.
  Kept geometric and consistent in weight so they read as brand placeholders.
#}
{% macro logomark(kind) %}
{% if kind == "venn" %}
<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="width:1.4rem;height:1.4rem;"><circle cx="9" cy="12" r="6" opacity=".55"/><circle cx="15" cy="12" r="6" opacity=".55"/></svg>
{% elif kind == "wave" %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:1.4rem;height:1.4rem;"><path d="M4 9l8 5 8-5"/><path d="M4 14l8 5 8-5"/></svg>
{% elif kind == "star" %}
<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="width:1.4rem;height:1.4rem;"><path d="M12 2l2.3 7.4L22 12l-7.7 2.6L12 22l-2.3-7.4L2 12l7.7-2.6z"/></svg>
{% elif kind == "hex" %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" aria-hidden="true" style="width:1.4rem;height:1.4rem;"><path d="M12 2.5l8.2 4.75v9.5L12 21.5 3.8 16.75v-9.5z"/></svg>
{% elif kind == "tiles" %}
<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="width:1.4rem;height:1.4rem;"><rect x="3" y="3" width="11" height="11" rx="2.5" opacity=".55"/><rect x="10" y="10" width="11" height="11" rx="2.5"/></svg>
{% elif kind == "grid" %}
<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="width:1.4rem;height:1.4rem;"><circle cx="7" cy="7" r="3"/><circle cx="17" cy="7" r="3" opacity=".55"/><circle cx="7" cy="17" r="3" opacity=".55"/><circle cx="17" cy="17" r="3"/></svg>
{% endif %}
{% endmacro %}

{% block page %}
<div class="page content">
  <div class="content__container">
    <header class="page__header">
      <h1 class="page__title">Welcome back, <span>Steven</span> 👋</h1>
    </header>
    <div class="page__body">
      <section class="page__section">
        <div class="row g-3">
          <div class="col-12 col-xl-4">
            <div class="card card--stat">
              <div class="card__body">
                <div class="card__title">Order Statistics</div>

                <div class="stat">
                  <div class="stat__value">59</div>
                  <div class="stat__meta">
                    <span class="stat__label">Total Orders · This Month</span>
                    <span class="badge badge--soft badge--success">{{ "solar:alt-arrow-up-linear" | icon }} 11%</span>
                  </div>
                </div>

                <div class="meter meter--block meter--roomy meter--stat">
                  <div class="meter__track">
                    <span class="meter__bar meter__bar--warning" style="width: 41%;"></span>
                    <span class="meter__bar meter__bar--primary" style="width: 20%;"></span>
                    <span class="meter__bar meter__bar--success" style="width: 39%;"></span>
                  </div>
                </div>

                {% set segments = [
                  { label: "Pending",   count: "24", pct: "41%", tone: "warning" },
                  { label: "Shipping",  count: "12", pct: "20%", tone: "primary" },
                  { label: "Completed", count: "23", pct: "39%", tone: "success" }
                ] %}
                <div class="stat-detail">
                  {% for s in segments %}
                  <div class="stat-detail__col">
                    <span class="stat-detail__label">
                      <span class="indicator indicator--{{ s.tone }}"></span>
                      {{ s.label }}
                    </span>
                    <span class="stat-detail__value">{{ s.count }}</span>
                    <span class="stat-detail__pct">{{ s.pct }}</span>
                  </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>

          <div class="col-12 col-sm-6 col-xl-4">
            <div class="card card--stat">
              <div class="card__body">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="icon-box icon-box--primary icon-box--roomy">{{ "solar:dollar-minimalistic-linear" | icon }}</span>
                  <span class="badge badge--soft badge--success">{{ "solar:alt-arrow-up-linear" | icon }} 8.2%</span>
                </div>
                <div class="stat">
                  <div class="stat__value"><span class="stat__unit">$</span>187,13</div>
                  <div class="stat__label">Available Balance</div>
                </div>
                <div id="sparkBalance" class="sparkline sparkline--hero"></div>
              </div>
            </div>
          </div>

          <div class="col-12 col-sm-6 col-xl-4">
            <div class="card card--stat">
              <div class="card__body">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="icon-box icon-box--success icon-box--roomy">{{ "solar:bag-4-linear" | icon }}</span>
                  <span class="badge badge--soft badge--success">{{ "solar:alt-arrow-up-linear" | icon }} 23%</span>
                </div>
                <div class="stat">
                  <div class="stat__value">4,732</div>
                  <div class="stat__label">Units Sold · MTD</div>
                </div>
                <div id="sparkSales" class="sparkline sparkline--hero"></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="page__section">
        <div class="row g-3 align-items-start">
          <div class="col-12 col-xl-8">
            <div class="card">
              <div class="card__header">
                <span class="card__title">Sales Performance</span>
                <div class="chart-legend">
                  <span class="chart-legend__item">
                    <span class="indicator indicator--primary"></span>
                    Sales
                  </span>
                  <span class="chart-legend__item">
                    <span class="indicator indicator--danger"></span>
                    Budget
                  </span>
                </div>
              </div>
              <div class="card__body">
                <div class="chart-scroll">
                  <div id="salesChart" class="chart"></div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12 col-xl-4">
            <div class="card">
              <div class="card__header">
                <span class="card__title">Top Customers</span>
              </div>
                {% set customers = [
                  { name: "Acme Corp",         mark: "venn",  tone: "primary", orders: "18 orders", spend: "$24,910", trend: "up",   delta: "12%", intent: "success" },
                  { name: "Riverway Ltd",      mark: "wave",  tone: "info",    orders: "11 orders", spend: "$18,200", trend: "up",   delta: "6%",  intent: "success" },
                  { name: "Northwind Traders", mark: "star",  tone: "warning", orders: "9 orders",  spend: "$12,540", trend: "down", delta: "3%",  intent: "danger"  },
                  { name: "Globex",            mark: "hex",   tone: "danger",  orders: "7 orders",  spend: "$9,180",  trend: "up",   delta: "8%",  intent: "success" },
                  { name: "Initech",           mark: "tiles", tone: "success", orders: "5 orders",  spend: "$6,420",  trend: "down", delta: "2%",  intent: "danger"  },
                  { name: "Hooli",             mark: "grid",  tone: "primary", orders: "4 orders",  spend: "$5,180",  trend: "up",   delta: "5%",  intent: "success" }
                ] %}
              <div class="media-list">
                {% for c in customers %}
                <div class="media media--flush">
                  <span class="avatar" style="--avatar-bg: color-mix(in oklch, var(--st-{{ c.tone }}) 16%, transparent); --avatar-color: var(--st-{{ c.tone }});">{{ logomark(c.mark) }}</span>
                  <div class="media__content">
                    <div class="media__title">{{ c.name }}</div>
                    <div class="media__meta">{{ c.orders }}</div>
                  </div>
                  <div class="text-end">
                    <div class="fw-semibold">{{ c.spend }}</div>
                    <span class="badge badge--soft badge--{{ c.intent }} fs-1">
                      {{ ("solar:graph-" + c.trend + "-linear") | icon }} {{ c.delta }}
                    </span>
                  </div>
                </div>
                {% endfor %}
              </div>
              <div class="card__footer">
                <a href="#" class="btn btn--roomy btn--neutral btn--block">View All</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="page__section">
        <div class="row g-3 align-items-stretch">
          <div class="col-12 col-sm-6 col-xl-3">
            <div class="card h-100">
              <div class="card__header">
                <span class="card__title">Conversion Funnel</span>
              </div>
              <div class="card__body gap-5">
                {% set funnel = [
                  { label: "Sessions",      value: "18,420", pct: 100, delta: null },
                  { label: "Product Views", value: "12,100", pct: 66,  delta: "-34%" },
                  { label: "Add to Cart",   value: "7,250",  pct: 39,  delta: "-40%" },
                  { label: "Checkout",      value: "3,980",  pct: 22,  delta: "-45%" },
                  { label: "Payment Info",  value: "2,890",  pct: 16,  delta: "-27%" },
                  { label: "Purchased",     value: "2,140",  pct: 12,  delta: "-26%" }
                ] %}
                {% for f in funnel %}
                <div class="meter">
                  <span class="meter__label">{{ f.label }}</span>
                  <span class="meter__value text-foreground fw-medium">
                    {{ f.value }}{% if f.delta %}
                    <span class="fs-1 text-muted-foreground">{{ f.delta }}</span>
                    {% endif %}
                  </span>
                  <div class="meter__track">
                    <span class="meter__bar meter__bar--primary" style="width: {{ f.pct }}%;"></span>
                  </div>
                </div>
                {% endfor %}
              </div>
            </div>
          </div>

          <div class="col-12 col-sm-6 col-xl-3">
            <div class="card h-100">
              <div class="card__header">
                <span class="card__title">Fulfillment</span>
              </div>
              <div class="card__body">
                <div id="fulfillmentChart" class="chart"></div>
                <div class="stat-detail">
                  <div class="stat-detail__col align-items-center">
                    <div class="stat-detail__label">Avg ship</div>
                    <div class="stat-detail__value">1.2d</div>
                  </div>
                  <div class="stat-detail__col align-items-center">
                    <div class="stat-detail__label">Returns</div>
                    <div class="stat-detail__value">0.4%</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12 col-sm-6 col-xl-3">
            <div class="card h-100">
              <div class="card__header">
                <span class="card__title">Order Heatmap</span>
              </div>
              <div class="card__body">
                <div class="d-flex align-items-center">
                  <span class="fs-4 fw-light">Fri · 6PM</span>
                  <span class="fs-1 text-muted-foreground ms-2">Peak window</span>
                </div>
                <div id="heatmapChart" class="chart"></div>
                <div class="heatmap-legend">
                  <span class="heatmap-legend__caption">Less</span>
                  <span class="heatmap-legend__swatch" style="opacity: .15;"></span>
                  <span class="heatmap-legend__swatch" style="opacity: .4;"></span>
                  <span class="heatmap-legend__swatch" style="opacity: .65;"></span>
                  <span class="heatmap-legend__swatch" style="opacity: .85;"></span>
                  <span class="heatmap-legend__swatch" style="opacity: 1;"></span>
                  <span class="heatmap-legend__caption">More</span>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12 col-sm-6 col-xl-3">
            <div class="card h-100">
              <div class="card__header">
                <span class="card__title">Recent Activity</span>
              </div>
              <div class="card__body">
                {% set activity = [
                  { tone: "success", time: "2 min ago",  body: 'New order <a href="#">#QC-7841</a> from Acme Corp' },
                  { tone: "primary", time: "9 min ago",  body: 'Payment captured · <a href="#">$2,410</a>' },
                  { tone: "warning", time: "22 min ago", body: 'Low stock alert · Ion Membrane Pack' },
                  { tone: "danger",  time: "41 min ago", body: 'Refund issued <a href="#">#QC-7802</a>' },
                  { tone: "primary", time: "1 hr ago",   body: 'New customer · Globex onboarded' }
                ] %}
                <ol class="timeline">
                  {% for a in activity %}
                  <li class="timeline__item">
                    <span class="timeline__marker timeline__marker--{{ a.tone }}"></span>
                    <div class="timeline__body">
                      <div class="timeline__title">{{ a.body | safe }}</div>
                      <div class="timeline__time">{{ a.time }}</div>
                    </div>
                  </li>
                  {% endfor %}
                </ol>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="page__section">
        <div class="card">
          <div class="card__header">
            <span class="card__title">Recent Orders</span>
            <a href="/dashboard/orders.html" class="ms-auto btn btn--neutral btn--ghost btn--compact">View all</a>
          </div>
          {% set orderStatus = {
            pending:   { label: "Pending",   tone: "warning", icon: "solar:clock-circle-linear" },
            shipped:   { label: "Shipped",   tone: "info",    icon: "solar:delivery-linear" },
            completed: { label: "Completed", tone: "success", icon: "solar:check-circle-linear" },
            refunded:  { label: "Refunded",  tone: "danger",  icon: "solar:refresh-linear" }
          } %}
          {% set orders = [
            { id: "10428", name: "Acme Corp",         email: "billing@acme.co",       img: 12, initials: "AC", date: "Jun 18", items: 6,  total: "$1,490.00", status: "pending" },
            { id: "10427", name: "Riverway Ltd",      email: "ap@riverway.io",        img: 32, initials: "RL", date: "Jun 17", items: 2,  total: "$580.00",   status: "shipped" },
            { id: "10426", name: "Northwind Traders", email: "orders@northwind.com",  img: 48, initials: "NT", date: "Jun 17", items: 18, total: "$8,200.00", status: "completed" },
            { id: "10425", name: "Globex",            email: "buy@globex.com",        img: 15, initials: "GX", date: "Jun 16", items: 1,  total: "$240.00",   status: "refunded" },
            { id: "10424", name: "Initech",           email: "po@initech.com",        img: 5,  initials: "IN", date: "Jun 15", items: 4,  total: "$1,120.00", status: "completed" }
          ] %}
          <div class="table-responsive">
            <table class="table table--hover table--align-middle mb-0">
              <thead class="table__head--alt">
                <tr>
                  <th scope="col">Order</th>
                  <th scope="col">Customer</th>
                  <th scope="col">Date</th>
                  <th scope="col" class="text-end">Items</th>
                  <th scope="col">Status</th>
                  <th scope="col" class="text-end">Total</th>
                </tr>
              </thead>
              <tbody>
                {% for o in orders %}
                {% set s = orderStatus[o.status] %}
                <tr>
                  <th scope="row"><a href="/dashboard/order-detail.html" class="link"><code>#{{ o.id }}</code></a></th>
                  <td>
                    <div class="d-flex align-items-center gap-3">
                      <span class="avatar avatar--compact avatar--circle" data-stisla-avatar>
                        <img class="avatar__image" src="https://i.pravatar.cc/64?img={{ o.img }}" alt="">
                        <span class="avatar__fallback">{{ o.initials }}</span>
                      </span>
                      <div>
                        <div class="fw-medium">{{ o.name }}</div>
                        <div class="fs-1 text-muted-foreground">{{ o.email }}</div>
                      </div>
                    </div>
                  </td>
                  <td>{{ o.date }}</td>
                  <td class="text-end">{{ o.items }}</td>
                  <td><span class="badge badge--soft badge--{{ s.tone }}">{{ s.icon | icon }} {{ s.label }}</span></td>
                  <td class="text-end"><span class="fw-semibold">{{ o.total }}</span></td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
{% endblock %}
