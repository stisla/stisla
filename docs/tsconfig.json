{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "strict": true,
    "types": ["vite/client"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@stisla/react": ["../packages/react/src/index.ts"],
      "@stisla/style": ["../packages/style/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
